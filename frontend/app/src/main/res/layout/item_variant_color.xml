<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_chip_outline"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="4dp">

    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp">

        <View
            android:id="@+id/viewSelectionBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_swatch_selected"
            android:visibility="gone" />

        <View
            android:id="@+id/viewColorCircle"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_circle" />

        <ImageView
            android:id="@+id/ivTick"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="center"
            android:contentDescription="@string/content_desc_selected"
            android:src="@drawable/ic_tick"
            android:visibility="gone"
            app:tint="@color/text_inverse" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvVariantName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginEnd="6dp"
        android:fontFamily="@font/nunito_regular"
        android:textColor="@color/text_main"
        android:textSize="13sp"
        tools:text="#001 Rose Red" />

</LinearLayout>
