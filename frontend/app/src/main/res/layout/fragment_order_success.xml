<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="@dimen/spacing_l">

    <!-- Top Branding -->
    <LinearLayout
        android:id="@+id/layoutBranding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:letterSpacing="0.2"
            android:text="KANILA"
            android:textColor="@color/button"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_regular"
            android:letterSpacing="0.4"
            android:text="BEAUTY"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Success Icon -->
    <FrameLayout
        android:id="@+id/layoutSuccessIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="35dp"
        android:background="@drawable/bg_circle_pink"
        android:backgroundTint="@color/button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutBranding">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            app:tint="@color/white" />
    </FrameLayout>

    <!-- Title and Description -->
    <TextView
        android:id="@+id/tvSuccessTitle"
        style="@style/Text.Kanila.H2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/order_success_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutSuccessIcon" />

    <TextView
        android:id="@+id/tvSuccessDesc"
        style="@style/Text.Kanila.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/order_success_desc"
        android:textColor="@color/text_tertiary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessTitle" />

    <!-- Order Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardOrderInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSuccessDesc"
        app:strokeColor="@color/border_divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_m">

            <!-- Order Code -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <ImageView
                    android:id="@+id/ivCode"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_checklist"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/ivCode"
                    android:text="@string/order_success_code"
                    style="@style/Text.Kanila.Body"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tvOrderCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="KNL2505150001"
                    android:textColor="@color/button"
                    android:textSize="14sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_divider" />

            <!-- Payment Method -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <ImageView
                    android:id="@+id/ivPayment"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_paymeny_card"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/ivPayment"
                    android:text="@string/order_success_payment"
                    style="@style/Text.Kanila.Body"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tvPaymentMethod"
                    android:layout_width="150dp"
                    android:gravity="right"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="MoMo"
                    android:textColor="@color/text_main"
                    android:textSize="14sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_divider" />

            <!-- Delivery Time -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <ImageView
                    android:id="@+id/ivDelivery"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_delivery_truck"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/ivDelivery"
                    android:text="@string/order_success_delivery"
                    style="@style/Text.Kanila.Body"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tvDeliveryTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/nunito_bold"
                    android:gravity="end"
                    android:text="17/05/2025\n(Thứ Bảy)"
                    android:textColor="@color/button"
                    android:textSize="14sp" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_divider" />

            <!-- Amount -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp">

                <ImageView
                    android:id="@+id/ivAmount"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_wallet"
                    app:tint="@color/text_tertiary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:layout_toEndOf="@id/ivAmount"
                    android:text="@string/order_success_amount"
                    style="@style/Text.Kanila.Body"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="629.000đ"
                    android:textColor="@color/button"
                    android:textSize="14sp" />
            </RelativeLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Reward Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardReward"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/background_sub"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardOrderInfo"
        app:strokeColor="@color/primary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_m">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_star"
                app:tint="@color/button" />

            <TextView
                android:id="@+id/tvRewardPoints"
                style="@style/Text.Kanila.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/order_success_reward"
                android:textColor="@color/text_main" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTrackOrder"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="32dp"
        android:text="@string/order_success_track"
        app:icon="@drawable/ic_delivery_truck"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/cardReward" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueShopping"
        style="@style/Widget.Kanila.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="12dp"
        android:text="@string/order_success_continue"
        app:icon="@drawable/ic_shopping_bag"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/btnTrackOrder" />

</androidx.constraintlayout.widget.ConstraintLayout>
