<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Banner Slider Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <include
                android:id="@+id/layoutHomeBanner"
                layout="@layout/view_home_banner_slider" />

        </FrameLayout>

        <!-- Home Shortcut Section -->
        <LinearLayout
            android:id="@+id/layoutHomeShortcutSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_m"
            android:layout_marginTop="@dimen/spacing_m"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:paddingVertical="@dimen/spacing_s">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHomeShortcuts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_s"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_home_shortcut" />

        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_m"
            android:layout_marginTop="@dimen/spacing_l"
            android:layout_marginBottom="@dimen/spacing_s">

            <TextView
                android:id="@+id/tvProductSectionTitle"
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Gợi ý riêng cho bạn"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/btnViewAllProducts"
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Xem tất cả"
                android:textColor="@color/pink_primary" />
        </RelativeLayout>

        <!-- Recommended Products RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecommendedProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_m"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_product_card" />

        <!-- Loading / Error States -->
        <FrameLayout
            android:id="@+id/layoutHomeStateContainer"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:visibility="gone">

            <include
                android:id="@+id/viewHomeLoading"
                layout="@layout/view_loading_state"
                android:visibility="gone" />

            <include
                android:id="@+id/viewHomeError"
                layout="@layout/view_error_generic"
                android:visibility="gone" />
        </FrameLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
