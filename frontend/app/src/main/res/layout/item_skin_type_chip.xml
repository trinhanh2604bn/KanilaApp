<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_s"
    android:background="@drawable/bg_create_post_chip_default"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing_m"
    android:paddingVertical="@dimen/spacing_s">

    <TextView
        android:id="@+id/tvChipLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_semibold"
        android:textColor="@color/text_main"
        android:textSize="13sp"
        tools:text="Da dầu mụn" />

    <ImageView
        android:id="@+id/ivCheckIcon"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="@dimen/spacing_xs"
        android:src="@drawable/ic_check_circle"
        android:visibility="gone"
        app:tint="@color/button"
        android:contentDescription="@null"
        tools:visibility="visible" />

</LinearLayout>