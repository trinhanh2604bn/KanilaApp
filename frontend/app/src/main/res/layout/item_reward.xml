<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardPreventCornerOverlap="false">

    <LinearLayout
        android:id="@+id/layoutRewardItem"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:background="@drawable/bg_reward"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivRewardIllustration"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:contentDescription="Reward illustration"
            android:scaleType="centerInside"
            android:src="@drawable/bg_reward_icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvRewardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="Chia sẻ để nhận reward!"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                tools:text="Chia sẻ để nhận reward!" />

            <TextView
                android:id="@+id/tvRewardDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:maxLines="3"
                android:text="Bài viết có nhiều lượt tương tác sẽ nhận voucher hấp dẫn mỗi tuần."
                android:textColor="@color/text_main"
                android:textSize="11sp"
                tools:text="Bài viết có nhiều lượt tương tác sẽ nhận voucher hấp dẫn mỗi tuần." />

            <TextView
                android:id="@+id/btnRewardRule"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_primary_pill_button"
                android:fontFamily="@font/nunito_semibold"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="Xem thể lệ →"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                tools:text="Xem thể lệ →" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRewardPointLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="Điểm của bạn"
                android:textColor="@color/text_main"
                android:textSize="11sp"
                tools:text="Điểm của bạn" />

            <TextView
                android:id="@+id/tvRewardPoint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="2.460 P"
                android:textColor="@color/button"
                android:textSize="22sp"
                tools:text="2.460 P" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvRewardRankLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_regular"
                    android:text="Bậc hiện tại: "
                    android:textColor="@color/text_main"
                    android:textSize="10sp"
                    tools:text="Bậc hiện tại: " />

                <TextView
                    android:id="@+id/tvRewardRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Gold"
                    android:textColor="@color/button"
                    android:textSize="10sp"
                    tools:text="Gold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressRewardRank"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="4dp"
                android:progress="80"
                android:progressTint="@color/primary" />

            <TextView
                android:id="@+id/tvRewardNextRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito_regular"
                android:text="Cần thêm 540 điểm để lên hạng Platinum"
                android:textColor="@color/text_main"
                android:textSize="9sp"
                tools:text="Cần thêm 540 điểm để lên hạng Platinum" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
