<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Banner Slider Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <include
                android:id="@+id/layoutHomeBanner"
                layout="@layout/view_home_banner_slider" />

        </FrameLayout>

        <!-- Home Shortcut Section -->
        <LinearLayout
            android:id="@+id/layoutHomeShortcutSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_m"
            android:layout_marginTop="@dimen/spacing_m"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:paddingVertical="@dimen/spacing_s">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHomeShortcuts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_s"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_home_shortcut" />

        </LinearLayout>

        <include layout="@layout/view_home_social_section" />

        <!-- Shop Catalog Section -->
        <LinearLayout
            android:id="@+id/layoutHomeCatalog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_l"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_m"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCatalogTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Dành riêng cho bạn"
                    android:textColor="@color/text_main"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tvCatalogSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/nunito_regular"
                    android:text="Khám phá thêm các sản phẩm Kanila đang có"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAllProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/spacing_m"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/item_product_card" />

        </LinearLayout>

        <!-- Personalized Recommendation Section -->
        <LinearLayout
            android:id="@+id/layoutHomeRecommendation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_l"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_m">

                <TextView
                    android:id="@+id/tvRecommendationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Gợi ý riêng cho bạn"
                    android:textColor="@color/text_main"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/btnViewAllRecommended"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignTop="@id/tvRecommendationTitle"
                    android:layout_alignBottom="@id/tvRecommendationTitle"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:fontFamily="@font/nunito_medium"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="4dp"
                    android:text="Xem tất cả"
                    android:textColor="@color/pink_primary"
                    android:textSize="14sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/tvRecommendationSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvRecommendationTitle"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/nunito_regular"
                    android:text="Dựa trên hồ sơ làm đẹp và sở thích của bạn"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecommendedProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_m"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_product_card" />

            <!-- Personalized Recommendation Error State -->
            <LinearLayout
                android:id="@+id/layoutRecommendedError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvRecommendedError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_regular"
                    android:text="Không thể tải gợi ý sản phẩm. Vui lòng thử lại."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/btnRecommendedRetry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_chip_outline"
                    android:fontFamily="@font/nunito_bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Thử lại"
                    android:textColor="@color/pink_primary"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Loading / Error States -->
        <FrameLayout
            android:id="@+id/layoutHomeStateContainer"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:visibility="gone">

            <include
                android:id="@+id/viewHomeLoading"
                layout="@layout/view_loading_state"
                android:visibility="gone" />

            <include
                android:id="@+id/viewHomeError"
                layout="@layout/view_error_generic"
                android:visibility="gone" />
        </FrameLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
