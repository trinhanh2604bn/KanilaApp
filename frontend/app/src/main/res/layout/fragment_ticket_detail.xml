<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:paddingTop="32dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/border_divider"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/content_desc_back"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/accent_dark" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ticket_detail_title"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/action_share"
            android:padding="10dp"
            android:src="@drawable/ic_share"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutBottom"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- Ticket Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_ticket_id"
                        android:textColor="@color/text_tertiary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/Text.Kanila.H3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ticket_id_sample"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_bookmark_outline"
                            app:tint="@color/text_tertiary" />
                    </LinearLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                style="@style/Text.Kanila.Micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_issue_type"
                                android:textColor="@color/text_tertiary" />

                            <TextView
                                style="@style/Text.Kanila.BodyMedium"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/issue_return"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:orientation="vertical"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <TextView
                                style="@style/Text.Kanila.Micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Trạng thái hiện tại"
                                android:textColor="@color/text_tertiary"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:background="@drawable/bg_chip_pill"
                                android:backgroundTint="@color/status_pending_bg"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="4dp"
                                android:text="@string/status_processing_text"
                                android:textColor="@color/status_pending_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Process Timeline Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.Kanila.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_process_title"
                        android:textColor="@color/accent_dark"
                        android:textStyle="bold" />

                    <!-- Steps -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical">

                        <!-- Step 1 -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/ivStep1"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/burgundy"
                                android:padding="4dp"
                                android:src="@drawable/ic_check"
                                app:tint="@color/white"
                                android:contentDescription="@null"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <View
                                android:id="@+id/line1"
                                android:layout_width="2dp"
                                android:layout_height="40dp"
                                android:background="@color/burgundy"
                                app:layout_constraintStart_toStartOf="@id/ivStep1"
                                app:layout_constraintEnd_toEndOf="@id/ivStep1"
                                app:layout_constraintTop_toBottomOf="@id/ivStep1" />

                            <TextView
                                android:id="@+id/tvStep1"
                                style="@style/Text.Kanila.BodyMedium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="8dp"
                                android:text="@string/step_received"
                                android:textStyle="bold"
                                app:layout_constraintStart_toEndOf="@id/ivStep1"
                                app:layout_constraintTop_toTopOf="@id/ivStep1"
                                app:layout_constraintEnd_toStartOf="@+id/tvTime1" />

                            <TextView
                                android:id="@+id/tvTime1"
                                style="@style/Text.Kanila.Micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12/05/2025 10:15"
                                android:textColor="@color/text_tertiary"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/ivStep1"
                                tools:ignore="HardcodedText" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Step 2 (Current) -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp">

                            <ImageView
                                android:id="@+id/ivStep2"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/burgundy"
                                android:padding="4dp"
                                android:src="@drawable/bg_circle"
                                app:tint="@color/white"
                                android:contentDescription="@null"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <View
                                android:id="@+id/line2"
                                android:layout_width="2dp"
                                android:layout_height="40dp"
                                android:background="@color/border_divider"
                                app:layout_constraintStart_toStartOf="@id/ivStep2"
                                app:layout_constraintEnd_toEndOf="@id/ivStep2"
                                app:layout_constraintTop_toBottomOf="@id/ivStep2" />

                            <TextView
                                android:id="@+id/tvStep2"
                                style="@style/Text.Kanila.BodyMedium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="8dp"
                                android:text="@string/step_verifying"
                                android:textStyle="bold"
                                app:layout_constraintStart_toEndOf="@id/ivStep2"
                                app:layout_constraintTop_toTopOf="@id/ivStep2"
                                app:layout_constraintEnd_toStartOf="@+id/tvTime2" />

                            <TextView
                                android:id="@+id/tvTime2"
                                style="@style/Text.Kanila.Micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12/05/2025 11:02"
                                android:textColor="@color/text_tertiary"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/ivStep2"
                                tools:ignore="HardcodedText" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Step 3 -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp">

                            <ImageView
                                android:id="@+id/ivStep3"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/border_divider"
                                android:padding="4dp"
                                android:src="@drawable/bg_circle"
                                app:tint="@color/white"
                                android:contentDescription="@null"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <View
                                android:id="@+id/line3"
                                android:layout_width="2dp"
                                android:layout_height="40dp"
                                android:background="@color/border_divider"
                                app:layout_constraintStart_toStartOf="@id/ivStep3"
                                app:layout_constraintEnd_toEndOf="@id/ivStep3"
                                app:layout_constraintTop_toBottomOf="@id/ivStep3" />

                            <TextView
                                android:id="@+id/tvStep3"
                                style="@style/Text.Kanila.BodyMedium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="8dp"
                                android:text="@string/step_replied"
                                android:textColor="@color/text_tertiary"
                                app:layout_constraintStart_toEndOf="@id/ivStep3"
                                app:layout_constraintTop_toTopOf="@id/ivStep3"
                                app:layout_constraintEnd_toStartOf="@+id/tvTime3" />

                            <TextView
                                android:id="@+id/tvTime3"
                                style="@style/Text.Kanila.Micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="–"
                                android:textColor="@color/text_tertiary"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/ivStep3"
                                tools:ignore="HardcodedText" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- Step 4 -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp">

                            <ImageView
                                android:id="@+id/ivStep4"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="@color/border_divider"
                                android:padding="4dp"
                                android:src="@drawable/bg_circle"
                                app:tint="@color/white"
                                android:contentDescription="@null"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvStep4"
                                style="@style/Text.Kanila.BodyMedium"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="8dp"
                                android:text="@string/step_completed"
                                android:textColor="@color/text_tertiary"
                                app:layout_constraintStart_toEndOf="@id/ivStep4"
                                app:layout_constraintTop_toTopOf="@id/ivStep4"
                                app:layout_constraintEnd_toStartOf="@+id/tvTime4" />

                            <TextView
                                android:id="@+id/tvTime4"
                                style="@style/Text.Kanila.Micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="–"
                                android:textColor="@color/text_tertiary"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/ivStep4"
                                tools:ignore="HardcodedText" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Latest Content Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.Kanila.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_latest_content"
                        android:textColor="@color/button"
                        android:textStyle="bold" />

                    <TextView
                        style="@style/Text.Kanila.Body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/content_sample"
                        android:textColor="@color/text_main" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/content_update_info"
                        android:textColor="@color/text_tertiary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Info Footer Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_alert"
                        app:tint="@color/burgundy"
                        android:contentDescription="@null" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_sla"
                            android:textColor="@color/text_tertiary" />
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/sla_value"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical|end"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_clock"
                        app:tint="@color/text_tertiary"
                        android:contentDescription="@null" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_last_update"
                            android:textColor="@color/text_tertiary" />
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/last_update_sample"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buttons Area -->
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddInfo"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_add_info"
            android:backgroundTint="@color/burgundy"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseTicket"
                style="@style/Widget.Kanila.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_close_ticket"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border_divider" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRate"
                style="@style/Widget.Kanila.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/btn_rate_support"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/border_divider"
                app:icon="@drawable/ic_star"
                app:iconSize="16dp"
                app:iconGravity="textStart" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
