<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp">

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_avatar_circle"
        android:padding="7dp"
        android:src="@drawable/ic_chat_placeholder"
        app:tint="@color/burgundy"
        android:contentDescription="Kanila AI" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="AI Assistant"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="280dp"
            android:background="@drawable/bg_bubble_bot"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:lineSpacingExtra="2dp"
            android:text="Chào bạn! Mình là Kanila AI Assistant. Mình có thể giúp gì cho bạn hôm nay?"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="09:41"
            android:textColor="@color/text_tertiary"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>