<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardOrder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_m"
    android:layout_marginVertical="@dimen/spacing_xs"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="@dimen/radius_m"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_m">

        <!-- Card Header: Store/Brand & Status -->
        <LinearLayout
            android:id="@+id/layoutOrderHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_m"
            android:paddingTop="@dimen/spacing_m">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_routine"
                app:tint="@color/text_main" />

            <TextView
                android:id="@+id/tvOrderBrandName"
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Kanila Official"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvOrderHeaderStatus"
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoàn thành"
                android:textColor="@color/button" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/border_divider" />

            <TextView
                android:id="@+id/tvPaymentStatus"
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã thanh toán"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Order Info: Code & Date -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_m"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvOrderNumber"
                style="@style/Text.Kanila.Micro"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mã đơn: KNL123456"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvOrderDate"
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20/07/2024"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <View
            android:id="@+id/dividerOrder"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_s"
            android:background="@color/border_divider" />

        <!-- Order Content: Inherit from item_cart_selected structure -->
        <include
            android:id="@+id/layoutOrderItemContent"
            layout="@layout/item_cart_selected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_m" />

        <!-- Total Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_m">

            <TextView
                android:id="@+id/tvOrderTotalSummary"
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng số tiền (1 sản phẩm): "
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvOrderGrandTotal"
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="245.000đ"
                android:textColor="@color/button" />
        </LinearLayout>

        <!-- Action Area -->
        <LinearLayout
            android:id="@+id/layoutOrderActionArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_m"
            android:gravity="end|center_vertical"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_m">

            <TextView
                android:id="@+id/tvOrderProcessingDisclaimer"
                style="@style/Text.Kanila.Micro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Vui lòng chỉ nhấn Đã nhận được hàng khi đơn hàng đã được giao đến bạn và sản phẩm nhận được không có vấn đề nào."
                android:textColor="@color/text_secondary"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOrderReturn"
                    style="@style/Widget.Kanila.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:minWidth="100dp"
                    android:paddingHorizontal="16dp"
                    android:text="Trả hàng/Hoàn tiền"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOrderAction"
                    style="@style/Widget.Kanila.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:minWidth="100dp"
                    android:paddingHorizontal="16dp"
                    android:text="Đánh giá"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
