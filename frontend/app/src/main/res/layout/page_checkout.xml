<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sub"
    android:orientation="vertical">

    <!-- Header -->
    <include
        android:id="@+id/layoutTopBar"
        layout="@layout/view_app_top_bar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- 1. Address Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCheckoutAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_s"
                android:layout_marginVertical="@dimen/spacing_xs"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="false"
                app:strokeColor="@color/background_sub"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Summary Area -->
                    <include
                        android:id="@+id/layoutCheckoutAddressSummary"
                        layout="@layout/view_checkout_option_card" />

                    <!-- Expandable Form Area -->
                    <LinearLayout
                        android:id="@+id/layoutCheckoutAddressForm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="@dimen/spacing_l"
                        android:paddingBottom="@dimen/spacing_l"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/spacing_m"
                            app:dividerColor="@color/border_divider" />

                        <!-- Name -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="@string/checkout_address_form_name"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/checkout_edtAddressFullName"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/label_input_spacing"
                            android:background="@drawable/bg_kanila_input_default"
                            android:fontFamily="@font/nunito_regular"
                            android:hint="@string/auth_full_name_hint"
                            android:inputType="textPersonName"
                            android:autofillHints="name"
                            android:paddingHorizontal="@dimen/spacing_m"
                            android:textColor="@color/text_main"
                            android:textSize="14sp" />

                        <!-- Phone -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/form_field_spacing"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="@string/checkout_address_form_phone"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/checkout_edtAddressPhone"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/label_input_spacing"
                            android:background="@drawable/bg_kanila_input_default"
                            android:fontFamily="@font/nunito_regular"
                            android:hint="@string/auth_phone_hint"
                            android:inputType="phone"
                            android:autofillHints="phone"
                            android:paddingHorizontal="@dimen/spacing_m"
                            android:textColor="@color/text_main"
                            android:textSize="14sp" />

                        <!-- City/Province -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/form_field_spacing"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="@string/checkout_address_form_city"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/checkout_edtAddressCity"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/label_input_spacing"
                            android:background="@drawable/bg_kanila_input_default"
                            android:drawableEnd="@drawable/ic_chevron_down"
                            android:focusable="false"
                            android:fontFamily="@font/nunito_regular"
                            android:hint="@string/checkout_address_form_city"
                            android:inputType="text"
                            android:autofillHints="postalAddressRegion"
                            android:paddingHorizontal="@dimen/spacing_m"
                            android:textColor="@color/text_main"
                            android:textSize="14sp" />

                        <!-- District -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/form_field_spacing"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="@string/checkout_address_form_district"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/checkout_edtAddressDistrict"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/label_input_spacing"
                            android:background="@drawable/bg_kanila_input_default"
                            android:drawableEnd="@drawable/ic_chevron_down"
                            android:focusable="false"
                            android:fontFamily="@font/nunito_regular"
                            android:hint="@string/checkout_address_form_district"
                            android:inputType="text"
                            android:autofillHints="postalAddressLocality"
                            android:paddingHorizontal="@dimen/spacing_m"
                            android:textColor="@color/text_main"
                            android:textSize="14sp" />

                        <!-- Ward -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/form_field_spacing"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="@string/checkout_address_form_ward"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/checkout_edtAddressWard"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:layout_marginTop="@dimen/label_input_spacing"
                            android:background="@drawable/bg_kanila_input_default"
                            android:drawableEnd="@drawable/ic_chevron_down"
                            android:focusable="false"
                            android:fontFamily="@font/nunito_regular"
                            android:hint="@string/checkout_address_form_ward"
                            android:inputType="text"
                            android:autofillHints="none"
                            android:paddingHorizontal="@dimen/spacing_m"
                            android:textColor="@color/text_main"
                            android:textSize="14sp" />

                        <!-- Detail Address -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/form_field_spacing"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="@string/checkout_address_form_detail"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/checkout_edtAddressDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/label_input_spacing"
                            android:background="@drawable/bg_kanila_input_default"
                            android:fontFamily="@font/nunito_regular"
                            android:hint="@string/checkout_address_form_detail"
                            android:inputType="textMultiLine"
                            android:autofillHints="streetAddress"
                            android:minHeight="@dimen/input_height"
                            android:padding="@dimen/spacing_m"
                            android:textColor="@color/text_main"
                            android:textSize="14sp" />

                        <!-- Note -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/form_field_spacing"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="@string/checkout_address_form_note"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <EditText
                            android:id="@+id/checkout_edtAddressNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/label_input_spacing"
                            android:background="@drawable/bg_kanila_input_default"
                            android:fontFamily="@font/nunito_regular"
                            android:hint="@string/checkout_note_hint"
                            android:inputType="text"
                            android:autofillHints="none"
                            android:minHeight="40dp"
                            android:paddingHorizontal="@dimen/spacing_m"
                            android:textColor="@color/text_main"
                            android:textSize="13sp" />

                        <!-- Save to Address Book Checkbox -->
                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/checkout_cbSaveToAddressBook"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_s"
                            android:fontFamily="@font/nunito_regular"
                            android:text="@string/checkout_address_save_to_book"
                            android:textColor="@color/text_main"
                            android:textSize="13sp"
                            app:buttonTint="@color/primary" />

                        <!-- Select Other Address Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/checkout_btnSelectOtherAddress"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="@dimen/spacing_s"
                            android:fontFamily="@font/nunito_bold"
                            android:text="@string/checkout_address_select_other"
                            android:textColor="@color/button"
                            android:textSize="13sp"
                            app:icon="@drawable/ic_location"
                            app:iconPadding="@dimen/spacing_xs"
                            app:iconSize="16dp"
                            app:iconTint="@color/button" />

                        <!-- Action Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_m"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/checkout_btnCancelAddressEdit"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/spacing_s"
                                android:layout_weight="1"
                                android:text="@string/action_cancel"
                                android:textColor="@color/text_secondary"
                                app:strokeColor="@color/border_divider" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/checkout_btnApplyAddressEdit"
                                style="@style/Widget.Kanila.Button.Primary"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_s"
                                android:layout_weight="1"
                                android:text="@string/action_apply" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Shipping Section -->
            <include
                android:id="@+id/layoutCheckoutShipping"
                layout="@layout/view_checkout_option_card" />

            <!-- 3. Payment Section -->
            <include
                android:id="@+id/layoutCheckoutPayment"
                layout="@layout/view_checkout_option_card" />

            <!-- 4. Voucher Section -->
            <include
                android:id="@+id/layoutCheckoutVoucher"
                layout="@layout/view_checkout_option_card" />

            <!-- 5. Selected Products Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_s"
                android:layout_marginVertical="@dimen/spacing_xs"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="false"
                app:strokeColor="@color/background_sub"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_m">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_s"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/checkout_selected_items"
                        android:textColor="@color/accent_dark"
                        android:textSize="14sp" />

                    <!-- Selected items list -->
                    <LinearLayout
                        android:id="@+id/layoutCheckoutItemsList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Items are added dynamically in CheckoutFragment.bindItems using item_cart layout -->

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 6. Ghi chú Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutCheckoutNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_s"
                android:layout_marginVertical="@dimen/spacing_xs"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="false"
                app:strokeColor="@color/background_sub"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_m">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/checkout_note_title"
                        android:textColor="@color/accent_dark"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edtCheckoutNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_s"
                        android:autofillHints="none"
                        android:background="@drawable/bg_kanila_input_default"
                        android:fontFamily="@font/nunito_regular"
                        android:hint="@string/checkout_note_hint"
                        android:inputType="text"
                        android:minHeight="40dp"
                        android:paddingHorizontal="@dimen/spacing_m"
                        android:textColor="@color/text_main"
                        android:textColorHint="@color/text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 7. Sử dụng xu Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutCheckoutCoins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_s"
                android:layout_marginVertical="@dimen/spacing_xs"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="false"
                app:strokeColor="@color/background_sub"
                app:strokeWidth="1dp">

            </com.google.android.material.card.MaterialCardView>

            <!-- 8. Price Summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_l">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_s">

                    <TextView
                        android:id="@+id/tvCheckoutPriceSubtotalLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvCheckoutPriceSubtotalValue"
                        android:fontFamily="@font/nunito_regular"
                        android:text="@string/checkout_price_subtotal"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        tools:text="Tạm tính (4 sản phẩm)" />

                    <TextView
                        android:id="@+id/tvCheckoutPriceSubtotalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        tools:text="970.000đ" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_s">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvCheckoutPriceShippingValue"
                        android:fontFamily="@font/nunito_regular"
                        android:text="@string/checkout_price_shipping"
                        android:textColor="@color/text_main"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvCheckoutPriceShippingValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        tools:text="40.000đ" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_s">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvCheckoutPriceDiscountValue"
                        android:fontFamily="@font/nunito_regular"
                        android:text="@string/checkout_price_discount"
                        android:textColor="@color/text_main"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvCheckoutPriceDiscountValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        tools:text="-100.000đ" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_s">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvCheckoutPricePointsValue"
                        android:fontFamily="@font/nunito_regular"
                        android:text="@string/checkout_price_points"
                        android:textColor="@color/text_main"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvCheckoutPricePointsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        tools:text="-10.000đ" />
                </RelativeLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="@dimen/spacing_s"
                    app:dividerColor="@color/border_divider" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_l">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/tvCheckoutTotalFinal"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/checkout_total_label"
                        android:textColor="@color/text_main"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvCheckoutTotalFinal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/nunito_bold"
                        android:textColor="@color/button"
                        android:textSize="18sp"
                        tools:text="800.000đ" />
                </RelativeLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlaceOrder"
                    style="@style/Widget.Kanila.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/checkout_place_order" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
