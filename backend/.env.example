PORT=5000
NODE_ENV=development
MONGO_URI=
MONGO_DB_NAME=kanila

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Compatibility with existing code
JWT_SECRET=
JWT_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5

EMAIL_PROVIDER=
EMAIL_FROM=
EMAIL_API_KEY=

SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_NAME=

APP_BASE_URL=

# SMTP for development (used by existing controller)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Vertex AI (Kanila AI — Chatbot & Review Summary) ──────────────────────
# Authentication: Vertex AI Express API key
# Obtain from: Google Cloud Console → APIs & Services → Credentials
# Docs: docs/VERTEX_AI_SETUP.md
# WARNING: Never commit your real key. Add to environment secrets on deployment.
VERTEX_API_KEY=
VERTEX_GEMINI_MODEL=

# ─── Legacy Gemini (Google AI Studio) — DO NOT USE in new code ─────────────
# Kept for reference only. New integrations must use VERTEX_API_KEY above.
# GEMINI_API_KEY=
# GEMINI_MODEL=
