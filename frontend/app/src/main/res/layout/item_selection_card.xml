<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="85dp"
    android:layout_height="85dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <FrameLayout
        android:id="@+id/layoutSelectionContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/ivSelectionIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_drops"
                app:tint="@color/text_main" />

            <TextView
                android:id="@+id/tvSelectionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Da dầu"
                android:textColor="@color/text_main"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dấu tick trắng trong hình tròn hồng (hiển thị khi được chọn) -->
        <ImageView
            android:id="@+id/ivSelectedTick"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="top|end"
            android:layout_margin="4dp"
            android:background="@drawable/bg_circle_pink"
            android:backgroundTint="@color/button"
            android:padding="4dp"
            android:src="@drawable/ic_tick"
            android:visibility="gone"
            app:tint="@android:color/white" />

    </FrameLayout>
</com.google.android.material.card.MaterialCardView>