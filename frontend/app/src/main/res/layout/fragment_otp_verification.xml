<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:padding="@dimen/spacing_xl">

    <ImageButton
        android:id="@+id/btnBack"
        style="@style/Widget.Kanila.Button.Icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/content_desc_back"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_main" />

    <ImageView
        android:id="@+id/ivIllustration"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/ic_verified"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:tint="@color/button" />

    <TextView
        android:id="@+id/tvTitle"
        style="@style/Text.Kanila.H1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/auth_otp_verify_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivIllustration" />

    <TextView
        android:id="@+id/tvSubtitle"
        style="@style/Text.Kanila.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_s"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        tools:text="Nhập mã OTP gồm 6 số đã được gửi đến số điện thoại 09xx xxx xxx." />

    <LinearLayout
        android:id="@+id/layoutOtpInputs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <include android:id="@+id/otpBox1" layout="@layout/view_otp_box" />
        <include android:id="@+id/otpBox2" layout="@layout/view_otp_box" />
        <include android:id="@+id/otpBox3" layout="@layout/view_otp_box" />
        <include android:id="@+id/otpBox4" layout="@layout/view_otp_box" />
        <include android:id="@+id/otpBox5" layout="@layout/view_otp_box" />
        <include android:id="@+id/otpBox6" layout="@layout/view_otp_box" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvResendCountdown"
        style="@style/Text.Kanila.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:textColor="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutOtpInputs"
        tools:text="Gửi lại mã sau 00:42" />

    <TextView
        android:id="@+id/btnResend"
        style="@style/Text.Kanila.BodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        android:text="@string/auth_otp_btn_resend"
        android:textColor="@color/button"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResendCountdown"
        tools:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerify"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="32dp"
        android:text="@string/auth_otp_btn_verify"
        app:layout_constraintTop_toBottomOf="@id/btnResend" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChangeTarget"
        style="@style/Widget.Kanila.Button.Secondary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnVerify"
        tools:text="@string/auth_otp_change_phone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_m"
        app:layout_constraintTop_toBottomOf="@id/btnChangeTarget">

        <ImageView
            android:id="@+id/ivSupportIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_chatbot" />

        <TextView
            android:id="@+id/tvSupportNote"
            style="@style/Text.Kanila.Micro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_m"
            android:textColor="@color/text_secondary"
            tools:text="@string/auth_otp_no_code_phone" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
