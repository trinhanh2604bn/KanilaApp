<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerEditProfile"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/background_main"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/secondary"
            app:strokeColor="@color/border_divider"
            app:strokeWidth="1dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/content_desc_back"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/accent_dark" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Chỉnh sửa hồ sơ làn da"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Loại da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerSkinType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreSkinType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 2: Tình trạng da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tình trạng da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerSkinCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 3: Mức độ nhạy cảm -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Mức độ nhạy cảm"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreSensitivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 4: Màu da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Màu da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerSkinColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 5: Sắc độ da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Sắc độ da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerSkinUndertone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreUndertone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 6: Hiệu ứng nền -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Hiệu ứng nền mong muốn"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerFoundationFinish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreFinish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 7: Màu son -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Màu son yêu thích"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerLipstickColors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreLipstick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 8: Phong cách trang điểm -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Phong cách trang điểm"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerMakeupStyles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreMakeup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <!-- Section 9: Ngân sách -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ngân sách ưu tiên"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerBudget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <!-- Section 10: Thành phần cần tránh -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Thành phần cần tránh"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/containerAvoidIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:id="@+id/tvSeeMoreAvoid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                style="@style/Widget.Kanila.Button.Primary"
                android:text="Lưu thay đổi" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
