<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCategoryVisualCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="100dp"
    android:background="@drawable/bg_category_visual_card"
    android:baselineAligned="false"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_m">

    <!-- Left content block -->
    <LinearLayout
        android:id="@+id/layoutCategoryInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="50dp"
            android:layout_height="48dp"
            android:contentDescription="@string/content_desc_category_icon"
            android:scaleType="centerInside"
            android:src="@drawable/ic_eyeshadow"
            app:tint="@color/button" />

        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_semibold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="@string/category_face"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            tools:text="Face" />
    </LinearLayout>

    <!-- Right product image block -->
    <FrameLayout
        android:id="@+id/layoutCategoryProductImageContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/ivCategoryProductImage"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:contentDescription="@string/content_desc_category_product_image"
            android:scaleType="centerInside"
            tools:src="@drawable/img_foudation" />
    </FrameLayout>

</LinearLayout>