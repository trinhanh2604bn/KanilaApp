<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sub">

    <include
        android:id="@+id/layoutHeader"
        layout="@layout/view_app_top_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollOrderDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomActions"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. Banner Trạng thái chung -->
            <LinearLayout
                android:id="@+id/layoutBannerStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#26A69A"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvOrderBannerStatus"
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái đơn hàng"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tvOrderBannerTime"
                    style="@style/Text.Kanila.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Thông tin thời gian"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- 1b. Khối đặc thù Trả hàng/Hoàn tiền (Mới) -->
            <LinearLayout
                android:id="@+id/layoutRefundDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    style="@style/Text.Kanila.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Chi tiết hoàn tiền >"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tvRefundAmount"
                    style="@style/Text.Kanila.H1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="150.000đ"
                    android:textColor="@color/text_main" />

                <TextView
                    style="@style/Text.Kanila.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="2dp"
                    android:text="Đến Số dư ví Kanila"
                    android:textColor="@color/text_tertiary" />

                <!-- Stepper Hoàn tiền -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/bg_circle_pink"
                            android:padding="8dp"
                            app:tint="@color/button"
                            app:srcCompat="@drawable/ic_routine"/>
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Chấp nhận\nhoàn tiền" />
                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:layout_marginBottom="24dp"
                        android:background="@color/success" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/bg_circle_pink"
                            android:padding="8dp"
                            app:tint="@color/button"
                            app:srcCompat="@drawable/ic_refresh"/>
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Đang\nhoàn tiền" />
                    </LinearLayout>

                    <View
                        android:layout_width="40dp"
                        android:layout_height="2dp"
                        android:layout_marginBottom="24dp"
                        android:background="@color/success" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/bg_circle_pink"
                            android:padding="8dp"
                            app:tint="@color/button"
                            app:srcCompat="@drawable/ic_paymeny_card"/>
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Đã\nhoàn tiền" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    style="@style/Text.Kanila.Micro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:alpha="0.7"
                    android:lineSpacingExtra="2dp"
                    android:text="Yêu cầu hoàn tiền của bạn đã được Kanila xử lý. Với đơn hoàn tiền về ví, tiền sẽ được cập nhật trong vòng 24 giờ."
                    android:textColor="@color/text_main" />
            </LinearLayout>

            <!-- 2. Thông tin vận chuyển -->
            <LinearLayout
                android:id="@+id/layoutShippingInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/Text.Kanila.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin vận chuyển" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Shipping"
                        android:src="@drawable/ic_shipping"
                        app:tint="@color/accent_dark" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvOrderShippingMethod"
                            style="@style/Text.Kanila.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giao hàng nhanh" />

                        <TextView
                            android:id="@+id/tvOrderTrackingNumber"
                            style="@style/Text.Kanila.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Mã vận đơn: KNL123456789"
                            android:textColor="@color/text_tertiary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 3. Địa chỉ nhận hàng -->
            <LinearLayout
                android:id="@+id/layoutAddressInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/Text.Kanila.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ nhận hàng" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Location"
                        android:src="@drawable/ic_location"
                        app:tint="@color/accent_dark" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvOrderRecipientNamePhone"
                            style="@style/Text.Kanila.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:text="Nguyen Bao (+84) 123 456 789" />

                        <TextView
                            android:id="@+id/tvOrderFullAddress"
                            style="@style/Text.Kanila.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="123 Trần Hưng Đạo, Phường Bến Thành, Quận 1, TP. Hồ Chí Minh"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 4. Khối Đơn hàng -->
            <LinearLayout
                android:id="@+id/layoutOrderDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="Store"
                        android:src="@drawable/ic_routine"
                        app:tint="@color/text_main" />

                    <TextView
                        style="@style/Text.Kanila.BodyMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Kanila Beauty" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_tertiary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <LinearLayout
                    android:id="@+id/layoutOrderItemsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thành tiền: " />

                    <TextView
                        android:id="@+id/tvOrderGrandTotal"
                        style="@style/Text.Kanila.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="245.000đ"
                        android:textColor="@color/button" />
                </LinearLayout>
            </LinearLayout>

            <!-- 5. Bạn cần hỗ trợ? -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical">

                <TextView
                    style="@style/Text.Kanila.BodyMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Bạn cần hỗ trợ?" />

                <include
                    android:id="@+id/menuContactShop"
                    layout="@layout/view_account_menu_item" />

                <include
                    android:id="@+id/menuHelpCenter"
                    layout="@layout/view_account_menu_item" />
            </LinearLayout>

            <!-- 6. Thông tin đơn hàng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mã đơn hàng" />

                    <TextView
                        android:id="@+id/tvOrderNumber"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KNL2507002"
                        android:textColor="@color/text_main" />

                    <TextView
                        android:id="@+id/btnCopyOrderNumber"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="SAO CHÉP"
                        android:textColor="@color/button" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutPaymentMethod"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Phương thức thanh toán" />

                    <TextView
                        android:id="@+id/tvPaymentMethod"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thanh toán khi nhận hàng"
                        android:textColor="@color/text_main" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Thời gian đặt hàng" />

                    <TextView
                        android:id="@+id/tvOrderPlacedTime"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10-07-2025 14:30"
                        android:textColor="@color/text_main" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnOrderInfoMore"
                    style="@style/Text.Kanila.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Xem chi tiết v"
                    android:textColor="@color/text_tertiary" />
            </LinearLayout>

            <!-- 7. "Có thể bạn cũng thích" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="—— Có thể bạn cũng thích ——" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecommendedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/spacing_m" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 8. Hai nút cố định đáy màn hình -->
    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActionSecondary"
            style="@style/Widget.Kanila.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Hủy đơn hàng"
            android:textColor="@color/text_main"
            app:strokeColor="@color/border_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActionPrimary"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Liên hệ Shop" />
    </LinearLayout>

    <include
        android:id="@+id/layoutLoading"
        layout="@layout/view_loading_state"
        android:visibility="gone" />

    <include
        android:id="@+id/layoutError"
        layout="@layout/view_error_generic"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
