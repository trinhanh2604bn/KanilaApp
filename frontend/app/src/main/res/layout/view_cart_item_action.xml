<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutCartItemAction"
    android:layout_width="match_parent"
    android:layout_height="87dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:gravity="end"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvActionSimilar"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_cart_action_similar"
        android:fontFamily="@font/nunito_semibold"
        android:gravity="center"
        android:paddingHorizontal="8dp"
        android:text="Sản phẩm\ntương tự"
        android:textAlignment="center"
        android:textColor="@color/background_main"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvActionDelete"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:background="@drawable/bg_cart_action_delete"
        android:fontFamily="@font/nunito_bold"
        android:gravity="center"
        android:text="Xóa"
        android:textColor="@color/button"
        android:textSize="14sp" />

</LinearLayout>
