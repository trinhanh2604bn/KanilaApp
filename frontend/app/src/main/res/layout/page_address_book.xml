<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Custom Toolbar -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/content_desc_back"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="@color/accent_dark" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/address_book_title"
            android:textAppearance="@style/Text.Kanila.H2"
            android:textColor="@color/accent_dark" />

        <!-- Notification icon or placeholder for balance -->
        <ImageView
            android:id="@+id/btnNotification"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/notification"
            android:src="@drawable/ic_notification"
            app:tint="@color/text_main" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="@string/address_book_list_header"
                android:textAppearance="@style/Text.Kanila.H3"
                android:textColor="@color/text_secondary"
                android:textStyle="bold" />

            <include layout="@layout/item_address_book" />

            <include layout="@layout/item_address_book" />

            <include layout="@layout/item_address_book" />

            <include layout="@layout/item_address_book" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Area (Sticky) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:elevation="8dp"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/btnAddAddress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_address_default_tag"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_plus"
                app:tint="@color/background_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/address_book_add_new"
                android:textAppearance="@style/Text.Kanila.H3"
                android:textColor="@color/background_main" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/layoutBottomNavigation"
        layout="@layout/view_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp" />

</LinearLayout>
