<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutBottomSheetFilter"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_m"
        android:background="@drawable/bg_drag_handle" />

    <!-- Fixed Header -->
    <FrameLayout
        android:id="@+id/layoutFilterHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_s"
        android:paddingTop="@dimen/spacing_s"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/tvFilterTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/filter_title"
            android:textColor="@color/accent_dark" />

        <ImageButton
            android:id="@+id/btnCloseFilter"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_gravity="end|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_close"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close"
            app:tint="@color/text_main"
            tools:ignore="TouchTargetSizeCheck" />
    </FrameLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollFilterContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/layoutFilterContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_s"
            android:paddingBottom="@dimen/spacing_l">

            <!-- Section 1: Loại da -->
            <TextView
                android:id="@+id/tvSkinTypeTitle"
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="@string/filter_skin_type"
                android:textColor="@color/accent_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:id="@+id/chipSkinOily"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_filter_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_drops"
                        app:tint="@color/selector_filter_icon_tint" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/filter_skin_oily"
                        android:textColor="@color/selector_filter_chip_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipSkinDry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_filter_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_drops"
                        app:tint="@color/selector_filter_icon_tint" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/filter_skin_dry"
                        android:textColor="@color/selector_filter_chip_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipSkinNormal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_filter_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_drops"
                        app:tint="@color/selector_filter_icon_tint" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/filter_skin_normal"
                        android:textColor="@color/selector_filter_chip_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipSkinSensitive"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_filter_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_drops"
                        app:tint="@color/selector_filter_icon_tint" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/filter_skin_sensitive"
                        android:textColor="@color/selector_filter_chip_text" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section 2: Tone da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="@string/filter_tone"
                android:textColor="@color/accent_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:baselineAligned="false"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:id="@+id/chipToneLight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_filter_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_drops"
                        app:tint="@color/selector_filter_icon_tint" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/filter_tone_light"
                        android:textColor="@color/selector_filter_chip_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipToneMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_filter_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_drops"
                        app:tint="@color/selector_filter_icon_tint" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/filter_tone_medium"
                        android:textColor="@color/selector_filter_chip_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipToneDark"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="@drawable/selector_filter_card_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_s">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_drops"
                        app:tint="@color/selector_filter_icon_tint" />

                    <TextView
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/filter_tone_dark"
                        android:textColor="@color/selector_filter_chip_text" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section 3: Khoảng giá -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="@string/filter_price_range"
                android:textColor="@color/accent_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edtMinPrice"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:autofillHints="none"
                    android:background="@drawable/bg_input"
                    android:hint="@string/filter_price_from"
                    android:inputType="number"
                    android:paddingHorizontal="@dimen/spacing_m"
                    android:textColor="@color/text_main"
                    tools:ignore="TouchTargetSizeCheck"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_s"
                    android:text="@string/filter_price_separator"
                    android:textColor="@color/text_tertiary" />

                <EditText
                    android:id="@+id/edtMaxPrice"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:autofillHints="none"
                    android:background="@drawable/bg_input"
                    android:hint="@string/filter_price_to"
                    android:inputType="number"
                    android:paddingHorizontal="@dimen/spacing_m"
                    android:textColor="@color/text_main"
                    tools:ignore="TouchTargetSizeCheck"
                    android:textSize="14sp" />
            </LinearLayout>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:chipSpacingVertical="@dimen/spacing_l"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrice0To100"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:text="@string/price_0_100"
                    android:textColor="@color/selector_filter_chip_text"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"
                    app:closeIconVisible="false"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrice100To300"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:text="@string/price_100_300"
                    android:textColor="@color/selector_filter_chip_text"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"
                    app:closeIconVisible="false"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrice300To500"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="110dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textAlignment="center"
                    android:text="@string/price_300_500"
                    android:textColor="@color/selector_filter_chip_text"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"
                    app:closeIconVisible="false"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Section 4: Đánh giá -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="@string/filter_rating"
                android:textColor="@color/accent_dark" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                app:chipSpacingVertical="@dimen/spacing_l"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRating5"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rating_5"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRating4Plus"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rating_4_plus"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRating3Plus"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rating_3_plus"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRating2Plus"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rating_2_plus"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRating1Plus"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rating_1_plus"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Section 5: Thương hiệu -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="@string/filter_brand"
                android:textColor="@color/accent_dark" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupBrands"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                app:chipSpacingHorizontal="@dimen/spacing_s"
                app:chipSpacingVertical="0dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrandFwee"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_fwee"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrandPeriPera"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_peripera"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrandNars"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_nars"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrandCarlans"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_carlans"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrandCanmake"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_canmake"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrandCharlotteTilbury"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_charlotte_tilbury"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBrandMario"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_mario"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Section 6: Thành phần nổi bật -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="@string/filter_ingredients"
                android:textColor="@color/accent_dark" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupIngredients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                app:chipSpacingHorizontal="@dimen/spacing_s"
                app:chipSpacingVertical="@dimen/spacing_s">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIngGlycerin"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ing_glycerin"
                    android:tag="Glycerin"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIngTocopherol"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ing_tocopherol"
                    android:tag="Tocopherol"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIngMica"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ing_mica"
                    android:tag="Mica"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Section 7: Nhu cầu -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:text="@string/filter_concerns"
                android:textColor="@color/accent_dark" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupConcerns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                app:chipSpacingHorizontal="@dimen/spacing_s"
                app:chipSpacingVertical="0dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipConcernLongWear"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/concern_long_wear"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipConcernSmoothFinish"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/concern_smooth_finish"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipConcernPhotoReady"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/concern_photo_ready"
                    android:checkable="true"
                    app:chipBackgroundColor="@color/selector_filter_chip_background"
                    app:chipStrokeColor="@color/selector_filter_chip_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/selector_filter_chip_text"
                    app:checkedIconVisible="false" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Section 8: Phù hợp da nhạy cảm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/filter_sensitive_only"
                    android:textColor="@color/accent_dark" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchSensitiveOnly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/selector_filter_icon_tint"
                    app:trackTint="@color/selector_filter_chip_stroke"
                    app:useMaterialThemeColors="false" />
            </LinearLayout>

            <!-- Section 9: Bán chạy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/filter_best_seller_only"
                    android:textColor="@color/accent_dark" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchBestSellerOnly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/selector_filter_icon_tint"
                    app:trackTint="@color/selector_filter_chip_stroke"
                    app:useMaterialThemeColors="false" />
            </LinearLayout>

            <!-- Section 10: AR-only switch -->
            <LinearLayout
                android:id="@+id/layoutArOnlyFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/filter_ar_only"
                    android:textColor="@color/accent_dark" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchArOnly"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/selector_filter_icon_tint"
                    app:trackTint="@color/selector_filter_chip_stroke"
                    app:useMaterialThemeColors="false" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Fixed Bottom Action Bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_divider" />

    <LinearLayout
        android:id="@+id/layoutFilterActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_l"
        android:paddingVertical="@dimen/spacing_m">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetFilter"
            style="@style/Widget.Kanila.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            tools:ignore="TouchTargetSizeCheck"
            android:layout_marginEnd="@dimen/spacing_s"
            android:text="@string/filter_reset" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyFilter"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_s"
            android:text="@string/filter_apply" />
    </LinearLayout>
</LinearLayout>
