<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_main">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingBottom="40dp">

        <ImageButton
            android:id="@+id/btnBack"
            style="@style/Widget.Kanila.Button.Icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/content_desc_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvLogoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="-0.02"
                android:text="Kanila"
                android:textColor="@color/accent_dark"
                android:textSize="34sp"
                tools:ignore="HardcodedText" />

        </LinearLayout>

        <ImageView
            android:id="@+id/ivIllustration"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerInside"
            android:src="@drawable/login_7"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/layoutLogo" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/auth_reset_password_title"
            android:textColor="@color/accent_dark"
            android:textSize="28sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivIllustration" />

        <TextView
            android:id="@+id/tvSubtitle"
            style="@style/Text.Kanila.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/auth_reset_password_subtitle"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintWidth_percent="0.9" />

        <LinearLayout
            android:id="@+id/reset_input_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <ui.common.KanilaInputField
                android:id="@+id/inputNewPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:kanilaLabel="@string/auth_reset_password_new_label"
                app:kanilaHint="••••••••"
                app:kanilaShowLeadingIcon="true"
                app:kanilaLeadingIcon="@drawable/ic_lock"
                app:kanilaMode="1" />

            <ui.common.KanilaInputField
                android:id="@+id/inputConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:kanilaLabel="@string/auth_reset_password_confirm_label"
                app:kanilaHint="••••••••"
                app:kanilaShowLeadingIcon="true"
                app:kanilaLeadingIcon="@drawable/ic_lock"
                app:kanilaMode="1" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_auth_primary_gradient"
            app:backgroundTint="@null"
            android:text="@string/auth_btn_reset_password"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/nunito_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/reset_input_container" />

        <LinearLayout
            android:id="@+id/layoutBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnReset">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="hoặc"
                android:textColor="@color/text_tertiary"
                android:textSize="14sp"
                tools:ignore="HardcodedText" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:drawableStartCompat="@drawable/ic_back"
            android:drawablePadding="8dp"
            app:drawableTint="@color/button"
            android:fontFamily="@font/nunito_bold"
            android:text="@string/auth_btn_back_to_login"
            android:textColor="@color/button"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutBackToLogin" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_auth_consent_row"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvBackToLogin">

            <ImageView
                android:id="@+id/ivHelpIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/bg_icon_soft"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/button"
                app:layout_constraintBottom_toBottomOf="@id/ivHelpIcon"
                app:layout_constraintEnd_toEndOf="@id/ivHelpIcon"
                app:layout_constraintStart_toStartOf="@id/ivHelpIcon"
                app:layout_constraintTop_toTopOf="@id/ivHelpIcon" />

            <TextView
                android:id="@+id/tvHelpQuestion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/nunito_bold"
                android:text="Cần hỗ trợ?"
                android:textColor="@color/accent_dark"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/ivArrow"
                app:layout_constraintStart_toEndOf="@id/ivHelpIcon"
                app:layout_constraintTop_toTopOf="parent"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvHelpAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:text="Liên hệ với Kanila để được hỗ trợ 24/7"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/ivArrow"
                app:layout_constraintStart_toStartOf="@id/tvHelpQuestion"
                app:layout_constraintTop_toBottomOf="@id/tvHelpQuestion"
                tools:ignore="HardcodedText" />

            <ImageView
                android:id="@+id/ivArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
