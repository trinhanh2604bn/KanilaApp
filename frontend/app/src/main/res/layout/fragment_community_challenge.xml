<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/challengeTabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="@color/button"
        app:tabSelectedTextColor="@color/button"
        app:tabTextColor="@color/text_secondary"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"
        android:background="@color/background_main" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/challengeViewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
