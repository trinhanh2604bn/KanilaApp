<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutAddressItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="16dp">

    <!-- Location Icon -->
    <ImageView
        android:id="@+id/ivLocation"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon_soft"
        android:padding="10dp"
        android:src="@drawable/ic_location"
        app:tint="@color/accent_dark"
        android:contentDescription="Vị trí" />

    <!-- Address Details -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvReceiverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyễn Thị Mai"
                android:textAppearance="@style/Text.Kanila.H3"
                android:textColor="@color/text_main"
                tools:text="Nguyễn Thị Mai" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Default Badge -->
            <!--<LinearLayout
                android:id="@+id/layoutDefaultBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_primary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_star"
                    app:tint="@color/background_main" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/address_book_default"
                    android:textAppearance="@style/Text.Kanila.Micro"
                    android:textColor="@color/background_main" />
            </LinearLayout>-->
        </LinearLayout>

        <TextView
            android:id="@+id/tvReceiverPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0987 654 321"
            android:textAppearance="@style/Text.Kanila.Caption"
            android:textColor="@color/text_secondary"
            tools:text="0987 654 321" />

        <TextView
            android:id="@+id/tvAddressFull"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="72 Nguyễn Trãi, Phường Bến Thành, Quận 1, TP. Hồ Chí Minh"
            android:textAppearance="@style/Text.Kanila.Caption"
            android:textColor="@color/text_secondary"
            tools:text="72 Nguyễn Trãi, Phường Bến Thành, Quận 1, TP. Hồ Chí Minh" />

    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_edit"
            android:contentDescription="Sửa địa chỉ"
            app:tint="@color/burgundy" />

        <View
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="2dp"
            android:src="@drawable/ic_trash"
            android:contentDescription="Xóa địa chỉ"
            app:tint="@color/burgundy" />
    </LinearLayout>

</LinearLayout>
