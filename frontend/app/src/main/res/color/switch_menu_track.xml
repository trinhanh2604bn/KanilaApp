<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    android:enterFadeDuration="200"
    android:exitFadeDuration="200">
    <!-- Khi ON: nền hồng nhạt -->
    <item android:alpha="0.4" android:color="@color/button" android:state_checked="true" />
    <!-- Khi OFF: nền xám đen nhạt -->
    <item android:alpha="0.12" android:color="#000000" />
</selector>