<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/suitable_ingredients_title"
            app:tint="@color/accent_dark"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/suitable_ingredients_title"
            android:textColor="@color/accent_dark"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_tick"
            android:contentDescription="@string/suitable_ingredients_title"
            app:tint="@color/accent_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.6"
                android:text="@string/suitable_ingredients_subtitle"
                android:textColor="@color/text_main" />

            <!-- Quick Setup Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.Kanila.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_setup" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <!-- Priority Card -->
                        <com.google.android.material.card.MaterialCardView
                            style="@style/QuickSetupCard">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="@drawable/bg_circle"
                                        android:backgroundTint="@color/icon_bg_green"
                                        android:contentDescription="@string/priority"
                                        android:padding="6dp"
                                        android:src="@drawable/ic_skincare"
                                        app:tint="@color/success" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:orientation="vertical">

                                        <TextView
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/priority"
                                            android:textColor="@color/success"
                                            android:textStyle="bold" />

                                        <TextView
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/priority_count"
                                            android:textSize="11sp" />

                                    </LinearLayout>

                                </LinearLayout>

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    style="@style/Text.Kanila.Micro"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/priority_list"
                                    android:textSize="11sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Avoid Card -->
                        <com.google.android.material.card.MaterialCardView
                            style="@style/QuickSetupCard">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="@drawable/bg_circle"
                                        android:backgroundTint="#FFEBEE"
                                        android:contentDescription="@string/avoid"
                                        android:padding="6dp"
                                        android:src="@drawable/ic_error_outline"
                                        app:tint="@color/error" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:orientation="vertical">

                                        <TextView
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/avoid"
                                            android:textColor="@color/error"
                                            android:textStyle="bold" />

                                        <TextView
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/avoid_count"
                                            android:textSize="11sp" />

                                    </LinearLayout>

                                </LinearLayout>

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1" />

                                <TextView
                                    style="@style/Text.Kanila.Micro"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/avoid_list"
                                    android:textSize="11sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Priority Ingredients Grid -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/priority_ingredients" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3">

                <!-- Niacinamide -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip.Selected">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_drops"
                                app:tint="@color/button" />

                            <TextView
                                style="@style/IngredientChipLabel.Selected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_niacinamide" />

                        </LinearLayout>

                        <ImageView style="@style/GridItemTick" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Ceramide -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip.Selected">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_shield_star"
                                app:tint="@color/button" />

                            <TextView
                                style="@style/IngredientChipLabel.Selected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_ceramide" />

                        </LinearLayout>

                        <ImageView style="@style/GridItemTick" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Hyaluronic Acid -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip.Selected">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_drops_filled"
                                app:tint="@color/button" />

                            <TextView
                                style="@style/IngredientChipLabel.Selected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_hyaluronic_acid" />

                        </LinearLayout>

                        <ImageView style="@style/GridItemTick" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- BHA -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_beaker"
                            app:tint="@color/text_main" />

                        <TextView
                            style="@style/IngredientChipLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/ing_bha" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Vitamin C -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_goal_sparkle"
                            app:tint="@color/text_main" />

                        <TextView
                            style="@style/IngredientChipLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/ing_vitamin_c" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Peptide -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_skincare"
                            app:tint="@color/text_main" />

                        <TextView
                            style="@style/IngredientChipLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/ing_peptide" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Avoid Ingredients Grid -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/avoid_ingredients" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3">

                <!-- Alcohol -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip.Selected">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_beaker"
                                app:tint="@color/button" />

                            <TextView
                                style="@style/IngredientChipLabel.Selected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_alcohol" />

                        </LinearLayout>

                        <ImageView style="@style/GridItemTick" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Fragrance -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip.Selected">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_cream"
                                app:tint="@color/button" />

                            <TextView
                                style="@style/IngredientChipLabel.Selected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_fragrance" />

                        </LinearLayout>

                        <ImageView style="@style/GridItemTick" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Paraben -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_shield_star"
                            app:tint="@color/text_main" />

                        <TextView
                            style="@style/IngredientChipLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/ing_paraben" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Retinol -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_goal_sparkle"
                            app:tint="@color/text_main" />

                        <TextView
                            style="@style/IngredientChipLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/ing_retinol" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Essential Oil -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/IngredientChip">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="8dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_skincare"
                            app:tint="@color/text_main" />

                        <TextView
                            style="@style/IngredientChipLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/ing_essential_oil" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Treatment Sensitivity Switch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_selection_selected"
                android:backgroundTint="#FDF9FB"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    style="@style/Text.Kanila.BodyMedium"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sensitive_skin_treatment" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/button"
                    app:trackTint="@color/secondary" />

            </LinearLayout>

            <!-- Priority Formula Message -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/icon_bg_pink"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@android:color/white"
                        android:contentDescription="@string/priority"
                        android:padding="8dp"
                        android:src="@drawable/ic_verified"
                        app:tint="@color/button" />

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/priority_formula_msg"
                        android:textColor="@color/text_main" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="@string/btn_save_setup"
        app:icon="@drawable/ic_checklist"
        app:iconGravity="textStart" />

</LinearLayout>