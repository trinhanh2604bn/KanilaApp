<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/suitableIngredientsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <!-- Nút Back hình tròn, có bóng -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/background_main"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/secondary"
            app:strokeColor="@color/border_divider"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Quay lại"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/accent_dark" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Tiêu đề -->
        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/suitable_ingredients_title"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Nội dung cuộn -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollSuitableIngredients"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mô tả -->
            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.6"
                android:text="@string/suitable_ingredients_subtitle"
                android:textColor="@color/text_main" />

            <!-- Thiết lập nhanh -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.Kanila.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_setup"
                        android:textColor="@color/accent_dark" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <!-- Thống kê thành phần ưu tiên -->
                        <com.google.android.material.card.MaterialCardView
                            style="@style/QuickSetupCard">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="@drawable/bg_circle"
                                        android:backgroundTint="@color/icon_bg_green"
                                        android:contentDescription="@string/priority"
                                        android:padding="6dp"
                                        android:src="@drawable/ic_skincare"
                                        app:tint="@color/success" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:orientation="vertical">

                                        <TextView
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/priority"
                                            android:textColor="@color/success"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:id="@+id/tvPriorityCount"
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            tools:text="3 thành phần" />

                                    </LinearLayout>

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tvPriorityList"
                                    style="@style/Text.Kanila.Micro"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    tools:text="Niacinamide, Ceramide, Hyaluronic Acid" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Thống kê thành phần cần tránh -->
                        <com.google.android.material.card.MaterialCardView
                            style="@style/QuickSetupCard">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="@drawable/bg_circle"
                                        android:backgroundTint="@color/icon_bg_pink"
                                        android:contentDescription="@string/avoid"
                                        android:padding="6dp"
                                        android:src="@drawable/ic_error_outline"
                                        app:tint="@color/error" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="8dp"
                                        android:orientation="vertical">

                                        <TextView
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/avoid"
                                            android:textColor="@color/error"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:id="@+id/tvAvoidCount"
                                            style="@style/Text.Kanila.Micro"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            tools:text="2 thành phần" />

                                    </LinearLayout>

                                </LinearLayout>

                                <TextView
                                    android:id="@+id/tvAvoidList"
                                    style="@style/Text.Kanila.Micro"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    tools:text="Cồn khô, Hương liệu" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tiêu đề ưu tiên -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/priority_ingredients"
                android:textColor="@color/accent_dark" />

            <!-- Danh sách thành phần ưu tiên -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Niacinamide -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardNiacinamide"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconNiacinamide"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_drops" />

                            <TextView
                                android:id="@+id/tvNiacinamide"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_niacinamide" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickNiacinamide"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Ceramide -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCeramide"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconCeramide"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_shield_star" />

                            <TextView
                                android:id="@+id/tvCeramide"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_ceramide" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickCeramide"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Hyaluronic Acid -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHyaluronicAcid"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconHyaluronicAcid"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_drops_filled" />

                            <TextView
                                android:id="@+id/tvHyaluronicAcid"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_hyaluronic_acid" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickHyaluronicAcid"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- BHA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBha"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconBha"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_beaker" />

                            <TextView
                                android:id="@+id/tvBha"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_bha" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickBha"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Vitamin C -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardVitaminC"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconVitaminC"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_goal_sparkle" />

                            <TextView
                                android:id="@+id/tvVitaminC"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_vitamin_c" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickVitaminC"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Peptide -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPeptide"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconPeptide"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_skincare" />

                            <TextView
                                android:id="@+id/tvPeptide"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_peptide" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickPeptide"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Tiêu đề cần tránh -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/avoid_ingredients"
                android:textColor="@color/accent_dark" />

            <!-- Danh sách thành phần cần tránh -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:columnCount="3"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Cồn khô -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAlcohol"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconAlcohol"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_beaker" />

                            <TextView
                                android:id="@+id/tvAlcohol"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_alcohol" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickAlcohol"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Hương liệu -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFragrance"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconFragrance"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_cream" />

                            <TextView
                                android:id="@+id/tvFragrance"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_fragrance" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickFragrance"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Paraben -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardParaben"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconParaben"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_shield_star" />

                            <TextView
                                android:id="@+id/tvParaben"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_paraben" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickParaben"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Retinol -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRetinol"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconRetinol"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_goal_sparkle" />

                            <TextView
                                android:id="@+id/tvRetinol"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_retinol" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickRetinol"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Tinh dầu -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEssentialOil"
                    style="@style/IngredientChip"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="8dp">

                            <ImageView
                                android:id="@+id/iconEssentialOil"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_skincare" />

                            <TextView
                                android:id="@+id/tvEssentialOil"
                                style="@style/IngredientChipLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/ing_essential_oil" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/tickEssentialOil"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:contentDescription="Đã chọn"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/button" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Công tắc điều trị da nhạy cảm -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/layoutSensitiveTreatment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/icon_bg_pink"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/button"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        style="@style/Text.Kanila.BodyMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sensitive_skin_treatment"
                        android:textColor="@color/text_main" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="6dp"
                        android:alpha="0.5"
                        android:src="@drawable/ic_shortcut_help"
                        app:tint="@color/text_main" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchSensitiveTreatment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Thông báo gợi ý (Smart Insight) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSmartInsight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <FrameLayout
                        android:id="@+id/layoutSmartInsightIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/background_sub">

                        <ImageView
                            android:id="@+id/ivSmartInsightIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_goal_sparkle"
                            app:tint="@color/text_tertiary" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvSmartInsightMessage"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="@string/priority_formula_msg"
                        android:textColor="@color/text_tertiary"
                        android:lineSpacingExtra="2dp"
                        android:fontFamily="@font/nunito_medium" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Nút lưu cố định phía dưới -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_save_setup"
        app:icon="@drawable/ic_checklist"
        app:iconGravity="textStart" />

</LinearLayout>