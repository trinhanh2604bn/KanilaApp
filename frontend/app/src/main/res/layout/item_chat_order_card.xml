<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="@dimen/radius_m"
    app:cardElevation="2dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_m">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông tin đơn hàng"
            android:textAppearance="@style/Text.Kanila.H3"
            android:textColor="@color/accent_dark" />

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:stretchColumns="1">

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã đơn hàng: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvOrderCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    tools:text="KNL123456" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvOrderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/success"
                    tools:text="Đang giao hàng" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thanh toán: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvPaymentStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    tools:text="Đã thanh toán" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tổng tiền: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/button"
                    android:textStyle="bold"
                    tools:text="450.000đ" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày đặt: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvOrderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    tools:text="08/07/2026" />
            </TableRow>

            <TableRow android:id="@+id/rowEstimatedDelivery" android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dự kiến giao: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvEstimatedDelivery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    tools:text="10/07/2026" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số sản phẩm: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvItemsCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    tools:text="3" />
            </TableRow>
        </TableLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/border_divider" />

        <LinearLayout
            android:id="@+id/layoutTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewOrderDetail"
            style="@style/Widget.Kanila.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:text="Xem chi tiết đơn hàng"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvNextAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textAppearance="@style/Text.Kanila.Caption"
            android:textColor="@color/primary"
            android:textStyle="bold"
            tools:text="Đã nhận hàng" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
