<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutHomeSocialSection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_m"
    android:layout_marginTop="@dimen/spacing_xs"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <!-- Kanila Reels Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutKanilaReelsCard"
        android:layout_width="0dp"
        android:layout_height="154dp"
        android:layout_marginEnd="@dimen/spacing_s"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/bg_section"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_soft"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="139dp"
            android:orientation="vertical"
            android:padding="@dimen/spacing_s">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_s">

                <TextView
                    android:id="@+id/tvKanilaReelsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="@string/home_social_reels_title"
                    android:textColor="@color/text_main"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_tertiary" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <!-- Reel 1 -->
                <FrameLayout
                    android:id="@+id/layoutReelThumbOne"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="4dp"
                        app:cardElevation="0dp">

                        <VideoView
                            android:id="@+id/vvReelOne"
                            android:layout_width="match_parent"
                            android:layout_height="100dp" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivReelThumbOne"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_blush"
                        app:shapeAppearanceOverlay="@style/RoundedFour" />

                    <ImageView
                        android:id="@+id/badgeReelOne"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|start"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/content_desc_reels_icon"
                        android:src="@drawable/ic_reels"
                        app:tint="@color/white" />

                </FrameLayout>

                <!-- Reel 2 -->
                <FrameLayout
                    android:id="@+id/layoutReelThumbTwo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="4dp"
                        app:cardElevation="0dp">

                        <VideoView
                            android:id="@+id/vvReelTwo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivReelThumbTwo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_brush"
                        app:shapeAppearanceOverlay="@style/RoundedFour" />

                    <ImageView
                        android:id="@+id/badgeReelTwo"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|start"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/content_desc_reels_icon"
                        android:src="@drawable/ic_reels"
                        app:tint="@color/white" />

                </FrameLayout>

                <!-- Reel 3 -->
                <FrameLayout
                    android:id="@+id/layoutReelThumbThree"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="4dp"
                        app:cardElevation="0dp">

                        <VideoView
                            android:id="@+id/vvReelThree"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivReelThumbThree"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_lipstick"
                        app:shapeAppearanceOverlay="@style/RoundedFour" />

                    <ImageView
                        android:id="@+id/badgeReelThree"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|start"
                        android:layout_margin="4dp"
                        android:contentDescription="@string/content_desc_reels_icon"
                        android:src="@drawable/ic_reels"
                        app:tint="@color/white" />

                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Kanila Challenge Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutKanilaChallengeCard"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/background_sub"
        app:cardCornerRadius="@dimen/radius_m"
        app:cardElevation="0dp"
        app:strokeColor="@color/secondary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="151dp"
            android:orientation="vertical"
            android:padding="@dimen/spacing_s">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_s">

                <TextView
                    android:id="@+id/tvKanilaChallengeTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/nunito_bold"
                    android:text="@string/home_social_challenge_title"
                    android:textColor="@color/accent_dark"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="@dimen/icon_size_small"
                    android:layout_height="@dimen/icon_size_small"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/accent_dark" />
            </RelativeLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivChallengeBanner"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_reward"
                    app:shapeAppearanceOverlay="@style/RoundedEight" />

                <TextView
                    android:id="@+id/tvChallengeBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_badge_hot"
                    android:fontFamily="@font/nunito_bold"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="@string/home_social_challenge_hot"
                    android:textColor="@color/white"
                    android:textSize="8sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvChallengeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_bold"
                android:maxLines="1"
                android:text="@string/home_social_challenge_name"
                android:textColor="@color/text_main"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinChallenge"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:backgroundTint="@color/button"
                android:fontFamily="@font/nunito_bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="8dp"
                android:text="@string/home_social_challenge_cta"
                android:textAllCaps="false"
                android:textSize="10sp"
                app:cornerRadius="12dp" />

            <ProgressBar
                android:id="@+id/progressChallenge"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:max="14"
                android:progress="8"
                android:progressDrawable="@drawable/bg_progress_bar" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tvChallengeProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:fontFamily="@font/nunito_semibold"
                    android:textColor="@color/button"
                    android:textSize="9sp"
                    tools:text="8/14 ngày" />

                <TextView
                    android:id="@+id/tvChallengeParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="@font/nunito_regular"
                    android:textColor="@color/text_tertiary"
                    android:textSize="9sp"
                    tools:text="12.6K tham gia" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvChallengeReward"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/button"
                    android:textSize="10sp"
                    tools:text="200 điểm" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
