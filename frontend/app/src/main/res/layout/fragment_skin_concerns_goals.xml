<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/skinConcernsGoalsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header Toolbar - Standardized -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/background_main"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/secondary"
            app:strokeColor="@color/border_divider"
            app:strokeWidth="1dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Back"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/accent_dark" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:gravity="center"
            android:text="Mối quan tâm &amp; Mục tiêu"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:clipChildren="false">

            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.6"
                android:text="Chọn vấn đề da và mục tiêu để nhận gợi ý chính xác hơn"
                android:textColor="@color/text_main" />

            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Mối quan tâm hiện tại"
                android:textColor="@color/accent_dark" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="4"
                android:clipChildren="false">

                <!-- Mụn -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernAcne" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconAcne" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_pink" android:padding="8dp" android:src="@drawable/ic_skin_acne" app:tint="@color/button" android:contentDescription="Mụn" />
                            <TextView android:id="@+id/labelAcne" style="@style/GridItemLabel" android:text="Mụn" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickAcne" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Thâm -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernSpots" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconSpots" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_pink" android:padding="8dp" android:src="@drawable/ic_skin_spots" app:tint="@color/button" android:contentDescription="Thâm" />
                            <TextView android:id="@+id/labelSpots" style="@style/GridItemLabel" android:text="Thâm" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickSpots" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Lỗ chân lông -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernPores" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconPores" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_grey" android:padding="8dp" android:src="@drawable/ic_skin_pores" android:contentDescription="Lỗ chân lông" />
                            <TextView android:id="@+id/labelPores" style="@style/GridItemLabel" android:text="Lỗ chân lông" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickPores" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Đỏ rát -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernRedness" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconRedness" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_pink" android:padding="8dp" android:src="@drawable/ic_skin_redness" app:tint="@color/button" android:contentDescription="Đỏ rát" />
                            <TextView android:id="@+id/labelRedness" style="@style/GridItemLabel" android:text="Đỏ rát" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickRedness" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Xỉn màu -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernDullness" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconDullness" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_yellow" android:padding="8dp" android:src="@drawable/ic_skin_dullness" app:tint="@color/status_pending_text" android:contentDescription="Xỉn màu" />
                            <TextView android:id="@+id/labelDullness" style="@style/GridItemLabel" android:text="Xỉn màu" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickDullness" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Thiếu ẩm -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernDehydration" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconDehydration" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_blue" android:padding="8dp" android:src="@drawable/ic_drops" app:tint="@color/status_preparing_text" android:contentDescription="Thiếu ẩm" />
                            <TextView android:id="@+id/labelDehydration" style="@style/GridItemLabel" android:text="Thiếu ẩm" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickDehydration" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Lão hóa -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernAging" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconAging" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_blue" android:padding="8dp" android:src="@drawable/ic_skin_aging" app:tint="@color/status_preparing_text" android:contentDescription="Lão hóa" />
                            <TextView android:id="@+id/labelAging" style="@style/GridItemLabel" android:text="Lão hóa" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickAging" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Nhạy cảm -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardConcernSensitive" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconSensitive" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_green" android:padding="8dp" android:src="@drawable/ic_skin_sensitive" app:tint="@color/success" android:contentDescription="Nhạy cảm" />
                            <TextView android:id="@+id/labelSensitive" style="@style/GridItemLabel" android:text="Nhạy cảm" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickSensitive" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Mục tiêu chăm sóc"
                android:textColor="@color/accent_dark" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:columnCount="3"
                android:clipChildren="false">

                <!-- Giảm mụn -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardGoalReduceAcne" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconGoalAcne" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_pink" android:padding="8dp" android:src="@drawable/ic_goal_target" app:tint="@color/button" android:contentDescription="Giảm mụn" />
                            <TextView android:id="@+id/labelGoalAcne" style="@style/GridItemLabel" android:text="Giảm mụn" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickGoalAcne" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mờ thâm -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardGoalFadeSpots" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconGoalSpots" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_pink" android:padding="8dp" android:src="@drawable/ic_goal_sparkle" app:tint="@color/button" android:contentDescription="Mờ thâm" />
                            <TextView android:id="@+id/labelGoalSpots" style="@style/GridItemLabel" android:text="Mờ thâm" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickGoalSpots" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Phục hồi -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardGoalRecovery" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconGoalRecovery" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_blue" android:padding="8dp" android:src="@drawable/ic_goal_recovery" app:tint="@color/status_preparing_text" android:contentDescription="Phục hồi" />
                            <TextView android:id="@+id/labelGoalRecovery" style="@style/GridItemLabel" android:text="Phục hồi" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickGoalRecovery" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Cấp ẩm -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardGoalHydrate" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconGoalHydrate" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_blue" android:padding="8dp" android:src="@drawable/ic_drops_filled" app:tint="@color/status_preparing_text" android:contentDescription="Cấp ẩm" />
                            <TextView android:id="@+id/labelGoalHydrate" style="@style/GridItemLabel" android:text="Cấp ẩm" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickGoalHydrate" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sáng da -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardGoalBrighten" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconGoalBrighten" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_yellow" android:padding="8dp" android:src="@drawable/ic_goal_sparkle" app:tint="@color/status_pending_text" android:contentDescription="Sáng da" />
                            <TextView android:id="@+id/labelGoalBrighten" style="@style/GridItemLabel" android:text="Sáng da" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickGoalBrighten" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Chống nắng -->
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardGoalSun" style="@style/GridItemCard">
                    <FrameLayout style="@style/GridItemFrame">
                        <LinearLayout style="@style/GridItemContent">
                            <ImageView android:id="@+id/iconGoalSun" style="@style/GridItemIcon" android:background="@drawable/bg_circle" android:backgroundTint="@color/icon_bg_yellow" android:padding="8dp" android:src="@drawable/ic_sun" app:tint="@color/status_pending_text" android:contentDescription="Chống nắng" />
                            <TextView android:id="@+id/labelGoalSun" style="@style/GridItemLabel" android:text="Chống nắng" />
                        </LinearLayout>
                        <ImageView android:id="@+id/tickGoalSun" style="@style/GridItemTick" android:visibility="gone" android:contentDescription="Selected" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/background_sub"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/secondary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@color/icon_bg_pink"
                        android:padding="8dp"
                        android:src="@drawable/ic_chatbot"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:tint="@color/button"
                        android:contentDescription="Kanila AI" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/Text.Kanila.BodyMedium"
                            android:text="Kanila AI gợi ý"
                            android:textColor="@color/accent_dark"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            style="@style/Text.Kanila.Micro"
                            android:text="Bạn ưu tiên phục hồi + giảm mụn trong 4 tuần tới"
                            android:textColor="@color/text_main" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                style="@style/Widget.Kanila.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Lưu thay đổi" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewRoutine"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                android:text="Xem quy trình đề xuất"
                android:textAllCaps="false"
                android:textColor="@color/button"
                app:cornerRadius="16dp"
                app:strokeColor="@color/button"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
