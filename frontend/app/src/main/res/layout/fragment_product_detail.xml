<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:clipChildren="false"
    android:clipToPadding="false"
    >

    <!-- Top Bar Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutProductTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:elevation="4dp"
        android:paddingHorizontal="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnTopBarBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#80F0F0F0"
            android:contentDescription="@string/content_desc_back"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="TouchTargetSizeCheck"
            app:tint="@color/button" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnWishlist"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#80F0F0F0"
                android:contentDescription="@string/wishlist"
                android:src="@drawable/selector_post_like"
                tools:ignore="TouchTargetSizeCheck"
                app:tint="@color/button" />

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#80F0F0F0"
                android:contentDescription="@string/action_share"
                android:src="@drawable/ic_share"
                tools:ignore="TouchTargetSizeCheck"
                app:tint="@color/button" />

            <ImageButton
                android:id="@+id/btnCart"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="#80F0F0F0"
                android:contentDescription="@string/cart"
                android:src="@drawable/ic_cart"
                tools:ignore="TouchTargetSizeCheck"
                app:tint="@color/button" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollProductDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/viewStickyTopShadow"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image Gallery -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="380dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpProductGallery"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/tvProductGalleryCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|right"
                    android:layout_marginBottom="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_kanila_button_pill"
                    android:backgroundTint="#80000000"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/background_main"
                    android:textSize="12sp"
                    tools:text="1/5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnArTryOn"
                    style="@style/Widget.Kanila.Button.Pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="@color/button"
                    android:textColor="@color/white"
                    android:text="Thử màu AR"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </FrameLayout>

            <!-- Thumbnails -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProductThumbnails"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <TextView
                android:id="@+id/tvSelectedVariantName"
                style="@style/Text.Kanila.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingLeft="16dp"
                android:gravity="left"
                android:paddingRight="16dp"
                android:textColor="@color/button"
                android:visibility="gone"
                tools:text="Rose Obsession"
                tools:visibility="visible" />

            <!-- Product Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"

                >

                <TextView
                    android:id="@+id/tvProductDetailBrand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    tools:text="fwee" />

                <TextView
                    android:id="@+id/tvProductDetailName"
                    style="@style/Text.Kanila.H3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="Son bùn fwee Rose Obsession Stay-Fit" />

                <TextView
                    android:id="@+id/tvProductDetailDesc"
                    style="@style/Text.Kanila.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_secondary"
                    tools:text="Mô tả ngắn sản phẩm" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <RatingBar
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="1"
                        android:rating="1"
                        android:progressTint="@color/button" />

                    <TextView
                        android:id="@+id/tvProductRating"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/nunito_bold"
                        tools:text="4.8" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@color/border_divider" />

                    <TextView
                        android:id="@+id/tvProductReviewCount"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        tools:text="12.3K đánh giá" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="@color/border_divider" />

                    <TextView
                        android:id="@+id/tvProductSoldCount"
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        tools:text="Đã bán 273K+" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProductDetailPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_bold"
                        android:textColor="@color/button"
                        android:textSize="20sp"
                        tools:text="245.000đ" />

                    <TextView
                        android:id="@+id/tvProductDetailComparePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_tertiary"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:text="350.000đ"
                        tools:visibility="visible" />
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cgProductBadges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:background="@color/background_sub" />

            <!-- Skin Match Score -->
            <include
                android:id="@+id/layoutSkinMatchScore"
                layout="@layout/view_skin_match_score" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/border_divider" />

            <!-- Sections -->
            <include
                android:id="@+id/layoutSectionDesc"
                layout="@layout/view_product_detail_section" />

            <include
                android:id="@+id/layoutSectionIngredients"
                layout="@layout/view_product_detail_section" />

            <include
                android:id="@+id/layoutSectionUsage"
                layout="@layout/view_product_detail_section" />

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/background_sub" />

            <!-- Review Summary -->
            <include
                android:id="@+id/layoutReviewSummary"
                layout="@layout/view_review_summary_compact" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProductDetailReviewPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="2"
                tools:listitem="@layout/item_review"
                tools:visibility="visible" />

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/background_sub" />

            <!-- Recently Viewed -->
            <LinearLayout
                android:id="@+id/layoutRecentlyViewed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="16dp">

                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Sản phẩm đã xem" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentlyViewed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </LinearLayout>

            <!-- Related Products -->
            <LinearLayout
                android:id="@+id/layoutRelatedProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">
                    <View android:layout_width="40dp" android:layout_height="1dp" android:background="@color/border_divider" />
                    <TextView
                        style="@style/Text.Kanila.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="Có thể bạn cũng thích" />
                    <View android:layout_width="40dp" android:layout_height="1dp" android:background="@color/border_divider" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRelatedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:paddingHorizontal="12dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Out of Stock Notice Overlay -->
    <LinearLayout
        android:id="@+id/layoutOutOfStockNotice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/error_bg"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layoutProductStickyCTA">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_alert"
            app:tint="@color/error" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sản phẩm tạm hết hàng"
                android:textColor="@color/error" />

            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Nhấn chuông để nhận thông báo ngay khi sản phẩm được bổ sung." />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyStock"
            style="@style/Widget.Kanila.Button.Pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhắc tôi" />

    </LinearLayout>

    <!-- Sticky CTA Pink Top Shadow -->
    <LinearLayout
        android:id="@+id/viewStickyTopShadow"
        android:layout_width="0dp"
        android:layout_height="7dp"
        android:orientation="vertical"
        android:elevation="24dp"
        android:translationZ="24dp"
        app:layout_constraintBottom_toTopOf="@id/layoutProductStickyCTA"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.03"
            android:background="@color/button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.06"
            android:background="@color/button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.10"
            android:background="@color/button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.15"
            android:background="@color/button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.20"
            android:background="@color/button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.26"
            android:background="@color/button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.32"
            android:background="@color/button" />

    </LinearLayout>
    <!-- Sticky Bottom CTA -->
    <include
        android:id="@+id/layoutProductStickyCTA"
        layout="@layout/view_product_sticky_cta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Full Screen Loading Overlay -->
    <include
        android:id="@+id/layoutLoading"
        layout="@layout/view_loading_state"
        android:visibility="gone" />

    <!-- Full Screen Error Overlay -->
    <include
        android:id="@+id/layoutError"
        layout="@layout/view_error_generic"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
