<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="@dimen/radius_m"
    app:cardElevation="2dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_m">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yêu cầu hỗ trợ"
            android:textAppearance="@style/Text.Kanila.H3"
            android:textColor="@color/accent_dark" />

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:stretchColumns="1">

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã ticket: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvTicketCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    android:textStyle="bold"
                    tools:text="SPT20260708001" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvTicketStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/status_pending_text"
                    tools:text="Đã tiếp nhận" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loại yêu cầu: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvTicketCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    tools:text="Sai/thiếu sản phẩm" />
            </TableRow>

            <TableRow android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời gian tạo: "
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
                <TextView
                    android:id="@+id/tvTicketCreatedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_main"
                    tools:text="08/07/2026 14:20" />
            </TableRow>
        </TableLayout>

        <TextView
            android:id="@+id/tvTicketMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/background_sub"
            android:padding="8dp"
            android:textAppearance="@style/Text.Kanila.Micro"
            android:textColor="@color/text_secondary"
            tools:text="Kanila đã ghi nhận yêu cầu hỗ trợ của bạn." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewTicketDetail"
            style="@style/Widget.Kanila.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:text="Theo dõi yêu cầu"
            android:textSize="12sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
