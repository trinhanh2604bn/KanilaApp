<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutPostItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/spacing_l"
    android:layout_marginEnd="@dimen/spacing_l"
    android:layout_marginTop="@dimen/spacing_s"
    android:layout_marginBottom="@dimen/spacing_s"
    android:background="@drawable/bg_community_card"
    android:orientation="vertical"
    app:cardElevation="4dp"
    app:cardMaxElevation="4dp"
    app:cardUseCompatPadding="false"
    android:padding="@dimen/spacing_l">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivPostAvatar"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImage"
            tools:src="@android:drawable/ic_menu_report_image" />

        <LinearLayout
            android:id="@+id/layoutPostUserInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvPostUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Kim Trần"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    tools:text="Kim Trần" />

                <ImageView
                    android:id="@+id/ivPostVerified"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="Verified"
                    android:src="@drawable/ic_verified"
                    app:tint="@color/button" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPostTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="2 giờ trước"
                android:textColor="@color/border_divider"
                android:textSize="10sp"
                tools:text="2 giờ trước" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPostMore"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"
            android:src="@drawable/ic_more_horiz"
            tools:ignore="TouchTargetSizeCheck"
            app:tint="@color/text_main" />
    </LinearLayout>

    <!-- Verified Purchase Badge -->
    <LinearLayout
        android:id="@+id/layoutVerifiedPurchase"
        android:layout_width="wrap_content"
        android:layout_height="25dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_verified_pill"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivVerifiedPurchaseIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_verified"
            app:tint="@color/button"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvVerifiedPurchase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:fontFamily="@font/nunito_semibold"
            android:text="Đã mua hàng"
            android:textColor="@color/button"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Content Section -->
    <TextView
        android:id="@+id/tvPostTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/nunito_bold"
        android:text="Serum Niacinamide 10% – sáng da, mờ thâm thấy rõ!"
        android:textColor="@color/text_main"
        android:textSize="16sp"
        tools:text="Serum Niacinamide 10% – sáng da, mờ thâm thấy rõ!" />

    <TextView
        android:id="@+id/tvPostContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/nunito_regular"
        android:lineSpacingExtra="2dp"
        android:text="Sau 3 tuần sử dụng The Ordinary Niacinamide 10% + Zinc 1% da mình sáng và cũng không nhờn rít."
        android:textColor="@color/text_main"
        android:textSize="12sp"
        tools:text="Sau 3 tuần sử dụng The Ordinary Niacinamide 10% + Zinc 1% da mình sáng và cũng không nhờn rít." />

    <!-- Gallery Section -->
    <HorizontalScrollView
        android:id="@+id/hsvPostImages"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="4dp"
        android:contentDescription="@string/post_gallery"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutPostImages"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPostImage1"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/post_image_1"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedProductImage"
                tools:src="@android:drawable/ic_menu_report_image" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPostImage2"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:contentDescription="@string/post_image_2"
                app:shapeAppearanceOverlay="@style/RoundedProductImage"
                tools:src="@android:drawable/ic_menu_report_image" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPostImage3"
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:contentDescription="@string/post_image_3"
                app:shapeAppearanceOverlay="@style/RoundedProductImage"
                tools:src="@android:drawable/ic_menu_report_image" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Footer Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/layoutPostLike"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            tools:ignore="TouchTargetSizeCheck"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/ivPostLikeIcon"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:duplicateParentState="true"
                android:src="@drawable/ic_heart_outline"
                app:tint="@color/selector_post_action_tint" />

            <TextView
                android:id="@+id/tvPostLikeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:duplicateParentState="true"
                android:fontFamily="@font/nunito_regular"
                android:text="1.2K"
                android:textColor="@color/selector_post_action_tint"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPostComment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            tools:ignore="TouchTargetSizeCheck"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/ivPostCommentIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:duplicateParentState="true"
                android:src="@drawable/ic_comment"
                app:tint="@color/selector_post_action_tint" />

            <TextView
                android:id="@+id/tvPostCommentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:duplicateParentState="true"
                android:fontFamily="@font/nunito_regular"
                android:text="137"
                android:textColor="@color/selector_post_action_tint"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutPostShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            tools:ignore="TouchTargetSizeCheck"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/ivPostShareIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:duplicateParentState="true"
                android:src="@drawable/ic_share"
                app:tint="@color/selector_post_action_tint" />

            <TextView
                android:id="@+id/tvPostShareCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:duplicateParentState="true"
                android:fontFamily="@font/nunito_regular"
                android:text="36"
                android:textColor="@color/selector_post_action_tint"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnPostSave"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@android:color/transparent"
            android:contentDescription="Save post"
            app:tint="@color/selector_post_action_tint"
            android:scaleType="centerInside"
            android:src="@drawable/ic_bookmark_outline"
            tools:ignore="TouchTargetSizeCheck"
            />

    </LinearLayout>

</LinearLayout>
