<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#F5F5F5"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivTicketIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@color/icon_bg_pink"
            android:padding="10dp"
            android:src="@drawable/ic_comment"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:tint="@color/button" />

        <TextView
            android:id="@+id/tvTicketTitle"
            style="@style/Text.Kanila.BodyMedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:text="@string/ticket_sample_title_1"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvStatus"
            app:layout_constraintStart_toEndOf="@id/ivTicketIcon"
            app:layout_constraintTop_toTopOf="@id/ivTicketIcon" />

        <TextView
            android:id="@+id/tvTicketDetails"
            style="@style/Text.Kanila.Micro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.6"
            android:text="#SR24060031 - Đơn #KB24052568"
            app:layout_constraintEnd_toEndOf="@id/tvTicketTitle"
            app:layout_constraintStart_toStartOf="@id/tvTicketTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTicketTitle" />

        <TextView
            android:id="@+id/tvLastUpdated"
            style="@style/Text.Kanila.Micro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.8"
            android:text="Cập nhật: 1 giờ trước"
            app:layout_constraintEnd_toEndOf="@id/tvTicketDetails"
            app:layout_constraintStart_toStartOf="@id/tvTicketDetails"
            app:layout_constraintTop_toBottomOf="@id/tvTicketDetails" />

        <TextView
            android:id="@+id/tvStatus"
            style="@style/Text.Kanila.Micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_pink"
            android:backgroundTint="@color/status_pending_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="@string/status_processing"
            android:textColor="@color/status_pending_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvTicketTitle" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_arrow_right"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatus"
            app:tint="@color/border_divider" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
