<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_main">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingBottom="40dp">

        <ImageButton
            android:id="@+id/btnBack"
            style="@style/Widget.Kanila.Button.Icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/content_desc_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/layoutLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvLogoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:letterSpacing="-0.02"
                android:text="Kanila"
                android:textColor="@color/accent_dark"
                android:textSize="34sp"
                tools:ignore="HardcodedText" />

        </LinearLayout>

        <ImageView
            android:id="@+id/ivIllustration"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="16dp"
            android:scaleType="centerInside"
            android:src="@drawable/login_7"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/layoutLogo" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/auth_otp_verify_title"
            android:textColor="@color/accent_dark"
            android:textSize="28sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivIllustration" />

        <TextView
            android:id="@+id/tvSubtitle"
            style="@style/Text.Kanila.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintWidth_percent="0.9"
            tools:text="Nhập mã OTP gồm 6 số đã được gửi đến số điện thoại 09xx xxx xxx." />

        <LinearLayout
            android:id="@+id/layoutOtpInputs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

            <include layout="@layout/view_otp_box" />
            <include layout="@layout/view_otp_box" />
            <include layout="@layout/view_otp_box" />
            <include layout="@layout/view_otp_box" />
            <include layout="@layout/view_otp_box" />
            <include layout="@layout/view_otp_box" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvOtpError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/nunito_regular"
            android:textColor="@color/error"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutOtpInputs"
            tools:text="Vui lòng nhập đủ 6 số"
            tools:visibility="visible" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutNotice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_auth_consent_row"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutOtpInputs">

            <ImageView
                android:id="@+id/ivNoticeIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/bg_icon_soft"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/button"
                app:layout_constraintBottom_toBottomOf="@id/ivNoticeIcon"
                app:layout_constraintEnd_toEndOf="@id/ivNoticeIcon"
                app:layout_constraintStart_toStartOf="@id/ivNoticeIcon"
                app:layout_constraintTop_toTopOf="@id/ivNoticeIcon" />

            <TextView
                android:id="@+id/tvNoticeTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/auth_otp_notice_title"
                android:textColor="@color/accent_dark"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivNoticeIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvNoticeDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:text="@string/auth_otp_notice_desc"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvNoticeTitle"
                app:layout_constraintTop_toBottomOf="@id/tvNoticeTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/layoutResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutNotice">

            <TextView
                android:id="@+id/tvResendCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                tools:text="Gửi lại mã sau 00:42" />

            <TextView
                android:id="@+id/btnResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/nunito_medium"
                android:text="@string/auth_otp_btn_resend"
                android:textColor="@color/button"
                android:textSize="14sp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_auth_primary_gradient"
            app:backgroundTint="@null"
            android:text="@string/auth_otp_btn_verify"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/nunito_bold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/layoutResend" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangeTarget"
            style="@style/Widget.Kanila.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:fontFamily="@font/nunito_bold"
            app:cornerRadius="28dp"
            app:layout_constraintTop_toBottomOf="@id/btnVerify"
            tools:text="@string/auth_otp_change_phone" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_auth_consent_row"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnChangeTarget">

            <ImageView
                android:id="@+id/ivHelpIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/bg_icon_soft"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chatbot"
                app:tint="@color/button"
                app:layout_constraintBottom_toBottomOf="@id/ivHelpIcon"
                app:layout_constraintEnd_toEndOf="@id/ivHelpIcon"
                app:layout_constraintStart_toStartOf="@id/ivHelpIcon"
                app:layout_constraintTop_toTopOf="@id/ivHelpIcon" />

            <TextView
                android:id="@+id/tvHelpQuestion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/auth_otp_help_question"
                android:textColor="@color/accent_dark"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/ivArrow"
                app:layout_constraintStart_toEndOf="@id/ivHelpIcon"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvHelpAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:text="@string/auth_otp_help_action"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/ivArrow"
                app:layout_constraintStart_toStartOf="@id/tvHelpQuestion"
                app:layout_constraintTop_toBottomOf="@id/tvHelpQuestion" />

            <ImageView
                android:id="@+id/ivArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
