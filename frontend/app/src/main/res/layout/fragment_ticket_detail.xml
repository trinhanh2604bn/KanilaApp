<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chi tiết yêu cầu"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Ticket Status Info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView android:id="@+id/tvTicketId" style="@style/Text.Kanila.H3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#SR24059980" android:textStyle="bold" />
                    <TextView android:id="@+id/tvTicketType" style="@style/Text.Kanila.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Tư vấn sản phẩm" android:alpha="0.7" />
                    <TextView android:id="@+id/tvTicketStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_chip_pill" android:backgroundTint="@color/status_success_bg" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="Đã hoàn tất" android:textColor="@color/status_success_text" android:textSize="11sp" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Latest Response -->
            <TextView style="@style/Text.Kanila.H3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phản hồi mới nhất" android:textColor="@color/accent_dark" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/background_sub">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView style="@style/Text.Kanila.Body" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Dạ Kanila đã nhận được thông tin và hoàn tất hỗ trợ cho bạn rồi ạ. Hy vọng bạn hài lòng với dịch vụ của chúng mình!" />
                    <TextView style="@style/Text.Kanila.Micro" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Bởi Linh - 1 ngày trước" android:alpha="0.5" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rating Section (Only for completed tickets) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ratingCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/secondary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đánh giá hỗ trợ"
                        style="@style/Text.Kanila.H3"
                        android:textColor="@color/accent_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Hãy cho chúng tôi biết cảm nhận của bạn về lần hỗ trợ này"
                        style="@style/Text.Kanila.Caption"
                        android:gravity="center"
                        android:alpha="0.6" />

                    <!-- Star Bar -->
                    <LinearLayout
                        android:id="@+id/starContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" />
                        <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" />
                        <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" />
                        <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" />
                        <ImageView android:layout_width="44dp" android:layout_height="44dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRatingLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tuyệt vời!"
                        style="@style/Text.Kanila.Micro"
                        android:textColor="@color/button"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etRatingComment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_kanila_input_default"
                        android:gravity="top"
                        android:minLines="4"
                        android:padding="16dp"
                        android:hint="Chia sẻ ý kiến của bạn về lần hỗ trợ này..."
                        style="@style/Text.Kanila.Caption"
                        android:textColor="@color/text_main"
                        android:importantForAutofill="no"
                        android:inputType="textMultiLine" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmitRating"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        style="@style/Widget.Kanila.Button.Primary"
                        android:text="Gửi đánh giá"
                        android:textAllCaps="false"
                        android:fontFamily="@font/nunito_bold"
                        android:backgroundTint="@color/accent_dark"
                        app:cornerRadius="16dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions (Removed) -->

</androidx.constraintlayout.widget.ConstraintLayout>
