<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/recommendationLookRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sub">

    <!-- Thanh tiêu đề -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbarRecommendation"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_sub"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Nút quay lại -->
        <ImageView
            android:id="@+id/btnBackRec"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="Look trang điểm đề xuất"
            android:textColor="@color/accent_dark"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Nhãn AI -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_pink"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="AI"
                android:src="@drawable/ic_goal_sparkle"
                app:tint="@color/button" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:fontFamily="@font/nunito_bold"
                android:text="AI"
                android:textColor="@color/button"
                android:textSize="12sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Nội dung có thể cuộn -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/layoutActionsRec"
        app:layout_constraintTop_toBottomOf="@id/toolbarRecommendation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Banner Look đề xuất -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="240dp"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivHeroImage"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:contentDescription="Look trang điểm đề xuất"
                        android:scaleType="centerCrop"
                        android:src="@drawable/hinh_nen"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintWidth_percent="0.6" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_makeup_hero_overlay" />

                    <TextView
                        android:id="@+id/badgeAI"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@android:color/white"
                        android:drawablePadding="6dp"
                        android:fontFamily="@font/nunito_bold"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="Gợi ý từ AI cho bạn"
                        android:textColor="@color/button"
                        android:textSize="10sp"
                        app:drawableStartCompat="@drawable/ic_goal_sparkle"
                        app:drawableTint="@color/button"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/badgeAI"
                        app:layout_constraintVertical_bias="0.2"
                        app:layout_constraintWidth_percent="0.65">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/nunito_bold"
                            android:lineSpacingExtra="2dp"
                            android:text="Look trong veo cho da dầu mụn"
                            android:textColor="@color/accent_dark"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:alpha="0.8"
                            android:fontFamily="@font/nunito_semibold"
                            android:text="Tự nhiên - Kiểm soát dầu - Hài hòa - Đi làm"
                            android:textColor="@color/text_main"
                            android:textSize="12sp" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Tiêu đề các bước -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="Các bước trang điểm"
                    android:src="@drawable/ic_goal_sparkle"
                    app:tint="@color/button" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Các bước trang điểm"
                    android:textColor="@color/accent_dark"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Danh sách các bước -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingHorizontal="4dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <include layout="@layout/item_makeup_step" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Bước tiếp theo"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/secondary" />

                    <include layout="@layout/item_makeup_step" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Bước tiếp theo"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/secondary" />

                    <include layout="@layout/item_makeup_step" />

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Các nút phía dưới -->
    <LinearLayout
        android:id="@+id/layoutActionsRec"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_sub"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuyAllRec"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/button"
            android:fontFamily="@font/nunito_bold"
            android:text="Mua trọn bộ"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_cart"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveLookRec"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/nunito_bold"
            android:text="Lưu look"
            android:textAllCaps="false"
            android:textColor="@color/button"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_bookmark"
            app:iconGravity="textStart"
            app:iconTint="@color/button"
            app:strokeColor="@color/button" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>