<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/ivMissionIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_chatbot_soft_dot"
        android:padding="10dp"
        android:src="@drawable/ic_camera"
        app:tint="@color/accent_dark" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMissionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Viết review có ảnh"
            android:textAppearance="@style/Text.Kanila.BodyMedium"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMissionSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Duy trì đăng nhập 7 ngày"
            android:textAppearance="@style/Text.Kanila.Micro"
            android:textColor="@color/text_tertiary"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvMissionPoints"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="+20đ"
        android:textAppearance="@style/Text.Kanila.BodyMedium"
        android:textColor="@color/button"
        android:textStyle="bold" />

    <ImageView
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/text_tertiary" />

</LinearLayout>
