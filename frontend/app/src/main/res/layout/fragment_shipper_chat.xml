<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:paddingTop="32dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark"
            android:contentDescription="@string/content_desc_back" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyễn Văn Nam"
                android:textColor="@color/accent_dark"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shipper đang đến"
                android:textColor="@color/success"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnCallHeader"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:padding="10dp"
            android:src="@drawable/ic_support"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark"
            android:contentDescription="@string/channel_call" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Chat Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutInput"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_chip_pill"
                android:backgroundTint="@color/background_sub"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Hôm nay"
                tools:ignore="HardcodedText" />

            <!-- Bot/Shipper Message -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_bubble_bot"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    style="@style/Text.Kanila.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chào anh, em đang lấy hàng từ kho Kanila ạ."
                    android:textColor="@color/text_main"
                    tools:ignore="HardcodedText" />
                <TextView
                    style="@style/Text.Kanila.Micro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="10:05"
                    android:textColor="@color/text_tertiary"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <!-- User Message -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginStart="64dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_bubble_user"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    style="@style/Text.Kanila.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ok em, khi nào đến gọi anh nhé."
                    android:textColor="@color/text_main"
                    tools:ignore="HardcodedText" />
                <TextView
                    style="@style/Text.Kanila.Micro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:text="10:07 ✔✔"
                    android:textColor="@color/text_tertiary"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Input Bar -->
    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_camera"
            app:tint="@color/text_tertiary"
            android:contentDescription="@null" />

        <EditText
            android:id="@+id/edtMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_chat_input"
            android:hint="Nhắn cho shipper..."
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:inputType="text"
            android:importantForAutofill="no"
            tools:ignore="HardcodedText" />

        <ImageView
            android:id="@+id/btnSendMessage"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_send"
            app:tint="@color/button"
            android:contentDescription="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
