<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sub">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome & Search Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_help_center_header"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="64dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Xin chào, chúng tôi có thể giúp gì cho bạn?"
                    android:textAppearance="@style/Text.Kanila.H3"
                    android:textColor="@color/bg_primary"
                    android:textStyle="bold" />

                <include
                    android:id="@+id/layoutHelpSearch"
                    layout="@layout/view_search_bar"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp" />

            </LinearLayout>

            <!-- Update Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_main"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/button" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Cập nhật địa chỉ hành chính mới"
                    android:textAppearance="@style/Text.Kanila.Body"
                    android:textColor="@color/text_main" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_tertiary" />
            </LinearLayout>

            <!-- Account Support Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:text="Hỗ trợ về tài khoản"
                    android:textAppearance="@style/Text.Kanila.H3"
                    android:textColor="@color/text_main" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:backgroundTint="@color/background_main">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/button" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Đổi Số Điện Thoại"
                        android:textAppearance="@style/Text.Kanila.Body"
                        android:textColor="@color/text_main" />
                </LinearLayout>
            </LinearLayout>

            <!-- FAQ Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:textStyle="bold"
                    android:text="Câu hỏi thường gặp"
                    android:textAppearance="@style/Text.Kanila.H3"
                    android:textColor="@color/text_main" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutHelpTabs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">
                        <!-- Tab Items -->
                    </LinearLayout>
                </HorizontalScrollView>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFaqList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="16dp"
                    tools:listitem="@layout/item_faq" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Nếu bạn vẫn còn câu hỏi? Bạn có thể tìm hiểu thêm tại Trung tâm hỗ trợ Kanila VN"
                    android:textAppearance="@style/Text.Kanila.Caption"
                    android:textColor="@color/text_tertiary" />
            </LinearLayout>

            <!-- Footer Contact Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Bạn có muốn tìm thêm thông tin gì không?"
                    android:textAppearance="@style/Text.Kanila.BodyMedium"
                    android:textColor="@color/text_main" />

                <include
                    android:id="@+id/menuCSKH"
                    layout="@layout/view_account_menu_item" />

                <include
                    android:id="@+id/menuCall"
                    layout="@layout/view_account_menu_item" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Header (Overlapping) -->
    <include
        android:id="@+id/layoutHeader"
        layout="@layout/view_app_top_bar" />

</FrameLayout>
