<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <!-- Top Bar -->
    <include
        android:id="@+id/layoutProductTopBar"
        layout="@layout/view_app_top_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollProductDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutProductStickyCTA"
        app:layout_constraintTop_toBottomOf="@id/layoutProductTopBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image Gallery -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="350dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vpProductGallery"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/tvProductGalleryCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_kanila_button_pill"
                    android:backgroundTint="#80000000"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/background_main"
                    android:textSize="12sp"
                    tools:text="1/5" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvProductDetailBrand"
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_dark"
                    tools:text="Kanila Beauty" />

                <TextView
                    android:id="@+id/tvProductDetailName"
                    style="@style/Text.Kanila.H2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="Kanila Sweet Lip For You" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProductDetailPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_bold"
                        android:textColor="@color/button"
                        android:textSize="22sp"
                        tools:text="245.000đ" />

                    <TextView
                        android:id="@+id/tvProductDetailComparePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_tertiary"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:text="300.000đ"
                        tools:visibility="visible" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/border_divider" />

                <!-- Description -->
                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mô tả sản phẩm" />

                <TextView
                    android:id="@+id/tvProductDetailDesc"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    tools:text="Sản phẩm son dưỡng có màu với chiết xuất từ thiên nhiên..." />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Bottom CTA -->
    <LinearLayout
        android:id="@+id/layoutProductStickyCTA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnProductChat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_kanila_button_pill"
            android:backgroundTint="@color/background_sub"
            android:contentDescription="Chat"
            android:src="@drawable/ic_support"
            app:tint="@color/accent_dark" />

        <ImageButton
            android:id="@+id/btnProductCart"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_kanila_button_pill"
            android:backgroundTint="@color/background_sub"
            android:contentDescription="Giỏ hàng"
            android:src="@drawable/ic_cart"
            app:tint="@color/accent_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddToCart"
            style="@style/Widget.Kanila.Button.Secondary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Thêm vào giỏ"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuyNow"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Mua ngay"
            android:textAllCaps="false" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
