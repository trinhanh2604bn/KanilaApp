<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="@dimen/radius_m"
    app:cardElevation="2dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_m">

        <TextView
            android:id="@+id/tvIngredientName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧪 Tên thành phần"
            android:textAppearance="@style/Text.Kanila.H3"
            android:textColor="@color/accent_dark"
            tools:text="🧪 Retinol" />

        <LinearLayout
            android:id="@+id/layoutCompatibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status_rounded"
            android:backgroundTint="@color/status_success_bg"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvCompatibilityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Caption"
                android:textColor="@color/success"
                android:textStyle="bold"
                tools:text="🟢 Phù hợp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCompatibilityReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/Micro"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            tools:text="Thành phần này an toàn cho loại da của bạn."
            tools:visibility="visible" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/border_divider" />

        <!-- Benefits -->
        <TextView
            android:id="@+id/tvBenefitsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Công dụng"
            android:textAppearance="@style/Text.Kanila.Caption"
            android:textColor="@color/text_tertiary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBenefits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/Text.Kanila.Caption"
            android:textColor="@color/text_main"
            tools:text="• Chống lão hóa\n• Giảm mụn\n• Mờ thâm" />

        <!-- Suitable Skin Types -->
        <TextView
            android:id="@+id/tvSkinTypesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Phù hợp với"
            android:textAppearance="@style/Text.Kanila.Caption"
            android:textColor="@color/text_tertiary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSkinTypes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/Text.Kanila.Caption"
            android:textColor="@color/text_main"
            tools:text="• Da dầu\n• Da hỗn hợp" />

        <!-- Warnings -->
        <LinearLayout
            android:id="@+id/layoutWarnings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Lưu ý"
                android:textAppearance="@style/Text.Kanila.Caption"
                android:textColor="@color/error"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWarnings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/Text.Kanila.Caption"
                android:textColor="@color/text_main"
                tools:text="• Tránh nắng kỹ\n• Không dùng chung với AHA/BHA" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
