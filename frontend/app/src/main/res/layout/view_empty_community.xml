<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl">

    <LinearLayout
        android:id="@+id/layoutEmptyHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivEmptyHeaderIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvEmptyHeaderText"
            style="@style/Text.Kanila.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Empty Community Feed"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivEmptyIllustration"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/community_feed" />

    <TextView
        android:id="@+id/tvEmptyTitle"
        style="@style/Text.Kanila.H2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_s"
        android:gravity="center"
        android:text="Chưa có bài viết nào" />

    <TextView
        android:id="@+id/tvEmptyDescription"
        style="@style/Text.Kanila.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_l"
        android:text="Hãy là người đầu tiên chia sẻ bí quyết làm đẹp với Kanila" />

    <Button
        android:id="@+id/btnEmptyAction"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:text="Tạo bài viết" />

</LinearLayout>