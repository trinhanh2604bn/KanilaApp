<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_bold"
        android:text="Thông tin nhận hoa hồng"
        android:textColor="@color/text_main"
        android:textSize="20sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/nunito_regular"
        android:text="Dùng để đối soát và thanh toán thu nhập hàng tháng."
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/nunito_semibold"
        android:text="Tên ngân hàng"
        android:textColor="@color/text_main" />

    <EditText
        android:id="@+id/etBankName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_kanila_input_default"
        android:hint="Ví dụ: Vietcombank"
        android:inputType="text"
        android:paddingHorizontal="16dp"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/nunito_semibold"
        android:text="Số tài khoản"
        android:textColor="@color/text_main" />

    <EditText
        android:id="@+id/etBankAccount"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_kanila_input_default"
        android:hint="Nhập số tài khoản"
        android:inputType="number"
        android:paddingHorizontal="16dp"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/nunito_semibold"
        android:text="Số CMND/CCCD"
        android:textColor="@color/text_main" />

    <EditText
        android:id="@+id/etIdNumber"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_kanila_input_default"
        android:hint="Nhập số CCCD"
        android:inputType="number"
        android:paddingHorizontal="16dp"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/nunito_semibold"
        android:text="Mã số thuế (nếu có)"
        android:textColor="@color/text_main" />

    <EditText
        android:id="@+id/etTaxId"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_kanila_input_default"
        android:hint="Không bắt buộc"
        android:inputType="text"
        android:paddingHorizontal="16dp"
        android:textSize="14sp" />

</LinearLayout>
