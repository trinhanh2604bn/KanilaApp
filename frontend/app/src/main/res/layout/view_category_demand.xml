<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCategoryIconCard"
    android:layout_width="match_parent"
    android:layout_height="@dimen/category_demand_card_height"
    android:background="@drawable/bg_category_icon_card"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_l">

    <!-- Icon circle container -->
    <FrameLayout
        android:id="@+id/layoutCategoryIconCircle"
        android:layout_width="@dimen/category_demand_icon_circle_size"
        android:layout_height="@dimen/category_demand_icon_circle_size"
        android:background="@drawable/bg_category_icon_circle">

        <ImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="@dimen/category_demand_icon_size"
            android:layout_height="@dimen/category_demand_icon_size"
            android:layout_gravity="center"
            android:contentDescription="@string/content_desc_category_icon"
            android:scaleType="centerInside"
            android:src="@drawable/ic_blush"
            app:tint="@color/success" />
    </FrameLayout>

    <!-- Category name -->
    <TextView
        android:id="@+id/tvCategoryName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_l"
        android:ellipsize="end"
        android:fontFamily="@font/nunito_semibold"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="@string/category_concealing"
        android:textColor="@color/text_main"
        android:textSize="22sp"
        tools:text="Concealing" />

</LinearLayout>