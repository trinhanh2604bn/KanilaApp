<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_drag_handle"
            android:backgroundTint="@color/border_divider" />

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_avatar_circle"
                android:padding="6dp"
                android:src="@drawable/ic_chat_placeholder"
                app:tint="@color/accent_dark"
                android:contentDescription="AI icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDialogIngredientTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧪 Phân tích thành phần"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/text_main"
                    android:textSize="17sp"
                    tools:text="🧪 Retinol" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phân tích từ Kanila AI"
                    android:fontFamily="@font/nunito_regular"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_divider" />

        <!-- Compatibility Badge -->
        <LinearLayout
            android:id="@+id/layoutDialogCompatibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_status_rounded"
            android:backgroundTint="@color/status_success_bg"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/tvDialogCompatibilityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/success"
                android:textSize="13sp"
                tools:text="🟢 Phù hợp với da của bạn" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDialogCompatibilityReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/nunito_regular"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Thành phần này an toàn và phù hợp với loại da của bạn."
            tools:visibility="visible" />

        <!-- Content sections -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Benefits -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Công dụng"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDialogBenefits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_recommendation_highlight"
                android:padding="12dp"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                tools:text="• Chống lão hóa\n• Giảm mụn\n• Mờ thâm nám" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="@color/border_divider" />

            <!-- Skin Types -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 Phù hợp với loại da"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvDialogSkinTypes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                tools:text="• Da dầu\n• Da hỗn hợp" />

            <!-- Warnings (optional) -->
            <LinearLayout
                android:id="@+id/layoutDialogWarnings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/border_divider" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Lưu ý quan trọng"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/error"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_rounded"
                    android:backgroundTint="@color/status_payment_failed_bg"
                    android:padding="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDialogWarnings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_main"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="• Tránh nắng kỹ khi dùng\n• Không dùng chung với AHA/BHA" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
