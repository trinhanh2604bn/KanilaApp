<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl">

    <TextView
        style="@style/Text.Kanila.H3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="Offline/Network Error" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivErrorIllustration"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginEnd="@dimen/spacing_l"
            android:scaleType="fitCenter"
            android:src="@drawable/offline" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvErrorTitle"
                style="@style/Text.Kanila.H2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_s"
                android:text="Không có kết nối Internet" />

            <TextView
                android:id="@+id/tvErrorDescription"
                style="@style/Text.Kanila.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_l"
                android:gravity="center"
                android:text="Vui lòng kiểm tra kết nối mạng\nvà thử lại" />

            <Button
                android:id="@+id/btnErrorRetry"
                style="@style/Widget.Kanila.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/button_height_small"
                android:backgroundTint="@color/secondary"
                android:minWidth="120dp"
                android:paddingHorizontal="@dimen/spacing_xl"
                android:text="Thử lại"
                app:backgroundTint="@color/secondary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>