<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="@dimen/spacing_l"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="@string/content_desc_close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_main" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_s"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:text="@string/create_post_title"
            android:textColor="@color/text_main"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvDraft"
            app:layout_constraintStart_toEndOf="@id/btnClose"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvDraft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_semibold"
            android:padding="@dimen/spacing_s"
            android:text="@string/create_post_draft"
            android:textColor="@color/button"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/dividerHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_divider"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_l"
        app:layout_constraintBottom_toTopOf="@id/btnPost"
        app:layout_constraintTop_toBottomOf="@id/dividerHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_l"
            android:paddingTop="@dimen/spacing_m">

            <!-- User Info Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivUserAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    tools:src="@drawable/ic_account" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_m"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/text_main"
                    android:textSize="15sp"
                    tools:text="Nguyễn Thảo Vy" />

                <TextView
                    android:id="@+id/tvPurchasedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_s"
                    android:background="@drawable/bg_purchased_badge"
                    android:fontFamily="@font/nunito_semibold"
                    android:text="@string/create_post_purchased_badge"
                    android:textColor="@color/button"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Caption Input Container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="@dimen/spacing_m"
                android:background="@drawable/bg_create_post_input"
                android:padding="@dimen/spacing_m">

                <EditText
                    android:id="@+id/edtCaption"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/nunito_regular"
                    android:gravity="top"
                    android:hint="@string/create_post_hint"
                    android:inputType="textMultiLine"
                    android:maxLength="1500"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toTopOf="@id/tvCharCounter"
                    app:layout_constraintTop_toTopOf="parent"
                    android:autofillHints="none" />

                <TextView
                    android:id="@+id/tvCharCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_regular"
                    android:text="0/1500"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Post Type Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/create_post_select_type"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutPostTypes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">
                    <!-- Static chips for UI preview, will be managed in Java -->
                    <include layout="@layout/item_create_post_type_chip" />
                    <include layout="@layout/item_create_post_type_chip" />
                    <include layout="@layout/item_create_post_type_chip" />
                    <include layout="@layout/item_create_post_type_chip" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Media Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/create_post_media_title"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSelectedMedia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_selected_media" />

            <!-- Products Used Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/create_post_products_used"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutProductsUsed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">

                    <include layout="@layout/item_create_post_product_used" />
                    <include layout="@layout/item_add_product_placeholder" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Skin Type Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:fontFamily="@font/nunito_bold"
                android:text="@string/create_post_skin_type_title"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutSkinTypes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp">
                    <include layout="@layout/item_skin_type_chip" />
                    <include layout="@layout/item_skin_type_chip" />
                    <include layout="@layout/item_skin_type_chip" />
                    <include layout="@layout/item_skin_type_chip" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Reward Note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:background="@drawable/bg_create_post_reward_note"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_m">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_gift"
                    app:tint="@color/button"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_m"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_semibold"
                        android:text="@string/create_post_reward_note_1"
                        android:textColor="@color/text_main"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_regular"
                        android:text="@string/create_post_reward_note_2"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Action Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPost"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="@dimen/spacing_l"
        android:enabled="false"
        android:text="@string/create_post_action"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>