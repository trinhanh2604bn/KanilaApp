<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutReelsProductTag"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/bg_community_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <FrameLayout
        android:id="@+id/layoutTagIconCircle"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="@drawable/bg_community_chip">

        <ImageView
            android:id="@+id/ivTagIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_product"
            app:tint="@color/button"
            android:contentDescription="@null" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTagTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:maxLines="1"
            android:text="# Skincare"
            android:textColor="@color/button"
            android:textSize="14sp"
            tools:text="# Skincare" />

        <TextView
            android:id="@+id/tvTagPostCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_regular"
            android:maxLines="1"
            android:text="12.4K posts"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            tools:text="12.4K posts" />
    </LinearLayout>

</LinearLayout>
