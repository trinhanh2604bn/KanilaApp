<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/border_divider"
            app:strokeWidth="1dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/content_desc_back"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/accent_dark" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tư vấn sản phẩm"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:padding="8dp"
            android:src="@drawable/ic_more_horiz"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Chat Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/layoutBottom"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Advisor Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_circle"
                        android:backgroundTint="@color/burgundy" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="K"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kanila Beauty Advisor"
                            android:textColor="@color/text_main"
                            android:textStyle="bold" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_verified"
                            app:tint="@color/button" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_circle"
                            android:backgroundTint="@color/success" />
                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Đang online"
                            android:textColor="@color/success" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- User Message -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginStart="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_bubble_user"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    style="@style/Text.Kanila.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Da mình dầu mụn, lỗ chân lông to, muốn tìm skincare dưới 500k. Kanila gợi ý giúp mình nhé!"
                    android:textColor="@color/text_main" />
                <TextView
                    style="@style/Text.Kanila.Micro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:text="09:41 ✔✔"
                    android:textColor="@color/text_tertiary" />
            </LinearLayout>

            <!-- Bot Message -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginEnd="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_bubble_bot"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    style="@style/Text.Kanila.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dạ Kanila gợi ý 3 sản phẩm phù hợp với da dầu mụn của bạn dưới 500k nhé! 💕"
                    android:textColor="@color/text_main" />
                <TextView
                    style="@style/Text.Kanila.Micro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="09:41"
                    android:textColor="@color/text_tertiary" />
            </LinearLayout>

            <!-- Product List Recommendations -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Product 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/border_divider"
                    app:strokeWidth="1dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/ivProd1"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/cl_product"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/tvProdName1"
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="32dp"
                            android:text="Sữa rửa mặt Rau Má Kanila Centella Cleanser"
                            android:textColor="@color/text_main"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/ivProd1"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/tvPrice1"
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="199.000đ"
                            android:textColor="@color/text_main"
                            app:layout_constraintStart_toStartOf="@id/tvProdName1"
                            app:layout_constraintTop_toBottomOf="@id/tvProdName1" />
                        <TextView
                            android:id="@+id/tag1"
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_chip_pink"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="Phù hợp da dầu mụn"
                            android:textColor="@color/button"
                            app:layout_constraintStart_toStartOf="@id/tvPrice1"
                            app:layout_constraintTop_toBottomOf="@id/tvPrice1" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_bookmark_outline"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/text_tertiary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@id/tag1"
                            app:layout_constraintTop_toBottomOf="@id/tag1">
                            <com.google.android.material.button.MaterialButton
                                style="@style/Widget.Kanila.Button.Secondary"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="Xem chi tiết"
                                android:textSize="12sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="8dp" />
                            <com.google.android.material.button.MaterialButton
                                style="@style/Widget.Kanila.Button.Primary"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="Thêm giỏ"
                                android:textSize="12sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="8dp"
                                app:icon="@drawable/ic_cart"
                                app:iconSize="14dp" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Product 2 (Repeat similar structure) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/border_divider"
                    app:strokeWidth="1dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp">
                        <ImageView
                            android:id="@+id/ivProd2"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/cl_product"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/tvProdName2"
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="32dp"
                            android:text="Serum Niacinamide 10% Kanila Clear Balance"
                            android:textColor="@color/text_main"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/ivProd2"
                            app:layout_constraintTop_toTopOf="parent" />
                        <TextView
                            android:id="@+id/tvPrice2"
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="299.000đ"
                            android:textColor="@color/text_main"
                            app:layout_constraintStart_toStartOf="@id/tvProdName2"
                            app:layout_constraintTop_toBottomOf="@id/tvProdName2" />
                        <TextView
                            android:id="@+id/tag2"
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_chip_pink"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="Phù hợp da dầu mụn"
                            android:textColor="@color/button"
                            app:layout_constraintStart_toStartOf="@id/tvPrice2"
                            app:layout_constraintTop_toBottomOf="@id/tvPrice2" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_bookmark_outline"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/text_tertiary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@id/tag2"
                            app:layout_constraintTop_toBottomOf="@id/tag2">
                            <com.google.android.material.button.MaterialButton
                                style="@style/Widget.Kanila.Button.Secondary"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:text="Xem chi tiết"
                                android:textSize="12sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="8dp" />
                            <com.google.android.material.button.MaterialButton
                                style="@style/Widget.Kanila.Button.Primary"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="Thêm giỏ"
                                android:textSize="12sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                app:cornerRadius="8dp"
                                app:icon="@drawable/ic_cart"
                                app:iconSize="14dp" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Input Area -->
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Suggestion Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="12dp"
            android:paddingHorizontal="16dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Serum"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    style="@style/Text.Kanila.Caption"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chống nắng"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    style="@style/Text.Kanila.Caption"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Routine sáng"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="8dp"
                    style="@style/Text.Kanila.Caption"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_divider">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_chevron_right"
                        android:padding="8dp"
                        app:tint="@color/text_tertiary"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Input Field -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_divider">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_plus"
                    android:padding="10dp"
                    app:tint="@color/text_tertiary"/>
            </com.google.android.material.card.MaterialCardView>

            <EditText
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_chat_input"
                android:hint="Nhắn tin cho Kanila Advisor..."
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:inputType="text"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/pink_bg">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_send"
                    android:padding="10dp"
                    app:tint="@color/button"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
