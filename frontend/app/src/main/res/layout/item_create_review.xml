<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCreateReview"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_community_card"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCreateReviewAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedProductImage"
            tools:src="@android:drawable/ic_menu_report_image" />

        <TextView
            android:id="@+id/tvCreateReviewPlaceholder"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/nunito_regular"
            android:text="Chia sẻ trải nghiệm của bạn..."
            android:textColor="@color/border_divider"
            android:textSize="13sp"
            tools:text="Chia sẻ trải nghiệm của bạn..." />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/background_sub" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/layoutActionPhoto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivActionPhoto"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_photo"
                app:tint="@color/button"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tvActionPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:text="Ảnh/Video"
                android:textColor="@color/text_main"
                android:textSize="11sp"
                tools:text="Ảnh/Video" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutActionProduct"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivActionProduct"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_product"
                app:tint="@color/button"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tvActionProduct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:text="Sản phẩm"
                android:textColor="@color/text_main"
                android:textSize="11sp"
                tools:text="Sản phẩm" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutActionRoutine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivActionRoutine"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_routine"
                app:tint="@color/button"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tvActionRoutine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:text="Routine"
                android:textColor="@color/text_main"
                android:textSize="11sp"
                tools:text="Routine" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutActionPoll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivActionPoll"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_poll"
                app:tint="@color/button"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/tvActionPoll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/nunito_regular"
                android:text="Thăm dò"
                android:textColor="@color/text_main"
                android:textSize="11sp"
                tools:text="Thăm dò" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
