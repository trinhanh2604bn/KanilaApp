<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHomeSearchHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="5dp"
        android:paddingTop="@dimen/spacing_m"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/containerSearchArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_xs"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnNotification"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <include
                android:id="@+id/layoutSearchBar"
                layout="@layout/view_search_bar" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/btnNotification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_notification"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnCart"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/button" />

        <ImageButton
            android:id="@+id/btnCart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_cart"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnWishlist"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/button" />

        <ImageButton
            android:id="@+id/btnWishlist"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_heart_outline"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/button" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/layoutHomeSearchHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- Banner Slider Container -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="@dimen/spacing_m">

                <include
                    android:id="@+id/layoutHomeBanner"
                    layout="@layout/view_home_banner_slider" />

            </FrameLayout>

            <!-- Home Shortcut Section -->
            <LinearLayout
                android:id="@+id/layoutHomeShortcutSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_m"
                android:layout_marginTop="@dimen/spacing_m"
                android:orientation="vertical"
                android:paddingVertical="@dimen/spacing_s">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHomeShortcuts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:orientation="horizontal"
                    android:padding="0dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_home_shortcut" />

            </LinearLayout>

            <include layout="@layout/view_home_social_section" />

            <!-- Shop Catalog Section -->
            <LinearLayout
                android:id="@+id/layoutHomeCatalog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCatalogTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_m"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Dành riêng cho bạn"
                    android:textColor="@color/text_main"
                    android:textSize="18sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAllProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_s"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/spacing_s"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    tools:listitem="@layout/item_product_card" />

            </LinearLayout>

            <!-- Personalized Recommendation Section -->
            <LinearLayout
                android:id="@+id/layoutHomeRecommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_m"
                    android:layout_marginBottom="@dimen/spacing_s">

                    <TextView
                        android:id="@+id/tvRecommendationTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:fontFamily="@font/nunito_bold"
                        android:text="Gợi ý riêng cho bạn"
                        android:textColor="@color/text_main"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/btnViewAllRecommended"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignTop="@id/tvRecommendationTitle"
                        android:layout_alignBottom="@id/tvRecommendationTitle"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:fontFamily="@font/nunito_medium"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="4dp"
                        android:text="Xem tất cả"
                        android:textColor="@color/pink_primary"
                        android:textSize="14sp" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecommendedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/spacing_s"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_product_card" />

                <LinearLayout
                    android:id="@+id/layoutRecommendedError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/spacing_m"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/tvRecommendedError"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/error_load_failed"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/nunito_medium" />
                    <Button
                        android:id="@+id/btnRecommendedRetry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/action_retry"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/pink_primary" />
                </LinearLayout>

            </LinearLayout>

            <!-- Loading / Error States -->
            <FrameLayout
                android:id="@+id/layoutHomeStateContainer"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:visibility="gone">

                <include
                    android:id="@+id/viewHomeLoading"
                    layout="@layout/view_loading_state"
                    android:visibility="gone" />

                <include
                    android:id="@+id/viewHomeError"
                    layout="@layout/view_error_generic"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/layoutBottomNavigation"
        layout="@layout/view_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/ivChatbot"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/chatbotai"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomNavigation"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
