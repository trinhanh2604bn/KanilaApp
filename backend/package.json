{
  "name": "kanila-backend",
  "version": "1.0.0",
  "description": "E-commerce backend API for KANILA",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "seed:admin": "node seed-admin.js",
    "seed:data": "node seed-data.js",
    "cleanup:customers": "node cleanup-invalid-customers.js",
    "seed:categories:makeup": "node scripts/seed-category-makeup-tree.js",
    "seed:brands": "node scripts/seed-brands.js",
    "seed:beauty-references": "node seed-beauty-references.js",
    "migrate:drop-product-code-unique-index": "node scripts/drop-product-code-unique-index.js",
    "verify:vertex": "node scripts/verify-vertex-config.js",
    "test:vertex:unit": "jest --testPathPatterns=\"tests/unit/vertexGemini\" --runInBand",
    "test:vertex:live": "node scripts/test-vertex-live.js",
    "test:vertex": "npm run verify:vertex && npm run test:vertex:unit",
    "test:ai-review": "jest --testPathPatterns=\"tests/reviewAi\" --runInBand",
    "test:search:unit": "jest --testPathPatterns=\"tests/unit/search\" --runInBand",
    "seed:search:aliases": "node scripts/seed-search-aliases.js",
    "rebuild:search:docs": "node scripts/rebuild-product-search-documents.js",
    "test:ar": "jest --testPathPatterns=\"tests/unit/ar.test.js\" --runInBand",
    "test": "jest --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/genai": "^1.52.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jimp": "^1.6.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.12.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  }
}
