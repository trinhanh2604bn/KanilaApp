<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sub">

    <include
        android:id="@+id/layoutHeader"
        layout="@layout/view_app_top_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollReturnDetail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Order Number & Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvOrderNumber"
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã đơn hàng: KNL2507002"
                    android:textColor="@color/text_main" />

                <TextView
                    android:id="@+id/tvReturnStatus"
                    style="@style/Text.Kanila.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Trạng thái: Đang xử lý"
                    android:textColor="@color/button" />
            </LinearLayout>

            <!-- Return Details Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/Text.Kanila.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:text="Thông tin hoàn trả" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/border_divider" />

                <!-- Reason -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lý do hoàn trả"
                        android:textColor="@color/text_tertiary" />

                    <TextView
                        android:id="@+id/tvReturnReason"
                        style="@style/Text.Kanila.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sản phẩm bị lỗi / hư hỏng" />
                </LinearLayout>

                <!-- Description -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mô tả chi tiết"
                        android:textColor="@color/text_tertiary" />

                    <TextView
                        android:id="@+id/tvReturnNote"
                        style="@style/Text.Kanila.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sản phẩm bị vỡ nắp khi nhận hàng..." />
                </LinearLayout>

                <!-- Shipping Method -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phương thức trả hàng"
                        android:textColor="@color/text_tertiary" />

                    <TextView
                        android:id="@+id/tvShippingMethod"
                        style="@style/Text.Kanila.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Shipper đến lấy" />
                </LinearLayout>

                <!-- Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Text.Kanila.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian yêu cầu"
                        android:textColor="@color/text_tertiary" />

                    <TextView
                        android:id="@+id/tvRequestedAt"
                        style="@style/Text.Kanila.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="12-07-2025 10:30" />
                </LinearLayout>
            </LinearLayout>

            <!-- Evidence Section -->
            <LinearLayout
                android:id="@+id/layoutEvidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/background_main"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/Text.Kanila.BodyMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:text="Hình ảnh minh chứng" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEvidenceMedia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_selected_media" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContactSupport"
                style="@style/Widget.Kanila.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_margin="16dp"
                android:text="Liên hệ hỗ trợ"
                app:strokeColor="@color/border_divider" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/layoutLoading"
        layout="@layout/view_loading_state"
        android:visibility="gone" />

    <include
        android:id="@+id/layoutError"
        layout="@layout/view_error_generic"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
