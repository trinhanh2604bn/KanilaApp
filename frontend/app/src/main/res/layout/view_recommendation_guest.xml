<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_beauty_profile_section"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/no_sign_in" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/nunito_bold"
        android:gravity="center"
        android:text="Khám phá gợi ý riêng cho bạn"
        android:textColor="@color/text_main"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/nunito_regular"
        android:gravity="center"
        android:text="Đăng nhập và hoàn thành Beauty Profile để nhận gợi ý phù hợp nhất."
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRecommendationLogin"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="32dp"
        android:text="Đăng nhập ngay"
        app:cornerRadius="24dp" />
</LinearLayout>
