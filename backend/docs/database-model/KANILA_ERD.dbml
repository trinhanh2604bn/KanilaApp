  order_id ObjectId [ref: > Order._id]
  shipmentId ObjectId [ref: > Shipment._id]
  returnNumber String [unique]
  returnReason String 
  returnStatus String 
  return_shipping_method String 
  requested_by_customer_id ObjectId [ref: > Customer._id]
  approvedByAccountId ObjectId [ref: > Account._id]
  requestedAt Date 
  approvedAt Date 
  receivedAt Date 
  completedAt Date 
  note String 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ReturnItem {
  returnId ObjectId [ref: > Return._id]
  orderItemId ObjectId [ref: > OrderItem._id]
  variantId ObjectId [ref: > ProductVariant._id]
  requestedQty Number 
  approvedQty Number 
  receivedQty Number 
  restockQty Number 
  rejectQty Number 
  restockStatus String 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ReturnMedia {
  return_request_id ObjectId [ref: > Return._id]
  media_type String 
  media_url String 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table Review {
  customer_id ObjectId [ref: > Customer._id]
  orderItemId ObjectId [ref: > OrderItem._id]
  productId ObjectId [ref: > Product._id]
  variantId ObjectId [ref: > ProductVariant._id]
  rating Number 
  reviewTitle String 
  reviewContent String 
  reviewTags Array<String> 
  skinTypes Array<String> 
  reviewStatus String 
  helpfulCount Number 
  verifiedPurchaseFlag Boolean 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ReviewMedia {
  reviewId ObjectId [ref: > Review._id]
  mediaType String 
  mediaUrl String 
  sortOrder Number 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ReviewSummary {
  productId ObjectId [unique, ref: > Product._id]
  reviewCount Number 
  averageRating Number 
  rating1Count Number 
  rating2Count Number 
  rating3Count Number 
  rating4Count Number 
  rating5Count Number 
  aiSummary String 
  keywords Array<String> 
  keywordStats Array<Embedded>  [note: "Embedded"]
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ReviewVote {
  reviewId ObjectId [ref: > Review._id]
  customer_id ObjectId [ref: > Customer._id]
  voteType String 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table Role {
  role_code String [unique]
  role_name String 
  description String 
  is_system_role Boolean 
  _id ObjectId [primary key]
  created_at Date 
  updated_at Date 
  __v Number 
}

Table RolePermission {
  role_id ObjectId [ref: > Role._id]
  permission_id ObjectId [ref: > Permission._id]
  created_at Date 
  _id ObjectId [primary key]
  __v Number 
}

Table Shipment {
  order_id ObjectId [ref: > Order._id]
  warehouseId ObjectId [ref: > Warehouse._id]
  shipmentNumber String [unique]
  carrierCode String 
  serviceName String 
  trackingNumber String 
  shipmentStatus String 
  shippedAt Date 
  deliveredAt Date 
  failedAt Date 
  shippingFeeAmount Number 
  currencyCode String 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ShipmentEvent {
  shipmentId ObjectId [ref: > Shipment._id]
  eventCode String 
  eventStatus String 
  eventDescription String 
  eventTime Date 
  locationText String 
  rawPayloadJson String 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ShipmentItem {
  shipmentId ObjectId [ref: > Shipment._id]
  orderItemId ObjectId [ref: > OrderItem._id]
  variantId ObjectId [ref: > ProductVariant._id]
  shippedQty Number 
  deliveredQty Number 
  returnedQty Number 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table ShippingMethod {
  shipping_method_code String [unique]
  shipping_method_name String 
  carrier_code String 
  service_level String 
  description String 
  is_active Boolean 
  _id ObjectId [primary key]
  created_at Date 
  updated_at Date 
  __v Number 
}

Table StockReservation {
  warehouseId ObjectId [ref: > Warehouse._id]
  variantId ObjectId [ref: > ProductVariant._id]
  cart_id ObjectId [ref: > Cart._id]
  checkout_session_id ObjectId [ref: > CheckoutSession._id]
  order_id ObjectId [ref: > Order._id]
  reservedQty Number 
  reservationStatus String 
  expiresAt Date 
  releasedAt Date 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table SupportTicket {
  ticket_code String [unique]
  account_id ObjectId [ref: > Account._id]
  customer_id ObjectId [ref: > Customer._id]
  session_id ObjectId [ref: > ChatbotSession._id]
  related_order_id ObjectId [ref: > Order._id]
  category String 
  subject String 
  description String 
  status String 
  priority String 
  source String 
  _id ObjectId [primary key]
  created_at Date 
  updated_at Date 
  __v Number 
}

Table VariantMedia {
  variantId ObjectId [ref: > ProductVariant._id]
  mediaType String 
  mediaUrl String 
  sortOrder Number 
  isPrimary Boolean 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table VariantOptionValue {
  variantId ObjectId [ref: > ProductVariant._id]
  productOptionValueId ObjectId [ref: > ProductOptionValue._id]
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table Warehouse {
  warehouseCode String [unique]
  warehouseName String 
  contactName String 
  phone String 
  addressLine1 String 
  addressLine2 String 
  ward String 
  district String 
  city String 
  countryCode String 
  warehouseStatus String 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table Wishlist {
  customer_id ObjectId [ref: > Customer._id]
  wishlistName String 
  isDefault Boolean 
  _id ObjectId [primary key]
  createdAt Date 
  updatedAt Date 
  __v Number 
}

Table WishlistItem {
  wishlistId ObjectId [ref: > Wishlist._id]
  productId ObjectId [ref: > Product._id]
  variantId ObjectId [ref: > ProductVariant._id]
  _id ObjectId [primary key]
