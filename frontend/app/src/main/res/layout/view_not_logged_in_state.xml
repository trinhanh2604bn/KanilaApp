<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_main">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutNotLoggedInState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xl">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guidelineTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.08" />

        <View
            android:id="@+id/viewBlob"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:alpha="0.3"
            android:background="@drawable/bg_not_logged_in_blob"
            app:layout_constraintBottom_toBottomOf="@+id/ivNotLoggedInIllustration"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ivNotLoggedInIllustration" />

        <ImageView
            android:id="@+id/ivNotLoggedInIllustration"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:contentDescription="Minh họa đăng nhập bảo mật"
            android:scaleType="fitCenter"
            android:src="@drawable/no_sign_in"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/guidelineTop" />

        <TextView
            android:id="@+id/tvNotLoggedInTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:letterSpacing="0.03"
            android:text="Đăng nhập để tiếp tục"
            android:textColor="@color/accent_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivNotLoggedInIllustration" />

        <TextView
            android:id="@+id/tvNotLoggedInDescription"
            style="@style/Text.Kanila.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_l"
            android:gravity="center"
            android:letterSpacing="0.01"
            android:lineSpacingExtra="4dp"
            android:text="Đăng nhập để lưu sản phẩm yêu thích, theo dõi đơn hàng, nhận ưu đãi và đồng bộ hồ sơ làm đẹp của bạn."
            android:textColor="@color/text_main"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvNotLoggedInTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLoginNow"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="40dp"
            android:letterSpacing="0.05"
            android:text="Đăng nhập ngay"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvNotLoggedInDescription" />

        <TextView
            android:id="@+id/tvPrivacyNote"
            style="@style/Text.Kanila.Micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:alpha="0.6"
            android:text="Thông tin của bạn được Kanila bảo mật an toàn."
            android:textColor="@color/text_main"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnLoginNow" />

        <TextView
            android:id="@+id/tvContinueShopping"
            style="@style/Widget.Kanila.Button.Ghost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_s"
            android:gravity="center"
            android:padding="@dimen/spacing_s"
            android:text="Tiếp tục mua sắm"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvPrivacyNote"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/layoutRegisterRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvContinueShopping"
            app:layout_constraintVertical_bias="1.0">

            <TextView
                android:id="@+id/tvRegisterPrefix"
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.01"
                android:text="Chưa có tài khoản? "
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvCreateAccount"
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:letterSpacing="0.01"
                android:text="Tạo tài khoản"
                android:textColor="@color/button" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
