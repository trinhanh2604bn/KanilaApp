<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivReviewAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/bg_avatar_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvReviewUserName"
            style="@style/Text.Kanila.H3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/ivReviewAvatar"
            app:layout_constraintTop_toTopOf="@id/ivReviewAvatar"
            tools:text="Kim Trân" />

        <TextView
            android:id="@+id/tvVerifiedPurchase"
            style="@style/Text.Kanila.Micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_verified_pill"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="Đã mua hàng"
            android:textColor="@color/success"
            app:layout_constraintBottom_toBottomOf="@id/tvReviewUserName"
            app:layout_constraintStart_toEndOf="@id/tvReviewUserName"
            app:layout_constraintTop_toTopOf="@id/tvReviewUserName" />

        <RatingBar
            android:id="@+id/rbReviewStars"
            style="?android:attr/ratingBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:numStars="5"
            android:progressTint="@color/button"
            app:layout_constraintStart_toStartOf="@id/tvReviewUserName"
            app:layout_constraintTop_toBottomOf="@id/tvReviewUserName"
            tools:rating="5" />

        <TextView
            android:id="@+id/tvReviewDate"
            style="@style/Text.Kanila.Micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/text_tertiary"
            app:layout_constraintBottom_toBottomOf="@id/rbReviewStars"
            app:layout_constraintStart_toEndOf="@id/rbReviewStars"
            app:layout_constraintTop_toTopOf="@id/rbReviewStars"
            tools:text="2 ngày trước" />

        <TextView
            android:id="@+id/tvReviewContent"
            style="@style/Text.Kanila.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/ivReviewAvatar"
            tools:text="Màu son lên chuẩn, chất son nhẹ môi, bám khá tốt và giúp gương mặt trông tươi tắn." />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReviewMedia"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvReviewContent" />

        <LinearLayout
            android:id="@+id/layoutReviewActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/rvReviewMedia">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/btnHelpful"
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:drawableStart="@drawable/ic_heart_outline"
                android:drawablePadding="4dp"
                android:gravity="center_vertical"
                android:text="Yêu thích (0)"
                android:textColor="@color/text_tertiary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/btnReply"
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:drawableStart="@drawable/ic_comment"
                android:drawablePadding="4dp"
                android:gravity="center_vertical"
                android:text="Trả lời"
                app:drawableTint="@color/text_tertiary" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutReviewComments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutReviewActions" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
