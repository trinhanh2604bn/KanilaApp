<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sub">

    <include
        android:id="@+id/layoutHeader"
        layout="@layout/view_app_top_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Section: Credit/Debit -->
            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="@string/payment_card_title"
                android:textColor="@color/text_tertiary" />

            <LinearLayout
                android:id="@+id/containerActiveCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnAddNewCard"
                style="@style/Widget.MaterialComponents.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp"
                app:rippleColor="@color/secondary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_paymeny_card"
                        app:tint="@color/button" />

                    <TextView
                        style="@style/Text.Kanila.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/payment_card_add"
                        android:textColor="@color/text_main" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Linked Bank -->
            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="@string/payment_bank_title"
                android:textColor="@color/text_tertiary" />

            <LinearLayout
                android:id="@+id/containerActiveBanks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnAddNewBank"
                style="@style/Widget.MaterialComponents.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp"
                app:rippleColor="@color/secondary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_routine"
                        app:tint="@color/button"
                        android:contentDescription="@string/payment_bank_title" />

                    <TextView
                        style="@style/Text.Kanila.Body"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/payment_bank_add"
                        android:textColor="@color/text_main" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: E-Wallets -->
            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="24dp"
                android:text="@string/payment_wallet_title"
                android:textColor="@color/text_tertiary" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MaterialComponents.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="@dimen/radius_m"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ShopeePay -->
                    <LinearLayout
                        android:id="@+id/btnShopeePay"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_gift"
                            app:tint="#EE4D2D"
                            android:contentDescription="@string/payment_wallet_shopeepay" />

                        <TextView
                            android:id="@+id/tvShopeePayTitle"
                            style="@style/Text.Kanila.Body"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="@string/payment_wallet_shopeepay"
                            android:textColor="@color/text_main" />

                        <TextView
                            android:id="@+id/tvShopeePayStatus"
                            style="@style/Text.Kanila.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_wallet_not_connected"
                            android:textColor="@color/text_tertiary" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary"
                            android:contentDescription="@string/action_see_all" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/border_divider" />

                    <!-- MoMo -->
                    <LinearLayout
                        android:id="@+id/btnMoMo"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/bg_circle_pink"
                            app:tint="#A50064"
                            android:contentDescription="@string/payment_wallet_momo" />

                        <TextView
                            android:id="@+id/tvMoMoTitle"
                            style="@style/Text.Kanila.Body"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="@string/payment_wallet_momo"
                            android:textColor="@color/text_main" />

                        <TextView
                            android:id="@+id/tvMoMoStatus"
                            style="@style/Text.Kanila.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_wallet_not_connected"
                            android:textColor="@color/text_tertiary" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary"
                            android:contentDescription="@string/action_see_all" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="56dp"
                        android:background="@color/border_divider" />

                    <!-- ZaloPay -->
                    <LinearLayout
                        android:id="@+id/btnZaloPay"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_zalo"
                            app:tint="#008FE5"
                            android:contentDescription="@string/payment_wallet_zalopay" />

                        <TextView
                            android:id="@+id/tvZaloPayTitle"
                            style="@style/Text.Kanila.Body"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:text="@string/payment_wallet_zalopay"
                            android:textColor="@color/text_main" />

                        <TextView
                            android:id="@+id/tvZaloPayStatus"
                            style="@style/Text.Kanila.Caption"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/payment_wallet_not_connected"
                            android:textColor="@color/text_tertiary" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary"
                            android:contentDescription="@string/action_see_all" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Placeholder for Expanded Lists -->
            <LinearLayout
                android:id="@+id/layoutExpandedMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvExpandedTitle"
                    style="@style/Text.Kanila.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/payment_expanded_title"
                    android:textColor="@color/text_tertiary" />

                <LinearLayout
                    android:id="@+id/containerMethodItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
