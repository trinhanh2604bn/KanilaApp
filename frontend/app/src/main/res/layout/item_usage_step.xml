<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStepNumber"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_circle_pink"
            android:backgroundTint="@color/background_sub"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:textColor="@color/button"
            android:textSize="16sp"
            tools:text="1" />

        <TextView
            android:id="@+id/tvStepDescription"
            style="@style/Text.Kanila.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            tools:text="Làm sạch môi trước khi sử dụng sản phẩm." />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
