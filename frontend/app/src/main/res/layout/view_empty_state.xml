<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutEmptyState"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl">

    <!-- Top Header State Indicator (as per image) -->
    <LinearLayout
        android:id="@+id/layoutEmptyHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="40dp">

        <ImageView
            android:id="@+id/ivEmptyHeaderIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:src="@drawable/ic_check_circle"
            android:tint="@color/accent_dark"
            tools:ignore="UseAppTint" />

        <TextView
            android:id="@+id/tvEmptyHeaderText"
            style="@style/Text.Kanila.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            android:textSize="14sp"
            tools:text="Empty Wishlist" />
    </LinearLayout>

    <ImageView
        android:id="@+id/ivEmptyIllustration"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/empty_wishlist" />

    <TextView
        android:id="@+id/tvEmptyTitle"
        style="@style/Text.Kanila.H2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_s"
        android:gravity="center"
        android:text="Chưa có dữ liệu" />

    <TextView
        android:id="@+id/tvEmptyDescription"
        style="@style/Text.Kanila.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_l"
        android:text="Nội dung sẽ hiển thị tại đây khi có thông tin mới." />

    <Button
        android:id="@+id/btnEmptyAction"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:text="Khám phá ngay" />

</LinearLayout>