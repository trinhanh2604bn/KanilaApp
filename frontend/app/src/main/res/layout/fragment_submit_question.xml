<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="Gửi câu hỏi của bạn"
            android:textColor="@color/accent_dark"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nội dung câu hỏi"
                android:textColor="@color/accent_dark" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/background_sub"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <EditText
                    android:id="@+id/etQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/nunito_regular"
                    android:gravity="top"
                    android:hint="Nhập nội dung câu hỏi của bạn tại đây..."
                    android:minHeight="150dp"
                    android:padding="16dp"
                    android:textColor="@color/text_main"
                    android:textSize="15sp" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Phân loại câu hỏi"
                android:textColor="@color/accent_dark" />

            <TextView
                style="@style/Text.Kanila.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Chọn chủ đề để Kanila hỗ trợ bạn nhanh nhất"
                android:textColor="@color/text_tertiary" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2">

                <!-- 6 Categories + 1 Other -->
                <CheckBox android:id="@+id/cbOrders" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Đơn hàng" android:fontFamily="@font/nunito_regular" />
                <CheckBox android:id="@+id/cbReturns" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Đổi trả" android:fontFamily="@font/nunito_regular" />
                <CheckBox android:id="@+id/cbPayment" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Thanh toán" android:fontFamily="@font/nunito_regular" />
                <CheckBox android:id="@+id/cbAccount" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Tài khoản" android:fontFamily="@font/nunito_regular" />
                <CheckBox android:id="@+id/cbProduct" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Sản phẩm" android:fontFamily="@font/nunito_regular" />
                <CheckBox android:id="@+id/cbPromotion" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Khuyến mãi" android:fontFamily="@font/nunito_regular" />
                <CheckBox android:id="@+id/cbOther" android:layout_width="0dp" android:layout_columnWeight="1" android:text="Mục khác" android:fontFamily="@font/nunito_regular" />

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="20dp"
        android:text="Gửi câu hỏi"
        app:cornerRadius="16dp" />

</LinearLayout>
