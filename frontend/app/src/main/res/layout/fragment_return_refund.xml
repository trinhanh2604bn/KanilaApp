<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main">

    <include
        android:id="@+id/layoutHeader"
        layout="@layout/view_app_top_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_l"
        app:layout_constraintBottom_toTopOf="@id/btnSubmit"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_l">

            <!-- Return Reason Section -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                android:text="Lý do đổi trả"
                android:textColor="@color/accent_dark" />

            <RadioGroup
                android:id="@+id/rgReturnReasons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbReasonWrongProduct"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Giao sai sản phẩm" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbReasonDefective"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Sản phẩm bị lỗi / hư hỏng" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbReasonIrritation"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Kích ứng / không phù hợp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbReasonMissingItems"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Thiếu hàng" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbReasonChangeMind"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Đổi ý không muốn mua nữa" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbReasonOther"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Khác" />
            </RadioGroup>

            <!-- Description Section -->
            <TextView
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:text="Mô tả chi tiết"
                android:textColor="@color/accent_dark" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="@dimen/spacing_s"
                android:background="@drawable/bg_create_post_input"
                android:padding="@dimen/spacing_m">

                <EditText
                    android:id="@+id/edtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/nunito_regular"
                    android:gravity="top"
                    android:hint="Vui lòng mô tả chi tiết vấn đề..."
                    android:inputType="textMultiLine"
                    android:maxLength="500"
                    android:textSize="14sp"
                    android:autofillHints="none" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Evidence Media Section -->
            <TextView
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:text="Hình ảnh / Video minh chứng"
                android:textColor="@color/accent_dark" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSelectedMedia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_selected_media" />

            <!-- Shipping Method Section -->
            <TextView
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:text="Phương thức trả hàng"
                android:textColor="@color/accent_dark" />

            <RadioGroup
                android:id="@+id/rgShippingMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbShipPickup"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Shipper đến lấy" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_divider" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbShipSelf"
                    style="@style/Text.Kanila.Body"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:buttonTint="@color/button"
                    android:text="Tự gửi bưu cục" />
            </RadioGroup>

            <!-- Refund Method Section -->
            <TextView
                style="@style/Text.Kanila.BodyMedium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_l"
                android:text="Phương thức hoàn tiền"
                android:textColor="@color/accent_dark" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRefundMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_s"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_m">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_wallet"
                        app:tint="@color/button" />

                    <TextView
                        android:id="@+id/tvRefundAccount"
                        style="@style/Text.Kanila.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_m"
                        android:layout_weight="1"
                        android:text="Hoàn tiền về ví Kanila" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="@dimen/spacing_l"
        android:text="Gửi yêu cầu"
        app:layout_constraintBottom_toBottomOf="parent" />

    <include
        android:id="@+id/layoutLoading"
        layout="@layout/view_loading_state"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
