<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingTop="12dp"
    android:paddingBottom="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_drag_handle" />

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Bộ lọc sản phẩm"
            android:textAppearance="@style/H3"
            android:textColor="@color/text_main" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:src="@drawable/ic_close"
            app:tint="@color/text_secondary"
            android:contentDescription="Đóng" />
    </FrameLayout>

    <!-- Nhóm: Danh mục -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:text="Danh mục"
        android:textAppearance="@style/H3"
        android:textColor="@color/text_main" />

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Skincare"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_selected"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Makeup"
            android:textAppearance="@style/Caption"
            android:textColor="@color/background_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Haircare"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Bodycare"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Nhóm: Giá -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:text="Giá"
        android:textAppearance="@style/H3"
        android:textColor="@color/text_main" />

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Dưới 200k"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_selected"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="200k – 500k"
            android:textAppearance="@style/Caption"
            android:textColor="@color/background_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="500k – 1 triệu"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Trên 1 triệu"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Nhóm: Thương hiệu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        android:text="Thương hiệu"
        android:textAppearance="@style/H3"
        android:textColor="@color/text_main" />

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_selected"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Tất cả"
            android:textAppearance="@style/Caption"
            android:textColor="@color/background_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Kanila"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="The Ordinary"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Laneige"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xem thêm"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_chevron_down"
            app:tint="@color/text_secondary"
            android:contentDescription="Mở rộng" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="@color/border_divider" />

    <!-- Action -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_button_outline"
            android:gravity="center"
            android:text="Đặt lại"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_main" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:text="Áp dụng (128)"
            android:textAppearance="@style/Body"
            android:textColor="@color/background_main" />
    </LinearLayout>
</LinearLayout>