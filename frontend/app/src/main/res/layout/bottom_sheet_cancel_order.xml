<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutBottomSheetCancelOrder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="@dimen/spacing_l">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/touch_target_min"
        android:paddingHorizontal="@dimen/spacing_s">

        <TextView
            style="@style/Text.Kanila.H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Lý Do Hủy"
            android:textColor="@color/accent_dark" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_gravity="end|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Đóng"
            android:scaleType="centerInside"
            android:src="@drawable/ic_close"
            app:tint="@color/text_main" />
    </FrameLayout>

    <!-- Warning area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#FFF9C4"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_alert"
            app:tint="#F9A825" />

        <TextView
            style="@style/Text.Kanila.Micro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:lineSpacingExtra="2dp"
            android:text="Bạn có biết? Bạn có thể cập nhật thông tin nhận hàng cho đơn hàng (1 lần duy nhất). Nếu bạn xác nhận hủy, toàn bộ đơn hàng sẽ được hủy."
            android:textColor="#F57F17" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/rgCancelReasons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <RadioButton
            android:id="@+id/rbReason1"
            style="@style/Text.Kanila.Body"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:buttonTint="@color/button"
            android:text="Tôi muốn cập nhật địa chỉ/sđt nhận hàng" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_divider" />

        <RadioButton
            android:id="@+id/rbReason2"
            style="@style/Text.Kanila.Body"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:buttonTint="@color/button"
            android:text="Người bán không trả lời thắc mắc / yêu cầu của tôi" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_divider" />

        <RadioButton
            android:id="@+id/rbReason3"
            style="@style/Text.Kanila.Body"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:buttonTint="@color/button"
            android:text="Thay đổi đơn hàng (màu sắc, kích thước, thêm mã giảm giá,...)" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_divider" />

        <RadioButton
            android:id="@+id/rbReason4"
            style="@style/Text.Kanila.Body"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:buttonTint="@color/button"
            android:text="Lý do khác" />

    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmCancel"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="24dp"
        android:enabled="false"
        android:text="Xác nhận" />

</LinearLayout>
