<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:background="@drawable/bg_card"
    android:backgroundTint="@color/background_sub"
    android:padding="@dimen/spacing_s">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivContentImage"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:shapeAppearanceOverlay="@style/RoundedEight"
        tools:src="@drawable/img_challenge1"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/ivContentImage"
        android:layout_marginEnd="@dimen/spacing_s"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_pill"
                android:backgroundTint="@color/button"
                android:fontFamily="@font/nunito_bold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:textColor="@color/white"
                android:textSize="9sp"
                tools:text="Ngày 1" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_s"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp"
                tools:text="12/05/2026 08:30" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvContentPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_regular"
            android:maxLines="2"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            tools:text="Hôm nay mình đã thực hiện bước làm sạch da rất kỹ và cảm thấy rất sảng khoái..." />
    </LinearLayout>

</RelativeLayout>
