<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_chip_outline"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp">

        <View
            android:id="@+id/viewSelectionBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_swatch_selected"
            android:visibility="gone" />

        <View
            android:id="@+id/viewColorCircle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_circle" />

        <ImageView
            android:id="@+id/ivTick"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:contentDescription="@string/content_desc_selected"
            android:src="@drawable/ic_tick"
            android:visibility="gone"
            app:tint="@color/text_inverse" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvVariantName"
        style="@style/Text.Kanila.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:textColor="@color/text_main"
        tools:text="#001 Rose Red" />

</LinearLayout>
