<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- Custom Toolbar -->
    <include
        android:id="@+id/layoutToolbar"
        layout="@layout/view_app_top_bar" />

    <!-- Category Filters -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_pill"
                android:backgroundTint="@color/accent_dark"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/notification_filter_all"
                android:textAppearance="@style/Text.Kanila.Caption"
                android:textColor="@color/background_main" />

            <TextView
                android:id="@+id/tvFilterOrders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_pill"
                android:backgroundTint="@color/background_sub"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/notification_filter_orders"
                android:textAppearance="@style/Text.Kanila.Caption"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvFilterOffers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_pill"
                android:backgroundTint="@color/background_sub"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/notification_filter_offers"
                android:textAppearance="@style/Text.Kanila.Caption"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvFilterCommunity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip_pill"
                android:backgroundTint="@color/background_sub"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/notification_filter_community"
                android:textAppearance="@style/Text.Kanila.Caption"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvFilterPersonal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_pill"
                android:backgroundTint="@color/background_sub"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/notification_filter_personal"
                android:textAppearance="@style/Text.Kanila.Caption"
                android:textColor="@color/text_main" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Danh sách thông báo (render động, trộn 4 loại) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_l"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_notification_order" />

    <!-- Trạng thái rỗng khi lọc ra 0 kết quả (ẩn mặc định) -->
    <TextView
        android:id="@+id/layoutNotifEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="@dimen/spacing_l"
        android:text="@string/notification_empty"
        android:textAppearance="@style/Text.Kanila.Caption"
        android:textColor="@color/text_tertiary"
        android:visibility="gone" />

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/layoutBottomNavigation"
        layout="@layout/view_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp" />

</LinearLayout>
