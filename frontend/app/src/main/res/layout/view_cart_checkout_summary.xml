<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCartCheckoutSummary"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="0dp"
    app:cardElevation="16dp"
    app:shapeAppearanceOverlay="@style/ShapeAppearance.Kanila.BottomPanel">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_m">

        <!-- 1. Select All Row -->
        <LinearLayout
            android:id="@+id/layoutCartSelectAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="@dimen/spacing_xs">

            <CheckBox
                android:id="@+id/cbCartSelectAll"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:checked="false"

                tools:ignore="TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/tvCartSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_s"
                android:fontFamily="@font/nunito_semibold"
                android:text="Chọn tất cả sản phẩm"
                android:textColor="@color/text_main"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 3. Discount Row -->
        <RelativeLayout
            android:id="@+id/layoutCartDiscount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:id="@+id/tvCartDiscountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:fontFamily="@font/nunito_regular"
                android:text="Giảm giá"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvCartDiscountValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="-100.000đ, miễn phí vận chuyển" />
        </RelativeLayout>

        <!-- 4. Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_xs"
            android:background="@color/border_divider" />

        <!-- 5. Total Row -->
        <RelativeLayout
            android:id="@+id/layoutCartTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_m"
            android:paddingVertical="@dimen/spacing_xs">

            <TextView
                android:id="@+id/tvCartTotalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/nunito_bold"
                android:text="Tổng cộng"
                android:textColor="@color/text_main"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvCartTotalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/button"
                android:textSize="18sp"
                tools:text="810.000đ" />
        </RelativeLayout>

        <!-- 6. Bottom Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCartChooseVoucher"
                style="@style/Widget.Kanila.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:layout_weight="1.2"
                android:text="Chọn voucher" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCartContinueCheckout"
                style="@style/Widget.Kanila.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Tiếp tục thanh toán" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
