<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl">

    <TextView
        style="@style/Text.Kanila.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="No Support Tickets"
        android:textColor="@color/text_main"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ImageView
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/support_ticket" />

    <TextView
        style="@style/Text.Kanila.H2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_s"
        android:gravity="center"
        android:text="Chưa có yêu cầu hỗ trợ nào" />

    <TextView
        style="@style/Text.Kanila.Body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_xl"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_l"
        android:text="Khi bạn yêu cầu hỗ trợ, lịch sử yêu cầu của bạn sẽ hiện ở đây" />

    <Button
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:text="Liên hệ hỗ trợ" />

</LinearLayout>