<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btnClose"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="end"
        android:src="@drawable/ic_close"
        app:tint="@color/text_tertiary"
        android:contentDescription="Đóng"
        tools:ignore="HardcodedText" />

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_icon_circle_success">
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            app:tint="@color/success"
            android:contentDescription="Thành công"
            tools:ignore="HardcodedText" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        style="@style/Text.Kanila.H3"
        android:text="Thành công!"
        android:textColor="@color/accent_dark"
        tools:ignore="HardcodedText" />

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        style="@style/Text.Kanila.Body"
        android:textColor="@color/text_secondary"
        android:text="Thao tác của bạn đã được thực hiện thành công."
        tools:ignore="HardcodedText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirm"
        style="@style/Widget.Kanila.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:text="Đóng"
        android:backgroundTint="@color/burgundy"
        tools:ignore="HardcodedText" />

</LinearLayout>
