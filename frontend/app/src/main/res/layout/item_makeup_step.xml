<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="#FDF9FB"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#1A000000"
                app:strokeWidth="0.5dp">

                <ImageView
                    android:id="@+id/ivStepProduct"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_skincare"
                    android:contentDescription="Product Image" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvStepNumber"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="@color/accent_dark"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:text="Kem lót"
            android:textColor="@color/accent_dark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvStepEffect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.6"
            android:fontFamily="@font/nunito_medium"
            android:gravity="center"
            android:text="Làm mờ lỗ chân lông"
            android:textColor="@color/text_main"
            android:textSize="10sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
