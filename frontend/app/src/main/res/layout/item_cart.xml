<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/background_main"
    app:cardCornerRadius="@dimen/radius_l"
    app:cardElevation="6dp"
    app:cardPreventCornerOverlap="false"
    app:shadowColor="@color/secondary"
    app:strokeColor="@color/background_sub"
    app:strokeWidth="1dp">

    <LinearLayout
        android:id="@+id/layoutCartItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="82dp"
        android:orientation="horizontal"
        android:padding="8dp">

        <CheckBox
            android:id="@+id/cbCartSelected"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:buttonTint="@color/button"
            android:checked="true"
            tools:ignore="TouchTargetSizeCheck" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCartProductImage"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/product_image_desc"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedProductImage"
            tools:src="@android:drawable/ic_menu_report_image" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/tvCartProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/nunito_bold"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="LANEIGE Lip Sleeping Mask EX"
                android:textColor="@color/text_main"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/layoutCartVariant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_variant_selector"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp">

                <TextView
                    android:id="@+id/tvCartProductVariant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/nunito_semibold"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="Berry 20g"
                    android:textColor="@color/accent_dark"
                    android:textSize="11sp" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="Select variant"
                    android:src="@drawable/ic_chevron_down"
                    app:tint="@color/accent_dark" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCartPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:includeFontPadding="false"
                    android:text="450.000đ"
                    android:textColor="@color/button"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvCartOldPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/nunito_regular"
                    android:includeFontPadding="false"
                    android:text="560.000đ"
                    android:textColor="@color/border_divider"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvCartDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_cart_discount_badge"
                    android:fontFamily="@font/nunito_semibold"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:minWidth="34dp"
                    android:paddingHorizontal="7dp"
                    android:singleLine="true"
                    android:text="-20%"
                    android:textColor="@color/button"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="end"
            android:minWidth="88dp"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnCartWishlist"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Wishlist"
                android:padding="5dp"
                android:scaleType="centerInside"
                android:src="@drawable/selector_post_like"
                app:tint="@color/selector_post_action_tint"
                tools:ignore="TouchTargetSizeCheck" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical|end"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/layoutQuantityControl"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_quantity_control"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <ImageButton
                        android:id="@+id/btnDecreaseQuantity"
                        android:layout_width="22dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Decrease"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_minus"
                        app:tint="@color/selector_post_action_tint"
                        tools:ignore="TouchTargetSizeCheck" />

                    <TextView
                        android:id="@+id/tvCartQuantity"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:fontFamily="@font/nunito_medium"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/text_main"
                        android:textSize="12sp" />

                    <ImageButton
                        android:id="@+id/btnIncreaseQuantity"
                        android:layout_width="22dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Increase"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_plus"
                        app:tint="@color/selector_post_action_tint"
                        tools:ignore="TouchTargetSizeCheck" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
