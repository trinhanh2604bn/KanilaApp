<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCreatorBadge"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_community_card"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCreatorAvatar"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedProductImage"
            tools:src="@android:drawable/ic_menu_report_image" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCreatorName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito_bold"
                    android:text="Kim Trần"
                    android:textColor="@color/text_main"
                    android:textSize="20sp"
                    tools:text="Kim Trần" />

                <ImageView
                    android:id="@+id/ivCreatorVerified"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_verified"
                    app:tint="@color/button"
                    android:contentDescription="Verified" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="Beauty Creator"
                android:textColor="@color/border_divider"
                android:textSize="14sp"
                tools:text="Beauty Creator" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnCreatorMore"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"
            android:src="@drawable/ic_more_horiz"
            app:tint="@color/text_main" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutCreatorStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCreatorPostCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="268"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                tools:text="268" />

            <TextView
                android:id="@+id/tvCreatorPostLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="Bài viết"
                android:textColor="@color/border_divider"
                android:textSize="12sp"
                tools:text="Bài viết" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCreatorFollowerCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="48.4K"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                tools:text="48.4K" />

            <TextView
                android:id="@+id/tvCreatorFollowerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="Followers"
                android:textColor="@color/border_divider"
                android:textSize="12sp"
                tools:text="Followers" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCreatorFollowingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="127"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                tools:text="127" />

            <TextView
                android:id="@+id/tvCreatorFollowingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="Following"
                android:textColor="@color/border_divider"
                android:textSize="12sp"
                tools:text="Following" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreatorFollow"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@android:color/transparent"
        android:fontFamily="@font/nunito_bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Following"
        android:textColor="@color/button"
        android:textSize="14sp"
        app:backgroundTint="@android:color/transparent"
        app:cornerRadius="12dp"
        app:strokeColor="@color/button"
        app:strokeWidth="1dp"
        tools:text="Following" />

</LinearLayout>
