<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp">

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_avatar_circle"
        android:padding="7dp"
        android:src="@drawable/ic_chat_placeholder"
        app:tint="@color/accent_dark"
        android:contentDescription="Kanila AI" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvBotName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="AI Assistant"
            style="@style/Text.Kanila.Caption"
            android:textColor="@color/text_tertiary" />

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="280dp"
            android:background="@drawable/bg_bubble_bot"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:lineSpacingExtra="2dp"
            android:text="Chào bạn! Mình là Kanila AI Assistant. Mình có thể giúp gì cho bạn hôm nay?"
            style="@style/Text.Kanila.Body"
            android:textColor="@color/text_main" />

        <TextView
            android:id="@+id/tvPersonalizedBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip_pink"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/chat_personalized_badge"
            style="@style/Text.Kanila.Caption"
            android:textColor="@color/accent_dark"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPreferenceOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingHorizontal="0dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_chat_quick_reply"
            tools:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingHorizontal="4dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_chat_product_card"
            tools:visibility="visible" />

        <LinearLayout
            android:id="@+id/layoutUpsell"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Có thể bạn quan tâm:"
                style="@style/Text.Kanila.Caption"
                android:textColor="@color/text_secondary"
                android:fontFamily="@font/nunito_bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvUpsellProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:paddingHorizontal="4dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_chat_product_card" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layoutOrderCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible">
            <include layout="@layout/item_chat_order_card" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/layoutTicketCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible">
            <include layout="@layout/item_chat_ticket_card" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/layoutComparisonCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible">
            <include layout="@layout/item_chat_product_comparison" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/layoutCartSummaryContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible">
            <include layout="@layout/item_chat_cart_summary" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/layoutIngredientCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="visible">
            <include layout="@layout/item_chat_ingredient_analysis" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="09:41"
            style="@style/Text.Kanila.Micro"
            android:textColor="@color/text_tertiary" />
    </LinearLayout>
</LinearLayout>