<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sub">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_l"
        android:paddingVertical="@dimen/spacing_m"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:src="@drawable/ic_list"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_main" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/chat_assistant_title"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnHistory"
            app:layout_constraintStart_toEndOf="@id/btnMenu"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Lịch sử"
            android:src="@drawable/ic_clock"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_main" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomInput"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- Welcome Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_l"
                android:layout_marginTop="@dimen/spacing_m"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/radius_xl"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="0.5dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAvatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="2dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/wait_chatting" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvWelcomeTitle"
                        style="@style/Text.Kanila.H3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/chat_welcome_title"
                        android:textColor="@color/accent_dark"
                        android:textSize="18sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardAvatar"
                        app:layout_constraintTop_toTopOf="@id/cardAvatar" />

                    <TextView
                        android:id="@+id/tvWelcomeDesc"
                        style="@style/Text.Kanila.Body"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/chat_welcome_desc"
                        android:textColor="@color/text_main"
                        android:lineSpacingExtra="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/tvWelcomeTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvWelcomeTitle" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Suggestions Section -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_l"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/chat_suggestion_header"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_l">

                <!-- Oily Skin -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/suggestOilySkin"
                    style="@style/Widget.MaterialComponents.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_s"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/radius_l"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_divider"
                    app:strokeWidth="0.8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_drops"
                            app:tint="@color/accent_dark" />

                        <TextView
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/chat_suggest_oily"
                            android:textColor="@color/text_main" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Order Status -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/suggestOrderStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_s"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/radius_l"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_divider"
                    app:strokeWidth="0.8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_order_tracking"
                            app:tint="@color/accent_dark" />

                        <TextView
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/chat_suggest_order"
                            android:textColor="@color/text_main" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sensitive Skin -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/suggestSensitiveSkin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_s"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/radius_l"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_divider"
                    app:strokeWidth="0.8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_face"
                            app:tint="@color/accent_dark" />

                        <TextView
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/chat_suggest_sensitive"
                            android:textColor="@color/text_main" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Return Policy -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/suggestReturnPolicy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_xl"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="@dimen/radius_l"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/border_divider"
                    app:strokeWidth="0.8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_refresh"
                            app:tint="@color/accent_dark" />

                        <TextView
                            style="@style/Text.Kanila.BodyMedium"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:text="@string/chat_suggest_return"
                            android:textColor="@color/text_main" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_tertiary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Floating AI Status Badge -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginEnd="@dimen/spacing_s"
                    app:cardBackgroundColor="#FFF0F3"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeColor="#FFD1DC"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_chatbot" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">

                            <TextView
                                style="@style/Text.Kanila.Micro"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/chat_ai_status"
                                android:textColor="@color/accent_dark"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_circle"
                            android:backgroundTint="@color/success" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Input Bar Container -->
    <LinearLayout
        android:id="@+id/layoutBottomInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_sub"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_l"
        android:paddingTop="@dimen/spacing_m"
        android:paddingBottom="@dimen/spacing_xl"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/border_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp">

                    <EditText
                        android:id="@+id/edtMessage"
                        style="@style/Text.Kanila.Body"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/chat_input_hint"
                        android:imeOptions="actionSend"
                        android:inputType="textCapSentences"
                        android:textColor="@color/text_main"
                        android:textColorHint="@color/text_tertiary" />

                    <ImageView
                        android:id="@+id/btnVoice"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_mic"
                        app:tint="@color/text_tertiary" />

                    <ImageView
                        android:id="@+id/btnCamera"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="12dp"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/text_tertiary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSend"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                app:cardBackgroundColor="@color/button"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/ic_send"
                    app:tint="@color/white" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <TextView
            style="@style/Text.Kanila.Micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/chat_disclaimer"
            android:textColor="@color/text_tertiary"
            android:gravity="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>