<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/nunito_bold"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/share_post_title"
        android:textColor="@color/text_main"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:paddingHorizontal="16dp">

        <!-- Zalo -->
        <LinearLayout
            android:id="@+id/btnShareZalo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="8dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_zalo"
                android:padding="8dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="@color/background_sub"
                android:contentDescription="@string/share_zalo" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/nunito_regular"
                android:text="@string/share_zalo"
                android:textColor="@color/text_main"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Messenger -->
        <LinearLayout
            android:id="@+id/btnShareMessenger"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="8dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_send"
                android:padding="10dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="@color/background_sub"
                app:tint="#0084FF"
                android:contentDescription="@string/share_messenger" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/nunito_regular"
                android:text="@string/share_messenger"
                android:textColor="@color/text_main"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Instagram -->
        <LinearLayout
            android:id="@+id/btnShareInstagram"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="8dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_image"
                android:padding="10dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="@color/background_sub"
                app:tint="#E1306C"
                android:contentDescription="@string/share_instagram" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/nunito_regular"
                android:text="@string/share_instagram"
                android:textColor="@color/text_main"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Other -->
        <LinearLayout
            android:id="@+id/btnShareOther"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="8dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_share"
                android:padding="12dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="@color/background_sub"
                app:tint="@color/text_main"
                android:contentDescription="@string/share_other" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/nunito_regular"
                android:text="@string/share_other"
                android:textColor="@color/text_main"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="@color/border_divider"
        android:layout_marginHorizontal="16dp" />

    <LinearLayout
        android:id="@+id/btnCopyLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit"
            app:tint="@color/text_main"
            android:padding="2dp"
            android:contentDescription="@string/share_copy_link" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/nunito_semibold"
            android:text="@string/share_copy_link"
            android:textColor="@color/text_main"
            android:textSize="14sp" />
    </LinearLayout>

</LinearLayout>
