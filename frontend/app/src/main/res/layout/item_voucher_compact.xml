<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutVoucherCompactItem"
    android:layout_width="290dp"
    android:layout_height="120dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_voucher"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/layoutVoucherCompactLeft"
        android:layout_width="115dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvVoucherCompactDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:includeFontPadding="false"
            android:text="50K"
            android:textColor="@color/button"
            android:textSize="24sp"
            tools:text="50K" />

        <TextView
            android:id="@+id/tvVoucherCompactConditionLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito_semibold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="2"
            android:text="GIẢM NGAY"
            android:textColor="@color/text_main"
            android:textSize="9sp"
            tools:text="GIẢM NGAY" />
    </LinearLayout>

    <View
        android:id="@+id/viewVoucherCompactDivider"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@color/secondary" />

    <LinearLayout
        android:id="@+id/layoutVoucherCompactRight"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/tvVoucherCompactCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_bold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="KANILA50"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            tools:text="KANILA50" />

        <TextView
            android:id="@+id/tvVoucherCompactCondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_regular"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Đơn từ 499K"
            android:textColor="@color/text_main"
            android:textSize="10sp"
            tools:text="Đơn từ 499K" />

        <TextView
            android:id="@+id/tvVoucherCompactExpiredDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_regular"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="HSD: 30/07/2025"
            android:textColor="@color/text_main"
            android:textSize="10sp"
            tools:text="HSD: 30/07/2025" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVoucherCompactSave"
            android:layout_width="73dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="Lưu"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            app:backgroundTint="@color/button"
            app:cornerRadius="14dp"
            tools:ignore="TouchTargetSizeCheck" />
    </LinearLayout>

</LinearLayout>