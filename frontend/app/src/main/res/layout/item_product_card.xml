<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/border_divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Status Badge -->
        <LinearLayout
            android:id="@+id/layoutProductStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_product_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
           >

            <TextView
                android:id="@+id/tvProductBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="New"
                android:textColor="@color/accent_dark"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Wishlist Button -->
        <ImageButton
            android:id="@+id/btnWishlist"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Add to wishlist"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/selector_post_like"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/selector_post_action_tint" />

        <!-- CheckBox for selection mode -->
        <CheckBox
            android:id="@+id/cbSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Product Image -->
        <ImageView
            android:id="@+id/ivProductImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:scaleType="centerInside"
            android:contentDescription="@string/product_image_desc"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnWishlist"
            tools:src="@drawable/ic_product" />

        <!-- Brand Name -->
        <TextView
            android:id="@+id/tvProductBrand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/text_main"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivProductImage"
            tools:text="BeautyBlender" />

        <!-- Product Name -->
        <TextView
            android:id="@+id/tvProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_regular"
            android:maxLines="2"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProductBrand"
            tools:text="Phấn phủ BOUNCE Soft Focus" />

        <!-- Category (Chat context) -->
        <TextView
            android:id="@+id/tvProductCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_regular"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProductName"
            tools:text="Chăm sóc da mặt" />

        <!-- Rating Section -->
        <LinearLayout
            android:id="@+id/layoutRating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProductCategory">

            <RatingBar
                android:id="@+id/tvProductRating"
                style="?android:attr/ratingBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:progressTint="@color/button"
                android:rating="4.5"
                android:isIndicator="true"/>

            <TextView
                android:id="@+id/tvProductReviewCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                tools:text="(1.2k)" />
        </LinearLayout>

        <!-- Price Section -->
        <LinearLayout
            android:id="@+id/layoutProductPriceContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="bottom"
            android:orientation="horizontal"
            app:layout_constraintEnd_toStartOf="@id/btnAddToCart"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutRating">

            <TextView
                android:id="@+id/tvProductPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/button"
                android:textSize="14sp"
                tools:text="450.000đ" />

            <TextView
                android:id="@+id/tvProductOriginalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:alpha="0.6"
                android:visibility="gone"
                tools:text="600.000đ" />
        </LinearLayout>

        <!-- Add to Cart Button (Default) -->
        <ImageButton
            android:id="@+id/btnAddToCart"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_circle_primary"
            android:contentDescription="Add to cart"
            android:src="@drawable/ic_plus"
            android:padding="6dp"
            app:layout_constraintBottom_toBottomOf="@id/layoutProductPriceContainer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/layoutProductPriceContainer"
            tools:ignore="TouchTargetSizeCheck"
            app:tint="#FFFFFF" />

        <!-- Matched Reason (Chat context) -->
        <TextView
            android:id="@+id/tvMatchedReason"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_recommendation_highlight"
            android:fontFamily="@font/nunito_regular"
            android:padding="8dp"
            android:textColor="@color/text_main"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutProductPriceContainer"
            tools:text="Phù hợp vì bạn cần son đi học dưới 300k, màu tự nhiên" />

        <!-- Chat Actions (Chat context) -->
        <LinearLayout
            android:id="@+id/layoutChatActions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMatchedReason">

            <!-- Primary actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChatViewDetail"
                    style="@style/Widget.Kanila.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="@string/chat_view_product"
                    android:textSize="11sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnChatAddToCart"
                    style="@style/Widget.Kanila.Button.Secondary"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="@string/chat_add_to_cart"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Why recommend button – only shown when reason exists -->
            <TextView
                android:id="@+id/btnWhyRecommend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:drawablePadding="4dp"
                android:fontFamily="@font/nunito_bold"
                android:text="💡 Tại sao được gợi ý?"
                android:textColor="@color/button"
                android:textSize="12sp"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp" />
        </LinearLayout>

        <!-- Find Similar Action -->
        <TextView
            android:id="@+id/tvFindSimilar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/nunito_bold"
            android:text="@string/action_find_similar"
            android:textColor="@color/button"
            android:textSize="12sp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutProductPriceContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
