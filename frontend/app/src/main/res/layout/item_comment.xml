<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCommentItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_community_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="10dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivCommentAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="10dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/RoundedProductImage"
        tools:src="@android:drawable/ic_menu_report_image" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCommentUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_semibold"
                android:text="Kim Trần"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                tools:text="Kim Trần" />

            <TextView
                android:id="@+id/tvCommentAuthorBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_community_chip"
                android:fontFamily="@font/nunito_semibold"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                android:text="Tác giả"
                android:textColor="@color/button"
                android:textSize="10sp"
                tools:text="Tác giả" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCommentContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_regular"
            android:maxLines="2"
            android:text="Mình dùng em này thấy da căng mịn hẳn luôn!"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            tools:text="Mình dùng em này thấy da căng mịn hẳn luôn!" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCommentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="2 giờ trước"
                android:textColor="@color/border_divider"
                android:textSize="11sp"
                tools:text="2 giờ trước" />

            <TextView
                android:id="@+id/tvCommentReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/nunito_semibold"
                android:text="Trả lời"
                android:textColor="@color/border_divider"
                android:textSize="11sp"
                tools:text="Trả lời" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <ImageButton
            android:id="@+id/btnCommentLike"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Like comment"
            android:src="@drawable/ic_heart_outline"
            tools:ignore="TouchTargetSizeCheck"
            app:tint="@color/button" />

        <TextView
            android:id="@+id/tvCommentLikeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_regular"
            android:text="54"
            android:textColor="@color/text_main"
            android:textSize="11sp"
            tools:text="54" />
    </LinearLayout>

</LinearLayout>
