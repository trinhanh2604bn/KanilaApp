<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutCategoryVisualCard"
    android:layout_width="match_parent"
    android:layout_height="@dimen/category_card_grid_height"
    android:background="@drawable/bg_category_visual_card"
    android:clickable="true"
    android:focusable="true"
    android:orientation="horizontal"
    android:padding="@dimen/spacing_s">

    <!-- Top Row: Icon and Product Image -->

    <!-- Bottom Row: Category Name -->
    <LinearLayout
        android:layout_width="295dp"
        android:layout_height="71dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivCategoryIcon"
            android:layout_width="@dimen/category_grid_icon_size"
            android:layout_height="@dimen/category_grid_icon_size"
            android:contentDescription="@string/content_desc_category_icon"
            android:scaleType="centerInside"
            app:tint="@color/button"
            tools:src="@drawable/ic_face" />


        <TextView
            android:id="@+id/tvCategoryName"
            style="@style/Text.Kanila.Micro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/text_main"
            android:textSize="10sp"
            tools:text="Face" />


    </LinearLayout>


    <ImageView
        android:id="@+id/ivCategoryProductImage"
        android:layout_width="50dp"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:contentDescription="@string/content_desc_category_product_image"
        android:scaleType="centerInside"
        tools:src="@drawable/img_foudation" />

</LinearLayout>
