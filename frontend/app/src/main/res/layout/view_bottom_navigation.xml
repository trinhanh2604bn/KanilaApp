<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutBottomNavigation"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="@drawable/bg_bottom_navigation"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Trang chủ -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:contentDescription="Mở Trang chủ">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/bgHome"
                    android:layout_width="48dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item_selected"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_home"
                    app:tint="@color/text_main" />

                <TextView
                    android:id="@+id/badgeHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="16dp"
                    android:minHeight="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_bottom_nav_badge"
                    android:gravity="center"
                    android:padding="1dp"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvHome"
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Trang chủ"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <!-- Danh mục -->
        <LinearLayout
            android:id="@+id/navCategory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:contentDescription="Mở Danh mục">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/bgCategory"
                    android:layout_width="48dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item_selected"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivCategory"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_category"
                    app:tint="@color/text_main" />

                <TextView
                    android:id="@+id/badgeCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="16dp"
                    android:minHeight="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_bottom_nav_badge"
                    android:gravity="center"
                    android:padding="1dp"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvCategory"
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Danh mục"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <!-- Reels -->
        <LinearLayout
            android:id="@+id/navReels"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:contentDescription="Mở Reels">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/bgReels"
                    android:layout_width="54dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item_selected"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivReels"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_reels"
                    app:tint="@color/text_main" />

                <TextView
                    android:id="@+id/badgeReels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="16dp"
                    android:minHeight="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_bottom_nav_badge"
                    android:gravity="center"
                    android:padding="1dp"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvReels"
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Reels"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <!-- Community -->
        <LinearLayout
            android:id="@+id/navCommunity"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:contentDescription="Mở Community">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/bgCommunity"
                    android:layout_width="48dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item_selected"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivCommunity"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_community"
                    app:tint="@color/text_main" />

                <TextView
                    android:id="@+id/badgeCommunity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="16dp"
                    android:minHeight="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_bottom_nav_badge"
                    android:gravity="center"
                    android:padding="1dp"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvCommunity"
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Community"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <!-- Tài khoản -->
        <LinearLayout
            android:id="@+id/navAccount"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:contentDescription="Mở Tài khoản">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <View
                    android:id="@+id/bgAccount"
                    android:layout_width="48dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_bottom_nav_item_selected"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivAccount"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_account"
                    app:tint="@color/text_main" />

                <TextView
                    android:id="@+id/badgeAccount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="16dp"
                    android:minHeight="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_bottom_nav_badge"
                    android:gravity="center"
                    android:padding="1dp"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvAccount"
                style="@style/Text.Kanila.Micro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Tài khoản"
                android:textColor="@color/text_main" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
