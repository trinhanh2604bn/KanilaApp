<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_soft">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_ticket_placeholder"
                app:tint="@color/button"
                android:contentDescription="Ticket" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="#TK2505123456"
            android:textAppearance="@style/Body"
            android:textColor="@color/text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_pill"
            android:backgroundTint="@color/status_success_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="Đang xử lý"
            android:textAppearance="@style/Caption"
            android:textColor="@color/success" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Vấn đề: Sản phẩm bị thiếu trong đơn hàng"
        android:textAppearance="@style/Body"
        android:textColor="@color/text_secondary" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/border_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cập nhật gần nhất: 12/05/2025 16:45"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_tertiary" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/text_tertiary"
            android:contentDescription="Xem chi tiết" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_avatar_circle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Nhân viên: Linh Chi"
            android:textAppearance="@style/Caption"
            android:textColor="@color/text_secondary" />
    </LinearLayout>
</LinearLayout>