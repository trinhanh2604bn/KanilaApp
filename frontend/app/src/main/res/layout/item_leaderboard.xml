<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutLeaderboardItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_community_card"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/layoutLeaderboardTabs"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/tabLeaderboardWeek"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvTabWeek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_bold"
                android:text="Tuần này"
                android:textColor="@color/button"
                android:textSize="13sp"
                tools:text="Tuần này" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabLeaderboardMonth"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvTabMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="Tháng này"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                tools:text="Tháng này" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabLeaderboardAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvTabAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/nunito_regular"
                android:text="Tất cả"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                tools:text="Tất cả" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="@color/background_sub" />

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/rowLeaderboard1"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvRankNumber1"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/button"
            android:textSize="18sp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivLeaderboardAvatar1"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedProductImage"
            tools:src="@android:drawable/ic_menu_report_image" />

        <TextView
            android:id="@+id/tvLeaderboardName1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/nunito_semibold"
            android:text="Nguyễn Mai Anh"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            tools:text="Nguyễn Mai Anh" />

        <TextView
            android:id="@+id/tvLeaderboardPoint1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="2.460 điểm"
            android:textColor="@color/button"
            android:textSize="13sp"
            tools:text="2.460 điểm" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/rowLeaderboard2"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvRankNumber2"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/text_main"
            android:textSize="16sp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivLeaderboardAvatar2"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedProductImage"
            tools:src="@android:drawable/ic_menu_report_image" />

        <TextView
            android:id="@+id/tvLeaderboardName2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/nunito_semibold"
            android:text="Linh Chi"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            tools:text="Linh Chi" />

        <TextView
            android:id="@+id/tvLeaderboardPoint2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="1.980 điểm"
            android:textColor="@color/button"
            android:textSize="13sp"
            tools:text="1.980 điểm" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/rowLeaderboard3"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvRankNumber3"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/text_main"
            android:textSize="16sp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivLeaderboardAvatar3"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedProductImage"
            tools:src="@android:drawable/ic_menu_report_image" />

        <TextView
            android:id="@+id/tvLeaderboardName3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="@font/nunito_semibold"
            android:text="Phương Thảo"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            tools:text="Phương Thảo" />

        <TextView
            android:id="@+id/tvLeaderboardPoint3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:text="1.520 điểm"
            android:textColor="@color/button"
            android:textSize="13sp"
            tools:text="1.520 điểm" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/nunito_bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Xem bảng xếp hạng"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:backgroundTint="@color/button"
        app:cornerRadius="14dp"
        tools:text="Xem bảng xếp hạng" />

</LinearLayout>
