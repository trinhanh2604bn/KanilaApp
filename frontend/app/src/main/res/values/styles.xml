<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Typography -->
    <style name="Text.Kanila.H1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="lineHeight">32dp</item>
    </style>

    <style name="Text.Kanila.H2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="lineHeight">28dp</item>
    </style>

    <style name="Text.Kanila.H3" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="lineHeight">24dp</item>
    </style>

    <style name="Text.Kanila.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/nunito_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="lineHeight">22dp</item>
    </style>

    <style name="Text.Kanila.BodyMedium" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/nunito_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="lineHeight">22dp</item>
    </style>

    <style name="Text.Kanila.Caption" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/nunito_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="lineHeight">18dp</item>
    </style>

    <style name="Text.Kanila.Micro" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/nunito_medium</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="lineHeight">14dp</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.Kanila.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="backgroundTint">@color/button</item>
        <item name="android:textColor">@color/background_main</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Kanila.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/radius_xl</item>
        <item name="strokeColor">@color/button</item>
        <item name="android:textColor">@color/button</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Kanila.Button.Ghost" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/accent_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Compact pill-shaped button -->

    <!-- ================================================= -->
    <!-- BEAUTY PROFILE - GRID SELECTION COMPONENTS        -->
    <!-- ================================================= -->

    <style name="Widget.Kanila.Button.Pill" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/chip_height</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">@dimen/radius_pill</item>
        <item name="backgroundTint">@color/button</item>
        <item name="android:textColor">@color/background_main</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/nunito_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">@dimen/spacing_l</item>
        <item name="android:paddingRight">@dimen/spacing_l</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="iconPadding">6dp</item>
    </style>

    <style name="Widget.Kanila.Button.Icon" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">@dimen/touch_target_min</item>
        <item name="android:layout_height">@dimen/touch_target_min</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="iconSize">@dimen/icon_size</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">@color/text_main</item>
    </style>

    <!-- Grid Selection Items -->
    <style name="GridItemCard" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">100dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#F0F0F0</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/background_main</item>
    </style>

    <style name="GridItemCard.Selected">
        <item name="cardBackgroundColor">@color/icon_bg_pink</item>
        <item name="strokeColor">@color/button</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="GridItemFrame">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="GridItemContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="GridItemIcon">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="tint">@color/text_main</item>
    </style>

    <style name="GridItemLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
    </style>

    <style name="MetricCard" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:layout_weight">1</item>

        <item name="cardBackgroundColor">@color/background_main</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="MetricIcon">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:background">@drawable/bg_circle</item>
        <item name="android:padding">6dp</item>
    </style>

    <style name="MetricLabel" parent="Text.Kanila.Caption">
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MetricValue" parent="Text.Kanila.H3">
        <item name="android:textSize">18sp</item>
    </style>


    <style name="GridItemTick">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:layout_gravity">top|end</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/bg_circle_pink</item>
        <item name="android:backgroundTint">@color/button</item>
        <item name="android:padding">3dp</item>
        <item name="android:src">@drawable/ic_tick</item>
        <item name="tint">@android:color/white</item>
    </style>



    <!-- ================================================= -->
    <!-- SUITABLE INGREDIENTS COMPONENTS                   -->
    <!-- ================================================= -->

    <!-- Hai thẻ Thiết lập nhanh: Ưu tiên / Cần tránh -->
    <style
        name="QuickSetupCard"
        parent="Widget.MaterialComponents.CardView">

        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">124dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>

        <item name="cardBackgroundColor">@color/background_main</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_divider</item>
        <item name="strokeWidth">1dp</item>

    </style>

    <!-- Chip thành phần ở trạng thái mặc định -->
    <style
        name="IngredientChip"
        parent="Widget.MaterialComponents.CardView">

        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_gravity">fill_horizontal</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>

        <item name="cardBackgroundColor">@color/background_main</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Chip thành phần đang được chọn -->
    <style
        name="IngredientChip.Selected"
        parent="IngredientChip">

        <item name="cardBackgroundColor">@color/background_sub</item>
        <item name="strokeColor">@color/button</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Tên thành phần mặc định -->
    <style
        name="IngredientChipLabel"
        parent="Text.Kanila.Micro">
        <item name="android:textColor">@color/text_main</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
    </style>

    <!-- Tên thành phần đang được chọn -->
    <style
        name="IngredientChipLabel.Selected"
        parent="IngredientChipLabel">

        <item name="android:textColor">@color/button</item>
    </style>

    <style name="MetricFooter"
        parent="Text.Kanila.Micro">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:alpha">0.6</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="CustomBottomSheetDialog" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/CustomBottomSheetShapeAppearance</item>
    </style>

    <style name="CustomBottomSheetShapeAppearance" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/radius_l</item>
        <item name="cornerSizeTopRight">@dimen/radius_l</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>
