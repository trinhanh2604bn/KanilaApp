<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="150dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_m"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="@dimen/radius_m"
    app:cardElevation="1dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="110dp"
            app:cardCornerRadius="@dimen/radius_m"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/bg_soft">

            <ImageView
                android:id="@+id/ivRewardImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/icon_gift"
                android:contentDescription="@null" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvRewardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_s"
            android:fontFamily="@font/nunito_bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="@color/text_main"
            android:textSize="12sp"
            tools:text="Voucher 50K" />

        <TextView
            android:id="@+id/tvRewardPoints"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:fontFamily="@font/nunito_semibold"
            android:textColor="@color/button"
            android:textSize="11sp"
            tools:text="500 điểm" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
