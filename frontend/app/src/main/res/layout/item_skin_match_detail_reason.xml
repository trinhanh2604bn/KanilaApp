<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:orientation="horizontal"
    android:padding="4dp">

    <ImageView
        android:id="@+id/ivReasonIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="2dp"
        android:contentDescription="@string/skin_match_reason"
        android:src="@drawable/ic_check_circle"
        app:tint="@color/success" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvReasonText"
            style="@style/Text.Kanila.BodyMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_main"
            tools:text="Cấp ẩm chuyên sâu cho da khô" />

        <TextView
            android:id="@+id/tvReasonDetail"
            style="@style/Text.Kanila.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            tools:text="Thành phần Hyaluronic Acid trong sản phẩm giúp giữ nước cho làn da khô, cải thiện tình trạng bong tróc và thô ráp."
            tools:visibility="visible" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvReasonContribution"
        style="@style/Text.Kanila.Micro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_chip_soft_pink"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@color/button"
        android:visibility="gone"
        tools:text="+15%"
        tools:visibility="visible" />

</LinearLayout>
