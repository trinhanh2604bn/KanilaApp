<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />

        <TextView
            android:id="@+id/tvTitleMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:text="@string/support_history_title"
            style="@style/Text.Kanila.H2"
            android:textColor="@color/accent_dark"
            android:textStyle="bold"
            android:gravity="center"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnSupportIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_comment"
            android:contentDescription="@string/chat_now"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="@color/button"
        app:tabSelectedTextColor="@color/button"
        app:tabTextColor="@color/text_main"
        app:tabIndicatorHeight="2dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextAppearance="@style/Text.Kanila.BodyMedium">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đang mở (2)" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đã hoàn tất (8)" />
    </com.google.android.material.tabs.TabLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:background="@color/background_sub">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Item 1 -->
            <include
                android:id="@+id/itemTicket1"
                layout="@layout/item_support_ticket" />

            <!-- Item 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemTicket2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivIcon2"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="#F5F5F5"
                        android:padding="10dp"
                        android:src="@drawable/ic_shopping_bag"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:tint="@color/text_main" />
                    <TextView
                        android:id="@+id/tvTitle2"
                        style="@style/Text.Kanila.BodyMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/ticket_sample_title_2"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/tvStatus2"
                        app:layout_constraintStart_toEndOf="@id/ivIcon2"
                        app:layout_constraintTop_toTopOf="@id/ivIcon2" />
                    <TextView
                        android:id="@+id/tvDetails2"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.6"
                        android:text="#SR24060012 - Đơn #KB24052611"
                        app:layout_constraintEnd_toEndOf="@id/tvTitle2"
                        app:layout_constraintStart_toStartOf="@id/tvTitle2"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle2" />
                    <TextView
                        android:id="@+id/tvTime2"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:alpha="0.8"
                        android:text="Cập nhật: 5 giờ trước"
                        app:layout_constraintEnd_toEndOf="@id/tvDetails2"
                        app:layout_constraintStart_toStartOf="@id/tvDetails2"
                        app:layout_constraintTop_toBottomOf="@id/tvDetails2" />
                    <TextView
                        android:id="@+id/tvStatus2"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_pink"
                        android:backgroundTint="@color/status_exchange_bg"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="@string/status_waiting_reply"
                        android:textColor="@color/status_exchange_text"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvTitle2" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="@string/view_all"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:tint="@color/border_divider" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 3 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivIcon3"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@color/icon_bg_pink"
                        android:padding="10dp"
                        android:src="@drawable/ic_comment"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:tint="@color/button" />
                    <TextView
                        android:id="@+id/tvTitle3"
                        style="@style/Text.Kanila.BodyMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/ticket_sample_title_3"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/tvStatus3"
                        app:layout_constraintStart_toEndOf="@id/ivIcon3"
                        app:layout_constraintTop_toTopOf="@id/ivIcon3" />
                    <TextView
                        android:id="@+id/tvDetails3"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.6"
                        android:text="#SR24059980"
                        app:layout_constraintEnd_toEndOf="@id/tvTitle3"
                        app:layout_constraintStart_toStartOf="@id/tvTitle3"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle3" />
                    <TextView
                        android:id="@+id/tvTime3"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:alpha="0.8"
                        android:text="Cập nhật: 1 ngày trước"
                        app:layout_constraintEnd_toEndOf="@id/tvDetails3"
                        app:layout_constraintStart_toStartOf="@id/tvDetails3"
                        app:layout_constraintTop_toBottomOf="@id/tvDetails3" />
                    <TextView
                        android:id="@+id/tvStatus3"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_pink"
                        android:backgroundTint="@color/status_success_bg"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="@string/status_finished"
                        android:textColor="@color/status_success_text"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvTitle3" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="@string/view_all"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:tint="@color/border_divider" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 4 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F5F5F5"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivIcon4"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="#F5F5F5"
                        android:padding="10dp"
                        android:src="@drawable/ic_paymeny_card"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:tint="@color/text_main" />
                    <TextView
                        android:id="@+id/tvTitle4"
                        style="@style/Text.Kanila.BodyMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/ticket_sample_title_4"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/tvStatus4"
                        app:layout_constraintStart_toEndOf="@id/ivIcon4"
                        app:layout_constraintTop_toTopOf="@id/ivIcon4" />
                    <TextView
                        android:id="@+id/tvDetails4"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.6"
                        android:text="@string/ticket_sample_id_4"
                        app:layout_constraintEnd_toEndOf="@id/tvTitle4"
                        app:layout_constraintStart_toStartOf="@id/tvTitle4"
                        app:layout_constraintTop_toBottomOf="@id/tvTitle4" />
                    <TextView
                        android:id="@+id/tvTime4"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:alpha="0.8"
                        android:text="@string/ticket_sample_time_4"
                        app:layout_constraintEnd_toEndOf="@id/tvDetails4"
                        app:layout_constraintStart_toStartOf="@id/tvDetails4"
                        app:layout_constraintTop_toBottomOf="@id/tvDetails4" />
                    <TextView
                        android:id="@+id/tvStatus4"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_pink"
                        android:backgroundTint="@color/status_success_bg"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="@string/status_finished"
                        android:textColor="@color/status_success_text"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvTitle4" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right"
                        android:contentDescription="@string/view_all"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:tint="@color/border_divider" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rating Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/background_main"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rate_support_title"
                        style="@style/Text.Kanila.H3"
                        android:textColor="@color/accent_dark" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/rate_support_subtitle"
                        style="@style/Text.Kanila.Caption"
                        android:alpha="0.6" />

                    <!-- Star Bar -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" android:contentDescription="1 Star" />
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" android:contentDescription="2 Stars" />
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" android:contentDescription="3 Stars" />
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" android:contentDescription="4 Stars" />
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_star" app:tint="@color/button" android:layout_marginHorizontal="4dp" android:contentDescription="5 Stars" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/rate_excellent"
                        style="@style/Text.Kanila.Micro"
                        android:textColor="@color/button"
                        android:textStyle="bold" />

                    <!-- Quick Chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_chip_pink"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="@string/chip_fast_response"
                            style="@style/Text.Kanila.Micro"
                            android:textColor="@color/button"
                            app:drawableEndCompat="@drawable/ic_tick"
                            app:drawableTint="@color/button"
                            android:drawablePadding="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_chip_pink"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="@string/chip_friendly"
                            style="@style/Text.Kanila.Micro"
                            android:textColor="@color/button"
                            app:drawableEndCompat="@drawable/ic_tick"
                            app:drawableTint="@color/button"
                            android:drawablePadding="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_chip_pink"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="@string/chip_good_resolution"
                            style="@style/Text.Kanila.Micro"
                            android:textColor="@color/button"
                            app:drawableEndCompat="@drawable/ic_tick"
                            app:drawableTint="@color/button"
                            android:drawablePadding="4dp" />
                    </LinearLayout>

                    <!-- Comment Input -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/share_more_label"
                        style="@style/Text.Kanila.Micro"
                        android:alpha="0.6" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_kanila_input_default"
                        android:gravity="top"
                        android:minLines="3"
                        android:padding="12dp"
                        android:text="@string/sample_rating_comment"
                        style="@style/Text.Kanila.Caption"
                        android:textColor="@color/text_main"
                        android:importantForAutofill="no"
                        android:inputType="textMultiLine" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        style="@style/Widget.Kanila.Button.Primary"
                        android:text="@string/btn_submit_rating"
                        android:backgroundTint="@color/accent_dark" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
