<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layoutVoucherItem"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_voucher"
    android:gravity="center_vertical"
    android:minHeight="96dp"
    android:orientation="horizontal">

    <!-- Left Section -->
    <LinearLayout
        android:id="@+id/layoutVoucherLeft"
        android:layout_width="174dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/tvVoucherDiscountPercent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="10%"
            android:textColor="@color/button"
            android:textSize="24sp"
            tools:text="10%" />

        <TextView
            android:id="@+id/tvVoucherDiscountLimit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito_semibold"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="1dp"
            android:maxLines="2"
            android:text="GIẢM TỐI ĐA\n100.000đ"
            android:textColor="@color/text_main"
            android:textSize="10sp"
            tools:text="GIẢM TỐI ĐA\n100.000đ" />
    </LinearLayout>

    <!-- Vertical Divider -->
    <View
        android:id="@+id/viewVoucherDivider"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@color/secondary" />

    <!-- Right Section -->
    <LinearLayout
        android:id="@+id/layoutVoucherRight"
        android:layout_width="198dp"
        android:layout_height="129dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvVoucherCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito_bold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="KANILA10"
            android:textColor="@color/text_main"
            android:textSize="14sp"
            tools:text="KANILA10" />

        <TextView
            android:id="@+id/tvVoucherCondition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/nunito_regular"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Đơn tối thiểu 500.000đ"
            android:textColor="@color/text_main"
            android:textSize="11sp"
            tools:text="Đơn tối thiểu 500.000đ" />

        <TextView
            android:id="@+id/tvVoucherExpiredDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="@font/nunito_regular"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="HSD: 25/05/2025"
            android:textColor="@color/text_main"
            android:textSize="11sp"
            tools:text="HSD: 25/05/2025" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCopyVoucher"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/nunito_bold"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="Sao chép"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            app:backgroundTint="@color/button"
            app:cornerRadius="18dp"
            tools:ignore="TouchTargetSizeCheck"
            tools:text="Sao chép" />
    </LinearLayout>

</LinearLayout>
