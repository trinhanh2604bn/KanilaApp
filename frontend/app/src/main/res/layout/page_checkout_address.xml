<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header -->
    <include
        android:id="@+id/layoutTopBar"
        layout="@layout/view_app_top_bar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvAddressListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_l"
            android:layout_marginTop="@dimen/spacing_m"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Danh sách địa chỉ" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCheckoutAddressList"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_s"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_xxl"
            app:layout_constraintBottom_toTopOf="@+id/btnAddNewAddress"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvAddressListTitle"
            tools:listitem="@layout/item_checkout_address" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddNewAddress"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_l"
            android:paddingHorizontal="@dimen/spacing_xl"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Thêm địa chỉ mới" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>
