<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingTop="@dimen/spacing_s">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_drag_handle" />

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_l"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/tvBottomSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@id/btnVariantClose"
            android:layout_centerVertical="true"
            android:text="@string/variant_title"
            android:fontFamily="@font/nunito_bold"
            android:textColor="@color/accent_dark"
            android:textSize="20sp"
            android:ellipsize="end"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnVariantClose"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_close"
            android:src="@drawable/ic_close"
            app:tint="@color/text_secondary" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="6dp">

            <!-- Product Summary Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_l"
                android:paddingVertical="@dimen/spacing_s">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivVariantProductImage"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/RoundedProductImage"
                    tools:src="@drawable/ic_product" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_m"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvVariantBrand"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_dark"
                        android:fontFamily="@font/nunito_bold"
                        android:textSize="12sp"
                        tools:text="Kanila Beauty" />

                    <TextView
                        android:id="@+id/tvVariantProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textAppearance="@style/Text.Kanila.BodyMedium"
                        android:textColor="@color/text_main"
                        tools:text="Son Tint Lì Kanila Silky Matte" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvVariantCurrentPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/Text.Kanila.H3"
                            android:textColor="@color/button"
                            tools:text="189.000đ" />

                        <TextView
                            android:id="@+id/tvVariantOriginalPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_s"
                            android:includeFontPadding="false"
                            android:textAppearance="@style/Text.Kanila.Caption"
                            android:textColor="@color/text_tertiary"
                            android:visibility="gone"
                            tools:text="250.000đ"
                            tools:visibility="visible" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvVariantStock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:textAppearance="@style/Text.Kanila.Caption"
                        android:textColor="@color/text_secondary"
                        tools:text="Còn 137 sản phẩm" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:dividerColor="@color/border_divider" />

            <!-- Section: Màu son / Options -->
            <TextView
                android:id="@+id/tvColorOptionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_l"
                android:paddingTop="@dimen/spacing_m"
                android:text="@string/variant_color_title"
                android:fontFamily="@font/nunito_bold"
                android:textSize="16sp"
                android:textColor="@color/accent_dark"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutColorOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="@dimen/spacing_l"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Section: Dung tích / Options -->
            <TextView
                android:id="@+id/tvSizeOptionsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_l"
                android:paddingTop="@dimen/spacing_m"
                android:text="@string/variant_size_title"
                android:fontFamily="@font/nunito_bold"
                android:textSize="16sp"
                android:textColor="@color/accent_dark"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutSizeOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="@dimen/spacing_l"
                android:visibility="gone"
                tools:visibility="visible" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_m"
                app:dividerColor="@color/border_divider" />

            <!-- Quantity Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_l"
                android:paddingVertical="@dimen/spacing_m">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/variant_quantity_title"
                    android:fontFamily="@font/nunito_bold"
                    android:textSize="16sp"
                    android:textColor="@color/accent_dark" />

                <LinearLayout
                    android:id="@+id/layoutVariantQuantity"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_quantity_control"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_xs">

                    <ImageButton
                        android:id="@+id/btnVariantDecrease"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_decrease"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_minus"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvVariantQuantity"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_bold"
                        android:gravity="center"
                        android:text="@string/default_quantity"
                        android:textColor="@color/button"
                        android:textSize="16sp"
                        tools:text="1" />

                    <ImageButton
                        android:id="@+id/btnVariantIncrease"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/content_desc_increase"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_plus"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Apply Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_main"
        android:paddingHorizontal="@dimen/spacing_l"
        android:paddingVertical="@dimen/spacing_m">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVariantApply"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/variant_apply"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>
