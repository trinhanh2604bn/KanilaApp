<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:parentTag="android.widget.LinearLayout"
    tools:orientation="vertical">

    <TextView
        android:id="@+id/tvLabel"
        style="@style/Text.Kanila.BodyMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/label_input_spacing"
        android:visibility="gone"
        tools:text="Label"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/containerInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_kanila_input_default"
        android:gravity="center_vertical"
        android:minHeight="@dimen/input_height"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_l">

        <ImageView
            android:id="@+id/ivLeadingIcon"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:layout_marginEnd="@dimen/spacing_s"
            android:visibility="gone"
            app:tint="@color/text_main"
            tools:src="@drawable/ic_search"
            tools:visibility="visible" />

        <EditText
            android:id="@+id/etInput"
            style="@style/Text.Kanila.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="@string/hint_generic_input"
            android:minHeight="@dimen/touch_target_min"
            android:paddingVertical="@dimen/spacing_m"
            android:textColorHint="@color/border_divider" />

        <ImageView
            android:id="@+id/ivTrailingIcon"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:padding="@dimen/spacing_s"
            android:scaleType="centerInside"
            android:visibility="gone"
            tools:src="@drawable/ic_eye"
            tools:visibility="visible" />

        <Button
            android:id="@+id/btnAction"
            style="@style/Widget.Kanila.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_height_small"
            android:layout_marginStart="@dimen/spacing_s"
            android:minWidth="60dp"
            android:paddingHorizontal="@dimen/spacing_m"
            android:visibility="gone"
            tools:text="Apply"
            tools:visibility="visible" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/containerMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/ivMessageIcon"
            android:layout_width="@dimen/icon_size_small"
            android:layout_height="@dimen/icon_size_small"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:visibility="gone"
            tools:src="@drawable/ic_error_outline"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvMessage"
            style="@style/Text.Kanila.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Error message"
            tools:textColor="@color/error" />

    </LinearLayout>

</merge>