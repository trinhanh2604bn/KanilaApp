<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerEditProfile"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/background_main"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/secondary"
            app:strokeColor="@color/border_divider"
            app:strokeWidth="1dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/content_desc_back"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/accent_dark" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Chỉnh sửa hồ sơ làn da"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Loại da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardSkinOily" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardSkinDry" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardSkinCombination" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreSkinType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardSkinNormal" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardSkinSensitive" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardSkinUnknown" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreSkinType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 2: Tình trạng da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tình trạng da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardConditionAcne" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardConditionDarkSpots" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardConditionMelasma" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreCondition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardConditionDullness" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardConditionLargePores" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardConditionBlackheads" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardConditionRedness" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardConditionDehydrated" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardConditionWrinkles" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardConditionUneven" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardConditionDamaged" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardConditionSun" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 3: Mức độ nhạy cảm -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Mức độ nhạy cảm"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardSensitivityLow" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardSensitivityMedium" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardSensitivityHigh" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardSensitivityReactive" layout="@layout/item_edit_grid_selection" />
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreSensitivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 4: Màu da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Màu da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardColorFair" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardColorLight" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardColorMedium" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardColorTan" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardColorDeep" layout="@layout/item_edit_grid_selection" />
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 5: Sắc độ da -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Sắc độ da"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardUndertoneCool" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardUndertoneWarm" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardUndertoneNeutral" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreUndertone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardUndertoneOlive" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardUndertoneUnknown" layout="@layout/item_edit_grid_selection" />
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreUndertone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 6: Hiệu ứng nền -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Hiệu ứng nền mong muốn"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardFinishNatural" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardFinishBright" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardFinishWarm" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreFinish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardFinishPinkish" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardFinishMatte" layout="@layout/item_edit_grid_selection" />
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreFinish"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 7: Màu son -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Màu son yêu thích"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardLipstickNude" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardLipstickPink" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardLipstickCoral" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreLipstick"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardLipstickRed" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardLipstickBrown" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardLipstickMlbb" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardLipstickBold" layout="@layout/item_edit_grid_selection" />
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreLipstick"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 8: Phong cách trang điểm -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Phong cách trang điểm"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardMakeupNatural" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardMakeupKorean" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardMakeupGlam" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreMakeup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardMakeupOffice" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardMakeupParty" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardMakeupDaily" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreMakeup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <!-- Section 9: Ngân sách -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ngân sách ưu tiên"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardBudgetUnder300" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardBudget300_500" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardBudgetOver500" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <!-- Section 10: Thành phần cần tránh -->
            <TextView
                style="@style/Text.Kanila.H3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Thành phần cần tránh"
                android:textColor="@color/accent_dark"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <include android:id="@+id/cardAvoidFragrance" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardAvoidAlcohol" layout="@layout/item_edit_grid_selection" />
                <include android:id="@+id/cardAvoidEssentialOil" layout="@layout/item_edit_grid_selection" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMoreAvoid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardAvoidParaben" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardAvoidMineralOil" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardAvoidSilicone" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardAvoidSulfate" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardAvoidLanolin" layout="@layout/item_edit_grid_selection" />
                    <include android:id="@+id/cardAvoidRetinoid" layout="@layout/item_edit_grid_selection" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cardAvoidHighAcid" layout="@layout/item_edit_grid_selection" />
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <View android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvSeeMoreAvoid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:padding="8dp"
                android:text="@string/action_see_more"
                android:textColor="@color/button"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                style="@style/Widget.Kanila.Button.Primary"
                android:text="Lưu thay đổi" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
