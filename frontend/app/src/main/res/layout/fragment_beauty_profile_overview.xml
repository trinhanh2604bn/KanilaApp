<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_main"
    android:orientation="vertical">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/background_main"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_back"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text.Kanila.H2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="64dp"
            android:gravity="center"
            android:text="@string/beauty_profile_title"
            android:textColor="@color/accent_dark"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:src="@drawable/ic_edit"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/accent_dark" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/layoutSectionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:padding="16dp">

            <!-- Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/secondary"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgAvatar"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/hinh_nen"
                            app:shapeAppearanceOverlay="@style/CircleImage" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView style="@style/Text.Kanila.H3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/beauty_profile_card_title" android:textStyle="bold" />
                            <TextView android:id="@+id/tvSummarySkinType" style="@style/Text.Kanila.Micro" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="@string/skin_type_unknown" android:textColor="@color/button" />
                        </LinearLayout>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progressProfile" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="16dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/custom_progress_bar" />
                    <TextView android:id="@+id/tvProgressLabel" style="@style/Text.Kanila.Micro" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/profile_completion_format" android:alpha="0.7" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAnalyzeSkin"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="Quy trình đề xuất"
                            android:textColor="@color/button"
                            android:textSize="12sp"
                            app:strokeColor="@color/button"
                            app:cornerRadius="12dp"
                            app:rippleColor="@color/secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSavedRoutines"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="Quy trình đã lưu"
                            android:textColor="@color/button"
                            android:textSize="12sp"
                            app:strokeColor="@color/button"
                            app:cornerRadius="12dp"
                            app:rippleColor="@color/secondary" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Analysis Result Section (Mapped from SkinAnalysisFragment) -->
            <LinearLayout
                android:id="@+id/layoutAiAnalysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phân tích làn da AI"
                    android:textColor="@color/accent_dark"
                    android:textStyle="bold" />

                <!-- Điểm sức khỏe làn da -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHealthScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFF9FA"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/secondary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            style="@style/Text.Kanila.Micro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DIỂM SỨC KHỎE LÀN DA"
                            android:letterSpacing="0.1"
                            android:textColor="@color/button" />

                        <FrameLayout
                            android:layout_width="140dp"
                            android:layout_height="140dp"
                            android:layout_marginTop="16dp">

                            <ProgressBar
                                android:id="@+id/progressScore"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:indeterminate="false"
                                android:max="100"
                                android:progress="82"
                                android:secondaryProgress="100"
                                android:progressDrawable="@drawable/custom_progress_circle"
                                style="?android:attr/progressBarStyleHorizontal" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvScore"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="82"
                                    android:textSize="36sp"
                                    android:textColor="@color/accent_dark"
                                    android:fontFamily="@font/nunito_bold"/>
                                <TextView
                                    android:id="@+id/tvScoreStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tốt"
                                    android:textColor="@color/success"
                                    android:textSize="12sp"
                                    android:fontFamily="@font/nunito_semibold"/>
                            </LinearLayout>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvAiStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center"
                            android:alpha="0.8"
                            android:text="Chỉ số của bạn cao hơn 75% người dùng."
                            style="@style/Text.Kanila.Caption"
                            android:textColor="@color/text_main"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- AI Verdict -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/background_main"
                    app:strokeColor="@color/border_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_goal_sparkle"
                                app:tint="@color/button"
                                android:contentDescription="Verdict Icon"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                style="@style/Text.Kanila.H3"
                                android:text="AI Verdict"
                                android:textSize="14sp"
                                android:textColor="@color/accent_dark" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvAiVerdict"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Đang phân tích..."
                            style="@style/Text.Kanila.Body"
                            android:textSize="13sp"
                            android:textColor="@color/text_main"/>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Ideal Ingredients -->
                <TextView
                    style="@style/Text.Kanila.H3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Thành phần lý tưởng"
                    android:textSize="14sp"
                    android:textColor="@color/accent_dark" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal">

                    <include android:id="@+id/cardIngredient1" layout="@layout/item_grid_selection" />
                    <include android:id="@+id/cardIngredient2" layout="@layout/item_grid_selection" />
                    <include android:id="@+id/cardIngredient3" layout="@layout/item_grid_selection" />

                </LinearLayout>

            </LinearLayout>

            <!-- Sections will be added here -->
            <LinearLayout
                android:id="@+id/layoutSectionsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty State Container (Now managed by logic) -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:layout_marginTop="40dp"
                android:visibility="gone">
                <!-- Managed via Popup CTA -->
            </LinearLayout>

            <!-- Recommended Products Section -->
            <LinearLayout
                android:id="@+id/layoutRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                android:clipChildren="false"
                tools:visibility="visible">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        style="@style/Text.Kanila.H3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sản phẩm gợi ý cho bạn"
                        android:textColor="@color/accent_dark"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnViewAllRec"
                        style="@style/Text.Kanila.Micro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="@string/action_see_all"
                        android:textColor="@color/button" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecommendedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2"
                    tools:listitem="@layout/item_recommendation_product" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
