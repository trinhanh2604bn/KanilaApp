<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_drag_handle"
        android:backgroundTint="@color/border_divider" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_avatar_circle"
            android:padding="6dp"
            android:src="@drawable/ic_chat_placeholder"
            app:tint="@color/accent_dark"
            android:contentDescription="AI icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chi tiết so sánh"
                android:fontFamily="@font/nunito_bold"
                android:textColor="@color/text_main"
                android:textSize="17sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phân tích từ Kanila AI"
                android:fontFamily="@font/nunito_regular"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_divider" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Products Horizontal Scroll -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/layoutDialogComparisonProducts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Differences Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍 Điểm khác biệt"
                    android:fontFamily="@font/nunito_bold"
                    android:textColor="@color/text_main"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/layoutDialogDifferences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Pros Cons Section -->
                <LinearLayout
                    android:id="@+id/layoutDialogProsCons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    tools:visibility="visible">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚖️ Ưu / Nhược điểm"
                        android:fontFamily="@font/nunito_bold"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:layout_marginBottom="10dp" />
                        
                    <LinearLayout
                        android:id="@+id/layoutDialogProsConsContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>

                <!-- Recommendation -->
                <LinearLayout
                    android:id="@+id/layoutDialogRecommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_recommendation_highlight"
                    android:padding="14dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Gợi ý của AI"
                            android:fontFamily="@font/nunito_bold"
                            android:textColor="@color/accent_dark"
                            android:textSize="13sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆 Lựa chọn tốt nhất"
                            android:fontFamily="@font/nunito_bold"
                            android:textColor="@color/primary"
                            android:textSize="11sp"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:background="@drawable/bg_status_chip_default"
                            android:backgroundTint="#FFE4B5"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDialogRecommendationText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_regular"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="Dựa trên hồ sơ da của bạn, Serum A phù hợp hơn vì..." />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
